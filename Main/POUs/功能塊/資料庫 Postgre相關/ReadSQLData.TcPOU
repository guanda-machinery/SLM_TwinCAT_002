<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="ReadSQLData" Id="{d43e31a7-a3d2-4d43-836e-907fbae18eb2}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM ReadSQLData
VAR
	step : INT;	

	_fb_PLCDBCmdEvt : FB_PLCDBCmdEvt(sNetID:= '', tTimeout:= T#5S );
	
	_SqlCommand : STRING(1024);
	
	// 讀回的資料筆數
	read_num: UDINT;
	
	// 帶入參數
	_stPara		: ARRAY [0..5] OF ST_ExpParameter;
	
	tcMessage     : I_TcMessage;
	
	database_server_id: UDINT := 2;
	
	_uuid : STRING(36);
	
	// 取得加工起始點的 SQL資料查詢結構
	_GetPosX : SQL_GetPosX_Struct;
	
	// 取得加工資料 的 資料查詢結構
	_Get_Payload : SQL_Get_Payload_Struct;
	
	_DataExists :BOOL;
	
	// 使用暫存器
	_FileBuffNumber	: INT;
	
	
	// 寫入啟動時間
	Write_Time_para : Payload_Write_Time;
	
	
	// 使用雷射參數
	_ParaNum : INT;
	
	// 使用暫存器
	_ParaBuffNumber	: INT;
	
	_fb_FileOpen : FB_FileOpen ;
	
	_e_OpenPath : E_OpenPath;
	
	_fb_FileWrite : FB_FileWrite;
	
	_fb_FileClose : FB_FileClose;
	
	test: PVOID;
	TmrWdt: TON;
	
	systime         : FB_LocalSystemTime;
	currentTime     : DT;
	
	cnt1 : INT;
END_VAR

VAR_OUTPUT
	bBuzy	: BOOL;
	bDone	: BOOL;
	bError	: BOOL;
	
	fNext_XPos	: LREAL;
	
	stLaserParameter : LaserParameter_Data;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
bBuzy := step > 0 AND step < 10000;

bError := step > 10000;

IF bBuzy OR bError THEN
	bDone := FALSE;
END_IF

TmrWdt(in := bBuzy, PT:=T#20S);
IF TmrWdt.Q THEN
	pMsg.Push_Alarm_NoPause(
				WStrConcat("ReadSQLData", ":功能執行超時", TO_WSTRING(step))
			);
	step := step + 10000;
END_IF

IF step = 0 THEN
	RETURN;
END_IF

systime(
	bEnable:= TRUE, 
	dwCycle:= 1,
	systemTime=> );
currentTime := SYSTEMTIME_TO_DT(systime.systemTime);

Stap_0100_Get_Work_Order();
	
Stap_0200_Get_SteelData_X();

Stap_0300_Get_Payload_DataNum();

Stap_0400_Get_Payload_Data();

Stap_0500_Get_X_Next_StartPos();

Stap_1200_Get_Steel_Num_On_Wait();

Stap_2000_Set_Payload_Start();

Stap_2100_Set_Payload_Finish();

Stap_3000_Set_Steel_Start();

Stap_3100_Set_Steel_Finish();

Stap_3200_Set_Steel_SN();]]></ST>
    </Implementation>
    <Folder Name="入口" Id="{7aed78ff-99e8-43c5-9f19-76feff82cf22}" />
    <Method Name="Get_DxfFile" Id="{ff9b2820-aed3-4d5f-b7e7-21fd3c99f9db}" FolderPath="入口\">
      <Declaration><![CDATA[METHOD Get_DxfFile : BOOL
VAR_INPUT
	// 檔案的UUID
	dataUuid : STRING(36);
	
	// 使用DXF檔案暫存
	BufferNumber : int;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT bBuzy THEN
	_uuid := dataUuid;
	
	_FileBuffNumber := BufferNumber;
	
	bdone := FALSE;
	
	bBuzy := TRUE;
	
	step := 1000;
	
	Get_DxfFile := TRUE;
ELSE
	Get_DxfFile := FALSE;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="Get_LaserParame" Id="{cfe2c40e-9618-4fa7-8d3c-3c148bfca207}" FolderPath="入口\">
      <Declaration><![CDATA[METHOD Get_LaserParame : BOOL
VAR_INPUT
	// 讀取的參數ID
	paramNum : INT;
	// 放到暫存區位置
	PutToMem :INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT bBuzy THEN
	_ParaNum := paramNum;
	
	_ParaBuffNumber := PutToMem;
	
	bdone := FALSE;
	
	bBuzy := TRUE;
	
	step := 600;
	
	Get_LaserParame := TRUE;
ELSE
	Get_LaserParame := FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Get_Payload" Id="{24dc8ee3-a1bc-4965-91df-ba611e739680}" FolderPath="入口\">
      <Declaration><![CDATA[METHOD Get_Payload
VAR_INPUT
	// 區間的起始位置
	Start_Pos : LREAL;
	// 區間的結束位置
	End_Pos : LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
_Get_Payload.PosBegain := Start_Pos;
_Get_Payload.PosEnd := End_Pos;

bdone := FALSE;

step := 300;]]></ST>
      </Implementation>
    </Method>
