<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.14">
  <POU Name="StoberErrorStr" Id="{088c1f4c-c293-4bb3-88f9-ba95ec5dd8ee}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION StoberErrorStr : WSTRING
VAR_INPUT
	in_Event	: UDINT;
	in_Case		: UDINT;
END_VAR
VAR
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[CASE in_Event OF
	31:	
		StoberErrorStr := "Short/ground";
		
	32:	
		StoberErrorStr := "Short/ground internal";
		
	33:	
