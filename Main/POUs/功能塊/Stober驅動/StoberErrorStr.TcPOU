	80:
		CASE in_Case OF
			1:
				StoberErrorStr := "Illegal action(Brake)";
			2:
				StoberErrorStr := "Illegal action(Brake)";
		END_CASE
	81:
		CASE in_Case OF
			1:
				StoberErrorStr := "Motor allocation(Different motor type)";
			32:
				StoberErrorStr := "Motor allocation(Different motor)";
			33:
				StoberErrorStr := "Motor allocation(Different motor & brake)";
			34:
				StoberErrorStr := "Motor allocation(Different motor & temperature sensor)";
			35:
				StoberErrorStr := "Motor allocation(Different motor & brake & temperature sensor)";
			36:
				StoberErrorStr := "Motor allocation(Different motor & gear unit)";
			37:
				StoberErrorStr := "Motor allocation(Different motor, brake & gear unit)";
			38:
				StoberErrorStr := "Motor allocation(Different motor, temperature sensor & gear unit)";
			39:
				StoberErrorStr := "Motor allocation(Different motor, brake, temperature sensor & gear unit)";
			64:
				StoberErrorStr := "Motor allocation(Different commutation)";
			65:
				StoberErrorStr := "Motor allocation(Different commutation & brake)";
			66:
				StoberErrorStr := "Motor allocation(Different commutation & temperature sensor)";
			67:
				StoberErrorStr := "Motor allocation(Different commutation & brake & temperature sensor)";
			129:
				StoberErrorStr := "Motor allocation(Different brake)";
			130:
				StoberErrorStr := "Motor allocation(Different temperature sensor)";
			131:
				StoberErrorStr := "Motor allocation(Different brake & temperature sensor)";
			150:
				StoberErrorStr := "Motor allocation(Temperature sensor unknown)";
			
		END_CASE
	82:
		CASE in_Case OF
			1:
				StoberErrorStr := "Hall sensor(Invalid sample)";
			2:
				StoberErrorStr := "Hall sensor(Invalid sequence)";
			3:
				StoberErrorStr := "Hall sensor(Signal edge missing)";
			4:
				StoberErrorStr := "Hall sensor(X120 wire break)";
		END_CASE
	83:
		StoberErrorStr := "Failure of one/ all phases (mains)";
	84:
		StoberErrorStr := "Drop in network voltage when power section active";
	85:
		CASE in_Case OF
			1:
				StoberErrorStr := "Excessive jump in reference value(Position)";
			2:
				StoberErrorStr := "Excessive jump in reference value(Velocity)";
		END_CASE
	86:
		CASE in_Case OF
			1:
				StoberErrorStr := "Unknown LeanMotor(Motor)";
			2:
				StoberErrorStr := "Unknown LeanMotor(Cable length)";
		END_CASE
	87:
		StoberErrorStr := "Reference lostReference loss";
	88:
		StoberErrorStr := "Control panel";
	89:
		CASE in_Case OF
			1:
				StoberErrorStr := "Maximum current LM(Id)";
			2:
				StoberErrorStr := "Maximum current LM(Iq)";
		END_CASE
	90:
		CASE in_Case OF
			1:
				StoberErrorStr := "Motion block(Next motion block missing)";
			2:
				StoberErrorStr := "Motion block(Target Position in reverse direction)";
		END_CASE
	91:
		StoberErrorStr := "PM geared motor replacement";
	
END_CASE]]></ST>
