			1:
				StoberErrorStr := "Overcurrent(Normal)";
			2:
				StoberErrorStr := "Overcurrent(Fast)";
		END_CASE
		
	34:
		CASE in_Case OF
			1,23,24,25:
				StoberErrorStr := "Hardware fault(FPGA)";
			2:
				StoberErrorStr := "Hardware fault(NOV control unit)";
			3:
				StoberErrorStr := "Hardware fault(NOV-Power Unit)";
			4,5:
				StoberErrorStr := "Hardware fault(Inactive)";
			6:
				StoberErrorStr := "Hardware fault(NOV safety module)";
			7:
				StoberErrorStr := "Hardware fault(Current measurement)";
			8,9,10,11,30:
				StoberErrorStr := "Hardware fault(power supply)";
			12:
				StoberErrorStr := "Hardware fault(Timer control board)";
			13:
				StoberErrorStr := "Hardware fault(Communication module adress-/databus)";
			14:
				StoberErrorStr := "Hardware fault(Communication module signal lines)";
			15:
				StoberErrorStr := "Hardware fault(Communication module clock error)";
			16:
				StoberErrorStr := "Hardware fault(Communication module voltage missing)";
			17:
				StoberErrorStr := "Hardware fault(Communication module databus)";
			18:
				StoberErrorStr := "Hardware fault(Terminal module adress-/databus)";
			19:
				StoberErrorStr := "Hardware fault(Terminal module signal lines)";
			20:
				StoberErrorStr := "Hardware fault(Terminal module clock error)";
			21:
				StoberErrorStr := "Hardware fault(Terminal module voltage is missing)";
			22:
				StoberErrorStr := "Hardware fault(Terminal module databus)";
			26,27,28:
				StoberErrorStr := "Hardware fault(CPU)";
			29:
				StoberErrorStr := "Hardware fault(Communication)";
			31:
				StoberErrorStr := "Hardware fault(Operating unit)";
		END_CASE
		
