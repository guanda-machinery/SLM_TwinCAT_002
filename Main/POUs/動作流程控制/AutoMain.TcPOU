			END_IF
			IF NOT io.i504 THEN
				pMsg.Push_alarm("JOG FxB: D下壓不再原點上");
			END_IF
			step := 9409;
		END_IF
		
		
	9401:
		IF GroupFx.step_BD_C.bBuzy OR NOT Hmi_Web.Jog_FxB.H_Close THEN
			step := step + 1;
		END_IF
		
	9402:
		IF GroupFx.step_BD_C.bDone OR NOT Hmi_Web.Jog_FxB.H_Close THEN
			step:=9409;
		END_IF
		
	9409:
		GroupFx.BD_Stop();
		IF NOT Hmi_Web.Jog_FxB.H_Close THEN
			step:=8001;
		END_IF

(*	====================================
					保持
	====================================	*) 
	9410:
		IF GroupFx.b_BD_Clamp THEN
			GroupFx.BD_Clamp();
			step := step + 1;
		ELSE
			step := 9419;
			pMsg.Push_alarm("JOG FxB: 尚未執行FxB夾輪靠緊");
		END_IF
		
	9411:
		IF GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError THEN
			step := step + 1;
		END_IF
		
	9412:
		IF GroupFx.step_BD_C.bdone THEN
			step := step + 1;
		ELSIF GroupFx.step_BD_C.bError THEN
			pMsg.Push_alarm("JOG FxB: 執行FxB夾輪保持時發生錯誤");
		END_IF
		
	9413:
		step:=9419;
		
	9419:
		IF NOT Hmi_Web.Jog_FxB.H_Hold THEN
			step:=8001;
		END_IF

(*	====================================
					放
  	====================================*) 
	9420: // 放
		IF NOT io.i502 AND NOT io.i504 THEN
			GroupFx.BD_UnClamp(99999);
			step := step + 1;
		ELSE
			IF io.i502 THEN
				pMsg.Push_alarm("JOG FxB: B下壓不再原點上");
			END_IF
			IF io.i504 THEN
				pMsg.Push_alarm("JOG FxB: D下壓不再原點上");
			END_IF
			step := 9429;
		END_IF
		
	9421:
		IF GroupFx.step_BD_C.bBuzy OR NOT Hmi_Web.Jog_FxB.H_Open THEN
			step := step + 1;
		END_IF
		
	9422:
		IF GroupFx.step_BD_C.bDone OR NOT Hmi_Web.Jog_FxB.H_Open THEN
				step:=9429;
		END_IF
		
	9429:
		GroupFx.BD_Stop();
		IF NOT Hmi_Web.Jog_FxB.H_Open THEN
			step:=8001;
		END_IF
		
(*	====================================
					下壓夾
  	====================================*) 
		
	9430:
		GroupFx.B_Press();
		GroupFx.D_Press();
		step := step + 1;
		
	9431:
		IF (GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			(GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError) THEN
			step := step + 1;
		END_IF
		
	9432:
		IF (GroupFx.step_B_P.bDone AND GroupFx.step_B_P.bDone) OR
			GroupFx.step_D_P.bError OR GroupFx.step_D_P.bError OR
			NOT Hmi_Web.Jog_FxB.V_Close THEN
			step := 9439;
		END_IF
		
	9439:
		IF NOT Hmi_Web.Jog_FxB.V_Close THEN
			step:=8001;
		END_IF
		
(*	====================================
					下壓放
  	====================================*) 
		
	9440:
		GroupFx.B_UnPress();
		GroupFx.D_UnPress();
		step := step + 1;
		
	9441:
		IF (GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			(GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError) THEN
			step := step + 1;
		END_IF
		
	9442:
		IF (GroupFx.step_B_P.bDone AND GroupFx.step_B_P.bDone) OR
			GroupFx.step_D_P.bError OR GroupFx.step_D_P.bError OR
			NOT Hmi_Web.Jog_FxB.V_Open THEN
