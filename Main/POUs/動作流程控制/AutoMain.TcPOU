    <Action Name="step_7800_FindZ" Id="{78554766-b253-4c2b-86e4-fe4f195d427b}" FolderPath="測試用區域\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	7800: // 設定 工件大小
		ProjectData.Now_Steel.Height	:= 400;
		ProjectData.Now_Steel.Width		:= 200;
		
	7801: // 設定 各軸組 X參考座標
		GroupA.Set_X_Ref(Value := Last_Pos);
		GroupB.Set_X_Ref(Value := Last_Pos);
		GroupC.Set_X_Ref(Value := Last_Pos);
		GroupD.Set_X_Ref(Value := Last_Pos);
		step := step + 1;
		
	7802: // 設定 各軸組 X參考座標
		GroupA.Set_Y_Ref(Value := MaCfg.laserA_Y_ReferencePos - ProjectData.Now_Steel.Width);
		GroupB.Set_Y_Ref(Value := MaCfg.laserB_Y_ReferencePos - ProjectData.Now_Steel.Height);
		GroupC.Set_Y_Ref(Value := MaCfg.laserC_Y_ReferencePos);
		GroupD.Set_Y_Ref(Value := MaCfg.laserD_Y_ReferencePos);
		step := step + 1;
		
	7810:
		GroupB.FindZ();
		GroupC.FindZ();
		GroupD.FindZ();
		step := step + 1;
		
	7811:
		IF 	(GroupB.StepA.bBuzy OR GroupB.StepA.bError) AND
			(GroupC.StepA.bBuzy OR GroupC.StepA.bError) AND
			(GroupD.StepA.bBuzy OR GroupD.StepA.bError) THEN
				step := step + 1;
		END_IF
		
	7812:
		IF 	(GroupB.StepA.bDone) AND
			(GroupC.StepA.bDone) AND 
			(GroupD.StepA.bDone) THEN
				GroupB_Now_Z := GroupB.Az.Pos;	// 記錄軸組B的雷射距離，小於200的料使用
			 	step := step + 1;
		ELSIF 
			(GroupB.StepA.bError) OR 
			(GroupC.StepA.bError) OR 
			(GroupD.StepA.bError) THEN
				step := step + 10000;
		END_IF
		
	7813:
		GroupA.FindZ();
		
		step := step + 1;
		
	7814:
		IF 	(GroupA.StepA.bBuzy OR GroupA.StepA.bError) THEN
				step := step + 1;
		END_IF
		
	7815:
		IF 	(GroupA.StepA.bDone) THEN
			step := step + 1;
		ELSIF 
			(GroupA.StepA.bError) THEN
				step := step + 10000;
		END_IF
		
	7820:
		GroupA.XY_Move_Ref(0, (ProjectData.Now_Steel.Width / 2), 50);
		GroupB.XY_Move_Ref(0, (ProjectData.Now_Steel.Height / 2), 50);
		GroupC.XY_Move_Ref(0, (ProjectData.Now_Steel.Width / 2), 50);
		GroupD.XY_Move_Ref(0, (ProjectData.Now_Steel.Height / 2), 50);
		step := step + 1;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_7900_SensorTest" Id="{2a2185c3-79fd-40b1-a47d-319d15089cdf}" FolderPath="測試用區域\">
      <Implementation>
        <ST><![CDATA[(*====================================
		Group A X軸 Jog模式
  ====================================*) 
hmi.Jog_move_to_bBuzy := step > 7900 AND step < 7920;

IF hmi.Jog_move_to_bBuzy THEN
	hmi.Jog_move_to_bDone := FALSE;
END_IF
  
CASE step OF

	7900:
		IF hmi.Jog_move_to_start THEN
			hmi.Jog_move_to_start := FALSE;
			step := step + 1;
		END_IF
		
	7901:
		FOR SensorTest.posCount := 0 TO 49 DO
			SensorTest.MovePos[SensorTest.posCount] := (SensorTest.posCount + 1) * 220;
		END_FOR
		SensorTest.MovePos[50] := 0;
		step := step + 1;
			
	7902:
		SensorTest.posCount := 0;
		step := step + 1;
		
	7903:
		IF hmi.Jog_move_to_start THEN
			hmi.Jog_move_to_start := FALSE;
			step := step + 1;
		END_IF
		
	7904:
		step := 7909;
		
	7909:
		IF SensorTest.posCount <= SensorTest.posCountMax THEN
			hmi.Jog_move_to := SensorTest.MovePos[SensorTest.posCount];
			step := 7910;
		ELSE
			step := 7900;
		END_IF
		
		
	7910:
		Fx.AbsMove(hmi.Jog_move_to, 100);
		step := step + 1;
		
	7911:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	7912:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	7913:
		tmr01.PT := T#5S;
		tmr01.in := TRUE;
		IF tmr01.Q THEN
			tmr01.in := FALSE;
			step := step + 1;
		END_IF
		
	7914:
		step := 7920;
		
	7920:
		hmi.Jog_move_to_bDone := TRUE;
		step := step + 1;
		
	7921:
		tmr01.PT := T#0.5S;
		tmr01.in := TRUE;
		IF tmr01.Q THEN
			tmr01.in := FALSE;
			step := step + 1;
		END_IF
	
	7922:
		IF NOT hmi.Jog_move_to_bDone THEN
			SensorTest.posCount := SensorTest.posCount + 1;
			step := 7909;
		END_IF
		
		
	7930:
		axis.Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := 10000;
		axis.Encoder_FxB_PosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := 10000;
		step := step + 1;
		
	7931:
		axis.Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := TRUE;
		axis.Encoder_FxB_PosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := TRUE;
		step := step + 1;
		
	7932:
		IF axis.Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done AND
			axis.Encoder_FxB_PosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			step := step + 1;
		END_IF
		
	7933:
		axis.Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		axis.Encoder_FxB_PosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		step := step + 1;
		
	7934:
		Sensor.Set_SensoeZero := TRUE;
		step := step + 1;
		
	7935:
		IF ABS(Sensor.sensor_test_pos) < 2 THEN
 			Sensor.Set_SensoeZero := FALSE;
			step := step + 1;
		END_IF
		
	7936:
		
		step := 7900;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_8000_Jog" Id="{c27e7acc-5ac3-4b59-9fa3-c17028cc9d68}" FolderPath="JOG流程8100_9400\">
      <Implementation>
        <ST><![CDATA[(*====================================
				Jog模式
  ====================================*) 
IF (Hmi_Web.Auto_Start OR Hmi_Web.Auto_OneCycle_Start) AND step >= 8000 AND step < 9800 THEN
	step := 9800;
END_IF

IF SystemError THEN
	Hmi.Jog_X_P := FALSE;
	Hmi.Jog_X_N := FALSE;
	Hmi.Jog_Y_P := FALSE;
	Hmi.Jog_Y_N := FALSE;
	Hmi.Jog_Z_P := FALSE;
	Hmi.Jog_Z_N := FALSE;
END_IF

IF step = 0 THEN
	RETURN;
END_IF

step_8100_Jog_GroupA_X();
step_8200_Jog_GroupA_Y();
step_8300_Jog_GroupA_Z();

step_8400_Jog_GroupB_X();
step_8500_Jog_GroupB_Y();
step_8600_Jog_GroupB_Z();

step_8700_Jog_GroupC_X();
step_8800_Jog_GroupC_Y();
step_8900_Jog_GroupC_Z();

step_9000_Jog_GroupD_X();
step_9100_Jog_GroupD_Y();
step_9200_Jog_GroupD_Z();
step_9300_Jog_GroupFx_A();
step_9400_Jog_GroupFx_B();

step_9700_Jog_SetLimit();



IF step < 9700 OR step >= 9800 THEN
	IF Hmi.Jog_Set_GroupA THEN
		Hmi.Jog_Set_GroupA := FALSE;
		IF Hmi.Jog_GroupSelect <> 1 THEN
			Hmi.Jog_GroupSelect := 1;
		ELSE
			Hmi.Jog_GroupSelect := 0;
		END_IF
		
	ELSIF Hmi.Jog_Set_GroupB THEN
		Hmi.Jog_Set_GroupB := FALSE;
		IF Hmi.Jog_GroupSelect <> 2 THEN
			Hmi.Jog_GroupSelect := 2;
		ELSE
			Hmi.Jog_GroupSelect := 0;
		END_IF
		
	ELSIF Hmi.Jog_Set_GroupC THEN
		Hmi.Jog_Set_GroupC := FALSE;
		IF Hmi.Jog_GroupSelect <> 3 THEN
			Hmi.Jog_GroupSelect := 3;
		ELSE
			Hmi.Jog_GroupSelect := 0;
		END_IF	
		
	ELSIF Hmi.Jog_Set_GroupD THEN
		Hmi.Jog_Set_GroupD := FALSE;
		IF Hmi.Jog_GroupSelect <> 4 THEN
			Hmi.Jog_GroupSelect := 4;
		ELSE
			Hmi.Jog_GroupSelect := 0;
		END_IF	
	END_IF
END_IF





CASE step OF
	8000: // jog按鍵
		fbWritePersistentData.START := FALSE;
	
		Hmi.Jog_Mode := FALSE;
		Hmi.Mode_Select := 1;
		
		ExpConver.FeedJogStart();
		
		GaX.PowerOn();
		GaY.PowerOn();
		GaZ.PowerOn();
		GbX.PowerOn();
		GbY.PowerOn();
		GbZ.PowerOn();
		GcX.PowerOn();
		GcY.PowerOn();
		GcZ.PowerOn();
		GdX.PowerOn();
		GdY.PowerOn();
		GdZ.PowerOn();
		Fx.PowerOn();
		step := step + 1;
		
	8001:
		HMI.Mode_Select := 1;
		CASE Hmi.Jog_GroupSelect OF
			1:
				// 按鍵JOG 
				HMI.Jog_GroupSelect := 1;
				IF Hmi.Jog_X_P THEN
					step := 8100;
				ELSIF Hmi.Jog_X_N THEN
					step := 8150;
				ELSIF Hmi.Jog_Y_P THEN
					step := 8200;
				ELSIF Hmi.Jog_Y_N THEN
					step := 8250;
				ELSIF Hmi.Jog_Z_P THEN
					step := 8300;
				ELSIF Hmi.Jog_Z_N THEN
					step := 8350;
				END_IF
				
			2:
				// 按鍵JOG 
				HMI.Jog_GroupSelect := 2;
				IF Hmi.Jog_X_P THEN
					step := 8400;
				ELSIF Hmi.Jog_X_N THEN
					step := 8450;
				ELSIF Hmi.Jog_Y_P THEN
					step := 8500;
				ELSIF Hmi.Jog_Y_N THEN
					step := 8550;
				ELSIF Hmi.Jog_Z_P THEN
					step := 8600;
				ELSIF Hmi.Jog_Z_N THEN
					step := 8650;
				END_IF
				
			3:
				// 按鍵JOG 
				HMI.Jog_GroupSelect := 3;
				IF Hmi.Jog_X_P THEN
					step := 8700;
				ELSIF Hmi.Jog_X_N THEN
					step := 8750;
				ELSIF Hmi.Jog_Y_P THEN
					step := 8800;
				ELSIF Hmi.Jog_Y_N THEN
					step := 8850;
				ELSIF Hmi.Jog_Z_P THEN
					step := 8900;
				ELSIF Hmi.Jog_Z_N THEN
					step := 8950;
				END_IF
				
			4:
				// 按鍵JOG 
				HMI.Jog_GroupSelect := 4;
				IF Hmi.Jog_X_P THEN
					step := 9000;
				ELSIF Hmi.Jog_X_N THEN
					step := 9050;
				ELSIF Hmi.Jog_Y_P THEN
					step := 9100;
				ELSIF Hmi.Jog_Y_N THEN
					step := 9150;
				ELSIF Hmi.Jog_Z_P THEN
					step := 9200;
				ELSIF Hmi.Jog_Z_N THEN
					step := 9250;
				END_IF
				
			5:
				// 按鍵JOG 
				IF Hmi_Web.Jog_FxA.H_Close THEN
					step := 9000;
				ELSIF Hmi.Jog_X_N THEN
					step := 9050;
				ELSIF Hmi.Jog_Y_P THEN
					step := 9100;
				ELSIF Hmi.Jog_Y_N THEN
					step := 9150;
				ELSIF Hmi.Jog_Z_P THEN
					step := 9200;
				ELSIF Hmi.Jog_Z_N THEN
					step := 9250;
				END_IF
				
		END_CASE
		
		IF Hmi_Web.Jog_Ga.X_P THEN
			step := 8100;
		ELSIF Hmi_Web.Jog_Ga.X_N THEN
			step := 8120;
		ELSIF Hmi_Web.Jog_Ga.Y_P THEN
			step := 8200;
		ELSIF Hmi_Web.Jog_Ga.Y_N THEN
			step := 8220;
		ELSIF Hmi_Web.Jog_Ga.Z_P THEN
			step := 8300;
		ELSIF Hmi_Web.Jog_Ga.Z_N THEN
			step := 8320;
		ELSIF Hmi_Web.Jog_Gb.X_P THEN
			step := 8400;
		ELSIF Hmi_Web.Jog_Gb.X_N THEN
			step := 8420;
		ELSIF Hmi_Web.Jog_Gb.Y_P THEN
			step := 8500;
		ELSIF Hmi_Web.Jog_Gb.Y_N THEN
			step := 8520;
		ELSIF Hmi_Web.Jog_Gb.Z_P THEN
			step := 8600;
		ELSIF Hmi_Web.Jog_Gb.Z_N THEN
			step := 8620;
		ELSIF Hmi_Web.Jog_Gc.X_P THEN
			step := 8700;
		ELSIF Hmi_Web.Jog_Gc.X_N THEN
			step := 8720;
		ELSIF Hmi_Web.Jog_Gc.Y_P THEN
			step := 8800;
		ELSIF Hmi_Web.Jog_Gc.Y_N THEN
			step := 8820;
		ELSIF Hmi_Web.Jog_Gc.Z_P THEN
			step := 8900;
		ELSIF Hmi_Web.Jog_Gc.Z_N THEN
			step := 8920;
		ELSIF Hmi_Web.Jog_Gd.X_P THEN
			step := 9000;
		ELSIF Hmi_Web.Jog_Gd.X_N THEN
			step := 9020;
		ELSIF Hmi_Web.Jog_Gd.Y_P THEN
			step := 9100;
		ELSIF Hmi_Web.Jog_Gd.Y_N THEN
			step := 9120;
		ELSIF Hmi_Web.Jog_Gd.Z_P THEN
			step := 9200;
		ELSIF Hmi_Web.Jog_Gd.Z_N THEN
			step := 9220;
		ELSIF Hmi_Web.Jog_FxA.H_Close THEN
			step := 9300;
		ELSIF Hmi_Web.Jog_FxA.H_Hold THEN
			step := 9310;
		ELSIF Hmi_Web.Jog_FxA.H_Open THEN
			step := 9320;
		ELSIF Hmi_Web.Jog_FxA.V_Close THEN
			step := 9330;
		ELSIF Hmi_Web.Jog_FxA.V_Open THEN
			step := 9340;
		ELSIF Hmi_Web.Jog_FxA.P THEN
			step := 9360;
		ELSIF Hmi_Web.Jog_FxA.N THEN
			step := 9370;
		ELSIF Hmi_Web.Jog_FxA.ExEncTouch THEN
			IO.q311 := TRUE;
			IO.q311 := FALSE;
		ELSIF Hmi_Web.Jog_FxA.ExEncExit THEN
			IO.q311 := FALSE;
			IO.q311 := TRUE;
		ELSIF Hmi_Web.Jog_FxB.H_Close THEN
			step := 9400;
		ELSIF Hmi_Web.Jog_FxB.H_Hold THEN
			step := 9410;
		ELSIF Hmi_Web.Jog_FxB.H_Open THEN
			step := 9420;
		ELSIF Hmi_Web.Jog_FxB.V_Close THEN
			step := 9430;
		ELSIF Hmi_Web.Jog_FxB.V_Open THEN
			step := 9440;
		ELSIF Hmi_Web.Jog_FxB.ExEncTouch THEN
			IO.q313 := TRUE;
			IO.q314 := FALSE;
		ELSIF Hmi_Web.Jog_FxB.ExEncExit THEN
			IO.q313 := FALSE;
			IO.q314 := TRUE;
		ELSE
			IO.q311 := FALSE;
			IO.q311 := FALSE;
			IO.q313 := FALSE;
			IO.q314 := FALSE;
		END_IF
		
		IF Hmi.Jog_Mode OR Hmi.MPG_Mode OR Hmi.Auto_Mode OR
			Hmi.Set_X_P_Limite OR Hmi.Set_X_Home OR
			Hmi.Set_Y_P_Limite OR Hmi.Set_Y_Home OR
			Hmi.Set_Z_P_Limite OR Hmi.Set_Z_Home OR
			Hmi_Web.Auto_Mode OR Hmi_Web.Auto_OneCycle_Start OR
			Hmi_Web.Jog_Mode
 		THEN
			step := step + 1;
		END_IF
		
	8002:
		IF Hmi.Jog_Mode OR Hmi_Web.Jog_Mode THEN
			Hmi.Jog_Mode := FALSE;
			Hmi_Web.Jog_Mode := FALSE;
			step := 9910;
			ExpConver.Feed_Reset();
			Hmi.Mode_Select := 0;
		ELSIF Hmi.MPG_Mode OR Hmi.Auto_Mode OR
			Hmi_Web.Auto_Mode OR Hmi_Web.Auto_OneCycle_Start OR Hmi_Web.Auto_Start
		 THEN
			step := 0;
		ELSIF 
		Hmi.Set_X_P_Limite OR Hmi.Set_X_Home OR
		Hmi.Set_Y_P_Limite OR Hmi.Set_Y_Home OR
		Hmi.Set_Z_P_Limite OR Hmi.Set_Z_Home
		THEN
			step := 9800;
		END_IF
		
	8003:
		Hmi.Jog_Mode := FALSE;
		ExpConver.Feed_Reset();
		step := 9910;
		Hmi.Mode_Select := 0;
		
		
	8010:
		Jog_MPG.Start();
		HMI.Jog_GroupSelect := Jog_MPG.in_iAxisGroup;
		Hmi.MPG_Mode := FALSE;
		Hmi.Mode_Select := 2;
		step := step + 1;
		
	8011:
		HMI.Mode_Select := 2;
		IF Hmi.Jog_Mode OR Hmi.MPG_Mode OR Hmi.Auto_Mode OR
			Hmi.Set_X_P_Limite OR Hmi.Set_X_Home OR
			Hmi.Set_Y_P_Limite OR Hmi.Set_Y_Home OR
			Hmi.Set_Z_P_Limite OR Hmi.Set_Z_Home
 		THEN
			step := step + 1;
		END_IF
		
		IF NOT Jog_MPG.Active THEN
			step := 8010;
		END_IF
		
	8012:
		Jog_MPG.Stop();
		step := step + 1;
		
	8013:
		
		IF NOT Jog_MPG.Active THEN
			step := step + 1;
		END_IF
		
	8014:
		step := step + 1;
		
	8015:
		GaX.Stop();
		GaY.Stop();
		GaZ.Stop();
		GbX.Stop();
		GbY.Stop();
		GbZ.Stop();
		GcX.Stop();
		GcY.Stop();
		GcZ.Stop();
		GdX.Stop();
		GdY.Stop();
		GdZ.Stop();
		IF NOT GaX.Axis1.Status.Moving AND 
			NOT GaY.Axis1.Status.Moving AND 
			NOT GaZ.Axis1.Status.Moving AND 
			NOT GbX.Axis1.Status.Moving AND 
			NOT GbY.Axis1.Status.Moving AND 
			NOT GbZ.Axis1.Status.Moving AND 
			NOT GcX.Axis1.Status.Moving AND 
			NOT GcY.Axis1.Status.Moving AND 
			NOT GcZ.Axis1.Status.Moving AND 
			NOT GdX.Axis1.Status.Moving AND 
			NOT GdY.Axis1.Status.Moving AND 
			NOT GdZ.Axis1.Status.Moving
		THEN
			step := step + 1;
		END_IF
		
	8016:
		IF Hmi.MPG_Mode THEN
			Hmi.MPG_Mode := FALSE;
			step := 0;
			Hmi.Mode_Select := 0;
		ELSIF Hmi.Jog_Mode OR Hmi.Auto_Mode THEN
			step := 0;
		ELSIF 
		Hmi.Set_X_P_Limite OR Hmi.Set_X_Home OR
		Hmi.Set_Y_P_Limite OR Hmi.Set_Y_Home OR
		Hmi.Set_Z_P_Limite OR Hmi.Set_Z_Home
		THEN
			step := 9800;
		END_IF
		
	(* 寫入停電記憶 *)
	8020:
		fbWritePersistentData.START := TRUE;
		step := step  + 1;
		
	8021:
		IF NOT fbWritePersistentData.BUSY THEN
			fbWritePersistentData.START := FALSE;
			step := step  + 1;
		END_IF
		
	8022:
		step := 8000;
		
	
	9800:
		Hmi.Jog_X_P := FALSE;
		Hmi.Jog_X_N := FALSE;
		Hmi.Jog_Y_P := FALSE;
		Hmi.Jog_Y_N := FALSE;
		Hmi.Jog_Z_P := FALSE;
		Hmi.Jog_Z_N := FALSE;
		
		GaX.bJogMode := FALSE;
		GaY.bJogMode := FALSE;
		GaZ.bJogMode := FALSE;
		
		GbX.bJogMode := FALSE;
		GbY.bJogMode := FALSE;
		GbZ.bJogMode := FALSE;
		
		GcX.bJogMode := FALSE;
		GcY.bJogMode := FALSE;
		GcZ.bJogMode := FALSE;

		GdX.bJogMode := FALSE;
		GdY.bJogMode := FALSE;
		GdZ.bJogMode := FALSE;

		Hmi.MPG_Mode:=FALSE;
		
		ExpConver.FeedJogExit();
		
		step := step + 1;
		
	
		
	9801:
		pmsg.Push_Info("退出手動模式");
		step:=9900;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_8100_Jog_GroupA_X" Id="{e799dead-5ecb-44cb-96a8-211ac7ea9e16}" FolderPath="JOG流程8100_9400\">
      <Implementation>
        <ST><![CDATA[(*====================================
		Group A X軸 Jog模式
  ====================================*) 

CASE step OF
(*====================================
				正方向
  ====================================*) 

	8100:
		IF PosC.GcX_P_Limite > 0 THEN
			GcX.AbsMove(PosC.GcX_P_Limite - 0.1, 100 * Hmi.Jog_Speed * 0.01);
		ELSE
			GcX.RelMove(99999, 100 * Hmi.Jog_Speed * 0.01);
		END_IF
		step := step + 1;
		
		
	8101:
		IF	GcX.bDone OR		// 位置(軟體極限)到達
			NOT GcX.OutLimiter OR		// 	硬體極限到達
			(NOT HMI.Jog_X_P AND NOT hmi_web.Jog_Ga.X_P) THEN 		// 人機按鍵放開
				step := 8109;
		END_IF
		
	8109:
		GcX.Stop();
		IF (NOT HMI.Jog_X_P AND NOT hmi_web.Jog_Ga.X_P) THEN
			step:=8001;
		END_IF
		
(*====================================
				負方向
  ====================================*) 
		
	8120:
		IF PosC.GcX_N_Limite <> 0 THEN
			GcX.AbsMove(PosC.GcX_N_Limite + 0.1, 100 * Hmi.Jog_Speed * 0.01);
		ELSE
			GcX.RelMove(-99999, 100 * Hmi.Jog_Speed * 0.01);
		END_IF
		step := step + 1;
		
		
	8121:
		IF GcX.bDone OR		// 位置(軟體極限)到達
			NOT GcX.inLimiter OR		// 	硬體極限到達
			(NOT HMI.Jog_X_N AND NOT hmi_web.Jog_Ga.X_N) THEN  			// 人機按鍵放開
			step:=8129;
		END_IF
		
	8129:
		GcX.Stop();
		IF (NOT HMI.Jog_X_N AND NOT hmi_web.Jog_Ga.X_N) THEN
			step:=8001;
		END_IF
		


END_CASE]]></ST>
      </Implementation>
    </Action>
