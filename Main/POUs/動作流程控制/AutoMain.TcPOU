    <Action Name="step_9300_Jog_GroupFx_A" Id="{4ea608c7-d2b7-4028-abc8-0bf6443d9578}" FolderPath="JOG流程8100_9400\">
      <Implementation>
        <ST><![CDATA[(*====================================
		Group FX A軸 Jog模式
  ====================================*) 

CASE step OF
(*====================================
				夾
  ====================================*) 

	9300: // 夾
		IF NOT io.i501 AND NOT io.i503 THEN
			GroupFx.AC_Clamp();
			step := step + 1;
		ELSE
			IF io.i501 THEN
				pMsg.Push_alarm("JOG FxB: B下壓不再原點上");
			END_IF
			IF io.i503 THEN
				pMsg.Push_alarm("JOG FxB: D下壓不再原點上");
			END_IF
			step := 9309;
		END_IF
		
	9301:
		IF GroupFx.step_AC_C.bBuzy OR NOT Hmi_Web.Jog_FxA.H_Close THEN
			step := step + 1;
		END_IF
		
	9302:
		IF GroupFx.step_AC_C.bDone OR NOT Hmi_Web.Jog_FxA.H_Close THEN
			step:=9309;
		END_IF
		
	9309:
		GroupFx.AC_Stop();
		IF NOT Hmi_Web.Jog_FxA.H_Close THEN
			step:=8001;
		END_IF

(*====================================
				保持
  ====================================*) 
	9310:
		IF GroupFx.b_AC_Clamp THEN
			GroupFx.AC_Clamp();
			step := step + 1;
		ELSE
			step := 9319;
			pMsg.Push_alarm("JOG FxA: 尚未執行FxA夾輪靠緊");
		END_IF
		
	9311:
		IF GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError THEN
			step := step + 1;
		END_IF
		
	9312:
		IF GroupFx.step_AC_C.bdone THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError THEN
			pMsg.Push_alarm("JOG FxA: 執行FxA夾輪保持時發生錯誤");
		END_IF
		
	9313:
		step:=9319;
		
	9319:
		IF NOT Hmi_Web.Jog_FxA.H_Hold THEN
			step:=8001;
		END_IF

(*====================================
				放
  ====================================*) 
	9320: // 放
		IF NOT io.i501 AND NOT io.i503 THEN
			GroupFx.AC_UnClamp(99999);
			step := step + 1;
		ELSE
			IF io.i501 THEN
				pMsg.Push_alarm("JOG FxB: B下壓不再原點上");
			END_IF
			IF io.i503 THEN
				pMsg.Push_alarm("JOG FxB: D下壓不再原點上");
			END_IF
			step := 9329;
		END_IF
		
	9321:
		IF GroupFx.step_AC_C.bBuzy OR NOT Hmi_Web.Jog_FxA.H_Open THEN
			step := step + 1;
		END_IF
		
	9322:
		IF GroupFx.step_AC_C.bDone OR NOT Hmi_Web.Jog_FxA.H_Open THEN
			step:=9329;
		END_IF
		
	9329:
		GroupFx.AC_Stop();
		IF NOT Hmi_Web.Jog_FxA.H_Open THEN
			step:=8001;
		END_IF
		
(*====================================
				下壓夾
  ====================================*) 
		
	9330:
		GroupFx.A_Press();
		GroupFx.C_Press();
		step := step + 1;
		
	9331:
		IF (GroupFx.step_A_P.bBuzy OR GroupFx.step_A_P.bError) AND
			(GroupFx.step_C_P.bBuzy OR GroupFx.step_C_P.bError) THEN
			step := step + 1;
		END_IF
		
	9332:
		IF (GroupFx.step_A_P.bDone AND GroupFx.step_A_P.bDone) OR
			GroupFx.step_C_P.bError OR GroupFx.step_C_P.bError OR
			NOT Hmi_Web.Jog_FxA.V_Close THEN
			step := 9339;
		END_IF
		
	9339:
		IF NOT Hmi_Web.Jog_FxA.V_Close THEN
			step:=8001;
		END_IF
		
(*====================================
				下壓放
  ====================================*) 
		
	9340:
		GroupFx.A_UnPress();
		GroupFx.C_UnPress();
		step := step + 1;
		
	9341:
		IF (GroupFx.step_A_P.bBuzy OR GroupFx.step_A_P.bError) AND
			(GroupFx.step_C_P.bBuzy OR GroupFx.step_C_P.bError) THEN
			step := step + 1;
		END_IF
		
	9342:
		IF (GroupFx.step_A_P.bDone AND GroupFx.step_A_P.bDone) OR
			GroupFx.step_C_P.bError OR GroupFx.step_C_P.bError OR
			NOT Hmi_Web.Jog_FxA.V_Open THEN
			step := 9349;
		END_IF
		
	9349:
		IF NOT Hmi_Web.Jog_FxA.V_Open THEN
			step:=8001;
		END_IF
		
(*====================================
				滾輪正轉
  ====================================*) 
		
	9360:
		Fx.RelMove(100000, 200 * Hmi.Jog_Speed * 0.01);
		step := step + 1;
		
	9361:
		IF Fx.bDone OR Fx.bError OR NOT Hmi_Web.Jog_FxA.P THEN
			step := 9369;
		END_IF
		
	9369:
		Fx.Stop();
		IF NOT Hmi_Web.Jog_FxA.P THEN
			step:=8001;
		END_IF
(*====================================
				滾輪反轉
  ====================================*) 
		
	9370:
		Fx.RelMove(-100000, 200 * Hmi.Jog_Speed * 0.01);
		step := step + 1;
		
	9371:
		IF Fx.bDone OR Fx.bError OR NOT Hmi_Web.Jog_FxA.N THEN
			step := 9389;
		END_IF
		
	9379:
		Fx.Stop();
		IF NOT Hmi_Web.Jog_FxA.N THEN
			step:=8001;
		END_IF
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_9400_Jog_GroupFx_B" Id="{b3bfee0c-2d0d-4c88-a8a1-984085440ece}" FolderPath="JOG流程8100_9400\">
      <Implementation>
        <ST><![CDATA[(*====================================
		Group FX B軸 Jog模式
  ====================================*) 

CASE step OF
(*	====================================
					夾
