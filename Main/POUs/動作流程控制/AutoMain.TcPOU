	8820:
		IF PosC.GaY_N_Limite <> 0 AND NOT Hmi.Jog_UnLimite THEN
			GaY.AbsMove(PosC.GaY_N_Limite + 0.1, 100 * Hmi.Jog_Speed * 0.01);
		ELSE
			GaY.RelMove(-99999, 100 * Hmi.Jog_Speed * 0.01);
		END_IF
		step := step + 1;
		
		
	8821:
		IF GaY.bDone OR		// 位置(軟體極限)到達
			NOT GaY.inLimiter OR		// 	硬體極限到達
			(NOT HMI.Jog_Y_N AND NOT hmi_web.Jog_Gc.Y_N) THEN 		// 人機按鍵放開
				step := 8829;
		END_IF
		
	8829:
		GaY.Stop();
		IF (NOT HMI.Jog_Y_N AND NOT hmi_web.Jog_Gc.Y_N) THEN
			step := 8001;
		END_IF
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_8900_Jog_GroupC_Z" Id="{53227d1d-026f-48c0-ad4b-19eb9bfd66e5}" FolderPath="JOG流程8100_9400\">
      <Implementation>
        <ST><![CDATA[(*====================================
		Group C Z軸 Jog模式
  ====================================*) 

CASE step OF
(*====================================
				正方向
  ====================================*) 

	8900:
		IF PosC.GaZ_P_Limite > 0 THEN
			GaZ.AbsMove(PosC.GaZ_P_Limite - 0.1, 100 * Hmi.Jog_Speed * 0.01);
		ELSE
			GaZ.RelMove(99999, 100 * Hmi.Jog_Speed * 0.01);
		END_IF
		step := step + 1;
		
		
	8901:
		IF	GaZ.bDone OR		// 位置(軟體極限)到達
			NOT GaZ.OutLimiter OR		// 	硬體極限到達
			(NOT HMI.Jog_Z_P AND NOT hmi_web.Jog_Gc.Z_P) THEN 		// 人機按鍵放開
				step := 8909;
		END_IF
		
	8909:
		GaZ.Stop();
		IF (NOT HMI.Jog_Z_P AND NOT hmi_web.Jog_Gc.Z_P) THEN
			step := 8001;
		END_IF
		
(*====================================
				負方向
  ====================================*) 
		
	8920:
		IF PosC.GaZ_N_Limite <> 0 THEN
			GaZ.AbsMove(PosC.GaZ_N_Limite + 0.1, 100 * Hmi.Jog_Speed * 0.01);
		ELSE
			GaZ.RelMove(-99999, 100 * Hmi.Jog_Speed * 0.01);
		END_IF
		step := step + 1;
		
		
	8921:
		IF GaZ.bDone OR		// 位置(軟體極限)到達
			NOT GaZ.inLimiter OR		// 	硬體極限到達
			(NOT HMI.Jog_Z_N AND NOT hmi_web.Jog_Gc.Z_N) THEN  			// 人機按鍵放開
				 step := 8929;
		END_IF
		
	8929:
		GaZ.Stop();
		IF (NOT HMI.Jog_Z_N AND NOT hmi_web.Jog_Gc.Z_N) THEN
			step := 8001;
		END_IF
END_CASE]]></ST>
      </Implementation>
    </Action>
