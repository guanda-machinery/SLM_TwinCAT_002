<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="AutoMain" Id="{640ea801-bc75-4e57-87c7-5cbed9d57d57}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM AutoMain
VAR
	
	step: DINT;
	
	// 自動執行中 的 進料動作流程
	step_Feed: Sub_Step;
	
	startStep: DINT;

	PutFloor: UINT;
	GetFloor: UINT;
	tmr01: TON;
	tmr8000: TON;
	Jog_Ldp: ARRAY[0..15] OF R_TRIG;

	fbWritePersistentData: FB_WritePersistentData;


	tmr_ErrorReset: TON;
	tmr_AutoLock: TON;
	
	sFilename: ARRAY [1..9] OF STRING := ['TEST-100-1', 'TEST-100-2', 'TEST-100-3', 'TEST-100-4', 'TEST-100-5', 'TEST-100-6', 'TEST-100-7', 'TEST-100-8', 'TEST-100-9'];
	fPoint: ARRAY [1..9, 1..2] OF REAL := [2(0.0), 100, 0.0, 100, 0.0, -200, 2(100), 0.0, 100, 0.0, -200, 2(100), 0.0, 100, 0.0];
	
	fPoint2: ARRAY [1..4, 1..2] OF REAL := [2(0.0), 80, 0.0, 80, 3(0)];
	
	fPointStart: ARRAY [1..2] OF REAL;
	
	iCount : INT;
	posCount: INT;
	
	NowWidth : LREAL;
	i: DINT;
	
	// 上次取得位置
	Last_Pos: LREAL;
	MaxWidth: LREAL;
	MinWidth: LREAL;
	FormatString: FB_FormatString2;
	
	_debug_X_NextPos_count :INT;
	_debug_X_NextPos : ARRAY [0..99] OF LREAL;
	
	// 軸組B雷射的距離
	GroupB_Now_Z: LREAL;
	// 回原點模式
	homeMode: BOOL;
	
	_log : Step_Log; 
END_VAR

VAR_OUTPUT
	bBuzy: BOOL;
	bError: BOOL;
	bDone: BOOL;
	iErrorId : DINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[WebHmi();

GroupA();
GroupB();
GroupC();
GroupD();

IF (EStop OR SystemError) AND bBuzy THEN
	hmi.Auto_bDone := FALSE;
	IF bBuzy THEN
		step := step  + 10000;
	END_IF
END_IF

bBuzy := (step >= 100 AND step < 10000);
bError := (step > 10000);

tmr_ErrorReset(in:= bError, PT:=T#1S);
IF tmr_ErrorReset.Q THEN
	iErrorId := step;
	step := 0;
END_IF




IF (ProgramReset OR Safety.SystemError) AND bError THEN
	step := 0;
END_IF

Step_0_Main();
step_0100_Homming();
step_0500_AutoMode_StartCheck();
step_0600_AutoMode_Feed();
step_0700_AutoMode_GoPrintPoint();
step_0800_AutoMode_GoPrintPoint_Cycle_200_UP();
step_0900_AutoMode_GoPrintPoint_Cycle_200_Down();
step_1000_AutoPrgEnd();

Start_Feed_In_NC_Start();

step_7800_FindZ();
step_8000_Jog();

TestActionPou();


// IF (bError) THEN
// 	hmi.Auto_Start := FALSE;
// 	hmi.Auto_Pause := FALSE;
// 	iErrorId := step - 10000;
// END_IF

Timer();
WritePersistentData();

_log(name := 'AutoMain', step := step);]]></ST>
    </Implementation>
    <Folder Name="JOG流程8100_9400" Id="{29c869f8-9e55-4891-96de-3fdfd31f73ae}" />
    <Folder Name="內部啟動用" Id="{e54b00b0-37e1-43e2-ac19-0768ee77541d}" />
    <Folder Name="自動流程500_1000" Id="{ed3b663e-b781-4d3b-9e19-bc41e1e6cd65}" />
    <Folder Name="測試用區域" Id="{91315759-1bb3-4063-b768-24ddab7b0df1}" />
    <Folder Name="輔助流程_加工動作中自動進料" Id="{60021586-c26a-4340-8fba-12b4e808dba8}" />
    <Method Name="Homming" Id="{44f06067-4083-4ca2-8078-ae6d4fcf2533}" FolderPath="內部啟動用\">
      <Declaration><![CDATA[METHOD Homming
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[step := 100;]]></ST>
      </Implementation>
    </Method>
    <Method Name="JogMode" Id="{762caa98-70af-49ec-be7a-f088d4acd762}" FolderPath="內部啟動用\">
      <Declaration><![CDATA[METHOD JogMode
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[step := 8000;]]></ST>
      </Implementation>
    </Method>
    <Method Name="JogMode_Exit" Id="{5ff6d66b-3b76-4114-a060-32c154db4adc}" FolderPath="內部啟動用\">
      <Declaration><![CDATA[METHOD JogMode_Exit
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[step := 9800;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReStart" Id="{36176bad-7a12-42cc-9d4b-bc1b6cb32850}" FolderPath="內部啟動用\">
      <Declaration><![CDATA[METHOD ReStart
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[step := 600;]]></ST>
      </Implementation>
    </Method>
    <Action Name="Start_Feed_In_NC_Start" Id="{b2d72d96-9689-4363-85ee-014fef8de968}" FolderPath="輔助流程_加工動作中自動進料\">
      <Implementation>
        <ST><![CDATA[
IF step > 700 AND step < 1000 AND	// 自動流程進入加工階段
	NOT step_Feed.bBuzy AND 		// 動作中進料沒在執行
	NOT ExpConver.Feed_bBuzy		// 進料機沒在執行
	THEN
		IF Hmi_Web.Auto_Start THEN
			step_Feed.Step := 1;
		END_IF
END_IF

CASE step_Feed.Step OF
	1:
		IF 	NOT ReadSQLData.bBuzy THEN
			step_Feed.Step := step_Feed.Step + 1;
		END_IF

	2:	// 從資料庫讀取是否有等待中的料
		IF ReadSQLData.Get_Steel_Num_On_Wait() THEN
			step_Feed.Step := step_Feed.Step + 1;
		END_IF
		
	3:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step_Feed.Step := step_Feed.Step + 1;
		END_IF
			
	4:
		IF ReadSQLData.bDone THEN
			step_Feed.Step := step_Feed.Step + 1;
		ELSIF ReadSQLData.bError THEN
			step_Feed.Step := step_Feed.Step + 10000;
		END_IF
		
	5:
		IF ProjectData.WorkOrder_Num_On_Wait > 0 THEN
			// 有等待中的料
			step_Feed.Step := step_Feed.Step + 1;
		ELSE
			// 沒有等待中的料，關閉 Hmi_Web.Auto_Start 並 結束流程
			Hmi_Web.Auto_Start := FALSE;
			step_Feed.Step := 0;
		END_IF
		
	6:
		step_Feed.Step := 10;
		
	
	10: // 自動流程還在 加工中 的狀態
		IF step > 700 AND step < 1000 THEN
			// 啟動 自動進料機
			ExpConver.Feed_holding_2_waitLoading();
			// 關閉 Hmi_Web.Auto_Start 的訊號
			Hmi_Web.Auto_Start := FALSE;
			step_Feed.Step := step_Feed.Step + 1;
		ELSE
			// 加工已經結束
			step_Feed.Step := 0;
		END_IF
		
	11:
		IF ExpConver.Feed_bBuzy OR ExpConver.Feed_bError THEN
			step_Feed.Step := step_Feed.Step + 1;
		END_IF
		
	12:
		step_Feed.Step := 0;
		step_Feed.bDone := TRUE;
		
	
		
END_CASE

step_Feed.bBuzy := step_Feed.Step > 0 AND step_Feed.Step < 10000;
step_Feed.bError := step_Feed.Step > 10000;
IF step_Feed.bBuzy OR step_Feed.bError THEN
	step_Feed.bDone := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_0_Main" Id="{b79c11b6-0e6f-4d9a-8471-e672afa2103e}">
      <Implementation>
        <ST><![CDATA[(*======================================
		確認起動條件&回原點
  ======================================*)
// 處裡緊急停止訊號
CASE step OF
	0:
		IF Hmi_Web.Jog_Mode THEN
			Hmi.Jog_Mode := FALSE;
			Hmi_Web.Jog_Mode := FALSE;
			SystemError := FALSE;
			IF NOT SystemError THEN
				step := 8000;
			END_IF
		ELSIF Hmi_Web.MPG_Mode THEN
			Hmi.MPG_Mode := FALSE;
			SystemError := FALSE;
			IF NOT SystemError THEN
				step := 8010;
			END_IF
		ELSIF Hmi_Web.Auto_Start OR Hmi_Web.Auto_OneCycle_Start THEN
// 			Hmi_Web.Auto_Start := FALSE;
// 			Hmi_Web.Auto_OneCycle_Start  := FALSE;
			IF NOT SystemError THEN
				step := 1;
			ELSE
				Hmi_Web.Auto_Start := FALSE;
				Hmi_Web.Auto_OneCycle_Start  := FALSE;
			END_IF
		END_IF
		
	
	1:
		// 檢查是否有設定要啟動的程式
		IF SystemError THEN
			Hmi_Web.Auto_Start := FALSE;
			Hmi_Web.Auto_OneCycle_Start := FALSE;
		ELSIF Hmi_Web.Auto_Start OR Hmi_Web.Auto_OneCycle_Start THEN
			step := step + 1;
		END_IF
		
	2:
		IF NOT GrobelVariable.bHome OR GbZ.fPos < 490 THEN
			step := 100;
		ELSE
			step := 500;
		END_IF
		
		

		
		
	10:
		
		tmr01.PT := T#500MS;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	11:
		SystemError := FALSE;
		IF Hmi.Mode_Select = 1 THEN
			step := 8000;
		ELSIF Hmi.Mode_Select = 2 THEN
			step := 8010;
		ELSE
			step := 0;
		END_IF
		

// ============== 動作結束 ==============

	
	
	9900:
		hmi.Auto_bDone:=TRUE;
		hmi.Auto_Start := FALSE;
		hmi.Auto_ProgramSelect := 0;
		fbWritePersistentData.START := TRUE;
		step := step  + 1;
		
		
	9901:
		uRunCounter := uRunCounter + 1;
		step := step  + 1;
		
	9902:
		IF NOT fbWritePersistentData.BUSY THEN
			fbWritePersistentData.START := FALSE;
			step := step  + 1;
		END_IF
		
	9903:
		step := 0;
		
	9905:
		hmi.Auto_Start := false;
		hmi.Auto_ProgramSelect := 0;
		PutFloor := 0;
		GetFloor := 0;
		step := step  + 1;
		
	9906:
		
		step := 0;
		
	9910:
		GaX.PowerOff();
		GaY.PowerOff();
		GaZ.PowerOff();
		GbX.PowerOff();
		GbY.PowerOff();
		GbZ.PowerOff();
		GcX.PowerOff();
		GcY.PowerOff();
		GcZ.PowerOff();
		GdX.PowerOff();
		GdY.PowerOff();
		GdZ.PowerOff();
		step := 0;
		
END_CASE

IF step = 0 THEN
	RETURN;
END_IF

// step_7900_SensorTest();]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_0100_Homming" Id="{a8c1ccf9-ccda-4182-a22a-bf89b00c7b8b}">
      <Implementation>
        <ST><![CDATA[CASE step OF
	100:
		Button.HomeButton_Light := 2;
		step := 110;

	110:
		GroupA.ToStanby();
		GroupB.ToStanby();
		GroupC.ToStanby();
		GroupD.ToStanby();
		step := step + 1;
		
	111:
		IF (GroupA.StepA.bBuzy OR GroupA.StepA.bError) AND 
			(GroupB.StepA.bBuzy OR GroupB.StepA.bError) AND
			(GroupC.StepA.bBuzy OR GroupC.StepA.bError) AND
			(GroupD.StepA.bBuzy OR GroupD.StepA.bError) THEN
				step := step + 1;
		END_IF
		
	112:
		ExpConver.FeedHomeStart();
		step := step + 1;
		
	113:
		IF (ExpConver.Feed_bBuzy OR ExpConver.Feed_bError) THEN
			step := step + 1;
		END_IF

	114:
		IF GroupB.StepA.bDone THEN
			step := step + 1;
		ELSIF GroupA.StepA.bError OR GroupB.StepA.bError OR GroupC.StepA.bError OR GroupD.StepA.bError THEN
			step := step + 10000;
		END_IF
		
	115:
		step := 120;
		
		
	120:
		homeMode := (IO.i501 OR IO.i502 OR IO.i503 OR IO.i504) AND GroupFx.b_AC_HOME AND GroupFx.b_BD_HOME; 
		GroupFx.A_UnPress();
		GroupFx.B_UnPress();
		GroupFx.C_UnPress();
		GroupFx.D_UnPress();
		step := step + 1;
		
	121:
		IF (GroupFx.step_A_P.bBuzy OR GroupFx.step_A_P.bError) AND 
			(GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			(GroupFx.step_C_P.bBuzy OR GroupFx.step_C_P.bError) AND
			(GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError) THEN
				step := step + 1;
		END_IF
		
	122:
		
		IF GroupFx.step_A_P.bDone AND GroupFx.step_B_P.bDone AND GroupFx.step_C_P.bDone AND GroupFx.step_D_P.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_A_P.bError OR GroupFx.step_B_P.bError OR GroupFx.step_C_P.bError OR GroupFx.step_D_P.bError THEN
			step := step + 10000;
		END_IF
		
	123:
		step := 130;
		
		
	130:
		IF homeMode THEN
			GroupFx.AC_UnClamp(10);
			GroupFx.BD_UnClamp(10);
		ELSE
			GroupFx.AC_Home();
			GroupFx.BD_Home();
		END_IF
		step := step + 1;
		
	131:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) AND 
			(GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError) THEN
				step := step + 1;
		END_IF
		
	132:
		
		IF GroupFx.step_AC_C.bDone AND GroupFx.step_BD_C.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError OR GroupFx.step_BD_C.bError THEN
			step := step + 10000;
		END_IF
		
	133:
		step := 140;
		
	140:
		IF NOT GroupFx.b_AC_HOME THEN
			GroupFx.AC_Home();
		END_IF
		IF NOT GroupFx.b_BD_HOME THEN
			GroupFx.BD_Home();
		END_IF
		step := step + 1;
		
	141:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError OR GroupFx.b_AC_HOME) AND 
			(GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError OR GroupFx.b_BD_HOME) THEN
				step := step + 1;
		END_IF
		
	142:
		IF (GroupFx.step_AC_C.bDone OR GroupFx.b_AC_HOME) AND (GroupFx.step_BD_C.bDone OR GroupFx.b_BD_HOME) THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError OR GroupFx.step_BD_C.bError THEN
			step := step + 10000;
		END_IF	
		
	143:
		step := 150;
		
	150:
		IF ExpConver.Feed_bDone THEN
			step := step + 1;
		ELSIF ExpConver.Feed_bError THEN
			step := step + 10000;
			pMsg.Push_Error("自動料架復歸時發生錯誤");
		END_IF
		
	151:
		IF GroupA.StepA.bDone AND GroupC.StepA.bDone AND GroupC.StepA.bDone THEN
			step := step + 1;
		ELSIF GroupA.StepA.bError AND GroupC.StepA.bError AND GroupC.StepA.bError THEN
			step := step + 10000;
			pMsg.Push_Error("自動料架復歸時發生錯誤");
		END_IF
		
	152:
		Button.HomeButton_Light := 1;
		bDone := TRUE;
		GrobelVariable.bHome := TRUE;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_0500_AutoMode_StartCheck" Id="{4829e2e7-827c-4026-a87b-a346e004fcb7}" FolderPath="自動流程500_1000\">
      <Implementation>
        <ST><![CDATA[CASE step OF
(*	====================================
				啟動前檢查
	====================================*)
		500:
			hmi.State := MachineState.auto_mode;
			IF IO.i212 THEN
				step := step + 1;
			ELSE
				pMsg.Push_Alarm_NoPause("氣壓壓力不足");
				step := 0;
			END_IF
			
		501:
			step := 510;
			
			
(*	================================================
			讀取 資料庫 的 work_order 資料表
	================================================*)
		510:
			ReadSQLData.Get_WorkkOrder();
			step := step + 1;
			
		511:
			IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
				step := step + 1;
			END_IF
			
		512:
			IF ReadSQLData.bDone THEN
				step := step + 1;
			ELSIF ReadSQLData.bError THEN
				step := step + 10000;
			END_IF
			
		513:
			IF Hmi_Web.Auto_Start THEN 
				
				// 標準進料模式
				Hmi_Web.Auto_Start := FALSE;
				step := 520;
			ELSIF Hmi_Web.Auto_OneCycle_Start THEN
				
				// 插單模式
				Hmi_Web.Auto_OneCycle_Start := FALSE;
				step := step + 1;
			END_IF
			
		514: // 插單模式 檢查 插單 或 不靠邊插單 是否有資料
			IF LEN(STR:=ProjectData.WorkOrder_inserts.steel_id) > 0 OR
				LEN(STR:=ProjectData.WorkOrder_alignment.steel_id) > 0
			THEN
				
				step := 550;
			ELSE
				pMsg.Push_Error(
					WStrConcat(
					str0:= "找不到 插單 或 不靠邊插單 的資料 AutoMain:", 
					str1:= TO_WSTRING(step))
				);
			END_IF
				
				
(*	====================================
				標準進料模式
	====================================*)
		520:
			IF LEN(STR:=ProjectData.WorkOrder_inSide.steel_id) > 0 THEN
				// 已經有 料的狀態 是 在輸送滾輪上(inSide)
				ProjectData.WorkOrder_Now := ProjectData.WorkOrder_inSide;
				step := step + 1;
			ELSE
				// 沒有 料的狀態 是 在輸送滾輪上(inSide)
				step := 530;
			END_IF
			
		521: // 自動進料機執行搬移動作，但不進料到 輸送滾輪上
			ExpConver.Feed_holding_2_waitLoading();
			step := step + 1;
			
		522:
			IF ExpConver.Feed_bBuzy OR ExpConver.Feed_bError THEN
				step := step + 1;
			END_IF
			
		523: // 確認自動進料機執行後，繼續機器進料動作
			step := 570;
			
(*	========================================
		標準進料模式 - 沒有料在輸送滾輪上
	========================================*)
		530: // 自動進料機 執行完整進料
			ExpConver.FeedAutoStart();
			step := step + 1;
			
		531:
			IF ExpConver.Feed_bBuzy OR ExpConver.Feed_bError THEN
				step := step + 1;
			END_IF
			
		532:
			IF ExpConver.Feed_bDone THEN
				step := step + 1;
			ELSIF ExpConver.Feed_bError THEN
				step := step + 10000;
			END_IF
			
		533:
			step := 540;
			
(*	========================================
		進料結束後 再次讀取資料庫
	========================================*)
		540:
			ReadSQLData.Get_WorkkOrder();
			step := step + 1;
			
		541:
			IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
				step := step + 1;
			END_IF
			
		542:
			IF ReadSQLData.bDone THEN
				step := step + 1;
			ELSIF ReadSQLData.bError THEN
				step := step + 10000;
			END_IF
			
		543:
			IF LEN(STR:=ProjectData.WorkOrder_inSide.steel_id) > 0 THEN
				// 已經有 料的狀態 是 在輸送滾輪上(inSide)
				ProjectData.WorkOrder_Now := ProjectData.WorkOrder_inSide;
				step := step + 1;
			ELSE
				// 沒有 料的狀態 是 在輸送滾輪上(inSide)
				pMsg.Push_Error(
					WStrConcat(
					str0:= "找不到狀態是 輸送滾輪上(inSide) 的資料 AutoMain:", 
					str1:= TO_WSTRING(step))
				);
			END_IF
			
		544:
			step := 570;
			
(*	=======================================
				插單模式 
			料已放置在 輸送滾輪 上
	=======================================*)
		550:
			ReadSQLData.Get_WorkkOrder();
			step := step + 1;
			
		551:
			IF (ReadSQLData.bBuzy OR ReadSQLData.bError) THEN
				step := step + 1;
			END_IF
			
		552:
			IF ReadSQLData.bDone THEN
				step := step + 1;
			ELSIF ReadSQLData.bError THEN
				step := step + 10000;
			END_IF
			
		553:
			step := 560;
			
			
		560:
			IF LEN(STR:=ProjectData.WorkOrder_alignment.steel_id) > 0 THEN
				// 無靠邊差單
				ProjectData.WorkOrder_Now := ProjectData.WorkOrder_alignment;
				step := step + 1;
			ELSIF LEN(STR:=ProjectData.WorkOrder_inserts.steel_id) > 0 THEN
				// 差單
				ProjectData.WorkOrder_Now := ProjectData.WorkOrder_inserts;
				step := step + 1;
			ELSE
				pMsg.Push_Error("AutoMain: 無差單資料");
				step := 0;
			END_IF
			
			
		561:
			step := 570;

(*	=======================================
			從資料庫 讀取 材料資料
	=======================================*)
		570:
			ReadSQLData.Get_SteelData(ProjectData.WorkOrder_Now.steel_id);
			step := step + 1;
			
		571:
			IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
				step := step + 1;
			END_IF
			
		572:
			IF ReadSQLData.bDone THEN
				step := step + 1;
			ELSIF ReadSQLData.bError THEN
				step := step + 10000;
			END_IF
			
		573:
			IF LEN(STR:=ProjectData.WorkOrder_alignment.steel_id) > 0 THEN
				// 無靠邊差單
				step := 590;
			ELSIF LEN(STR:=ProjectData.WorkOrder_inserts.steel_id) > 0 THEN
				// 差單
				step := 580;
			ELSIF LEN(STR:=ProjectData.WorkOrder_inSide.steel_id) > 0 THEN
				// 料架進料
				step := 600;
			END_IF
			
			
(*	=======================================
			等待按下 機器啟動
	=======================================*)		
		580:
			hmi.State := MachineState.auto_mode_wait;
			Button.StartButton_Light := 2;
			step := step + 1;
			
		581:
			
			IF Button.StartButton THEN
				step := step + 1;
			END_IF
			
		582:
			hmi.State := MachineState.auto_mode;
			Button.StartButton_Light := 1;
			step := 590;		

	
(*	=======================================
					靠邊
	=======================================*)	
		590:
			ExpConver.Feed_PullOver();
			step := step + 1;
			
		591:
			IF ExpConver.Feed_bBuzy OR ExpConver.Feed_bError THEN
				step := step + 1;
			END_IF
			
		592:
			IF ExpConver.Feed_bDone THEN
				step := step + 1;
			ELSIF ExpConver.Feed_bError THEN
				step := step + 10000;
			END_IF
			
		593:
			step := 600;
			
		

			
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_0600_AutoMode_Feed" Id="{d813016f-ba23-4674-893e-521536c59444}" FolderPath="自動流程500_1000\">
      <Implementation>
        <ST><![CDATA[CASE step OF
(*	==================================================
			夾輪到指定位置（防止工件墬落）
	==================================================*) 
	600: 
		ExpConver.InRollerStop();
		NowWidth := ProjectData.Now_Steel.Height;
		step := step + 1;
		
	601:
		GroupFx.AC_Clamp(NowWidth + 15);
		GroupFx.BD_Clamp(NowWidth + 15);
		step := step + 1;
		
	602:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) AND
			(GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError) THEN
			step := step + 1;
		END_IF
		
	603:
		step := 610;
(*	==================================================
			材料進入 入口位置 測量寬度
	==================================================*) 
	610:// 材料進入 入口位置
		ExpConver.InRollerStart();
		
		step := step + 1;
		
	611:
		IF ExpConver.In_Moter_Running OR ExpConver.In_Moter_Error THEN
			step := step + 1;
		END_IF
		
	612: // 到達 入口感應器 後停止
		IF io.i711 OR ExpConver.In_Moter_Error THEN
			// 停止馬達
			ExpConver.InRollerStop();
			
			IF  io.i711 THEN
				step := step + 1;
			ELSIF ExpConver.In_Moter_Error THEN
				pmsg.Push_Error(
					WStrConcat("AutoMain:進料馬達發生錯誤", TO_WSTRING(step))
				);
				step := step + 10000;
			END_IF
		END_IF
		
	613: // 確認進料馬達停止
		tmr01.PT := T#2S;
		tmr01.IN := NOT ExpConver.In_Moter_Running;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	614:// 紀錄寬度數據
	
		MaxWidth := ProjectData.Now_Steel.Height + (ProjectData.Now_Steel.Height * 0.2); 
		MinWidth := ProjectData.Now_Steel.Height - (ProjectData.Now_Steel.Height * 0.2);
		IF ExpConver.Feed_Workpiace_H > MinWidth AND ExpConver.Feed_Workpiace_H < MaxWidth THEN
			step := step + 1;
		ELSE
			pMsg.Push_Error(WStrConcat(
				"AutoMain: ",
				WLEFT(STR:= TO_WSTRING(ProjectData.Now_Steel.uid), SIZE:= 8),
				" :高度數據與輸入資料錯誤,設定值:",
				TO_WSTRING(NowWidth),
				" 實際值:",
				TO_WSTRING(ExpConver.Feed_Workpiace_H)
				));
			step := step + 10000;
		END_IF
// 		HightCheck(ExpConver.Feed_Workpiace_H, ExpConver.Feed_Workpiace_W);
		
		
	615:
		IF GroupFx.step_AC_C.bDone AND GroupFx.step_BD_C.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError OR GroupFx.step_BD_C.bError THEN
			step := step + 10000;
		END_IF
		
	616:
		step := 630;
(*	==================================================
			材料前進到 出口位置 (整料)
	==================================================*) 
	630:
		ExpConver.InRollerStart();
		step := step + 1;
		
	631:
		IF ExpConver.In_Moter_Running OR ExpConver.In_Moter_Error THEN
			step := step + 1;
		END_IF
		
	632: // 到達 出口感應器 後停止
		IF io.i709 OR ExpConver.In_Moter_Error THEN
			// 停止馬達
			ExpConver.InRollerStop();
			
			IF  io.i709 THEN
				step := step + 1;
			ELSIF ExpConver.In_Moter_Error THEN
				pmsg.Push_Error(
					WStrConcat("AutoMain:進料馬達發生錯誤", TO_WSTRING(step))
				);
				step := step + 10000;
			END_IF
		END_IF
		
	633: // 確認進料馬達停止
		tmr01.PT := T#2S;
		tmr01.IN := NOT ExpConver.In_Moter_Running;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	634:
		step := 640;
		
		
(*	=========================
			整料開始
	=========================*) 
	640: // BD
		GroupFx.AC_Clamp(0);
		GroupFx.BD_Clamp(0);
		step := step + 1;
	
	641:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) AND
			(GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError) THEN
			step := step + 1;
		END_IF
		
		
	642:
		IF GroupFx.step_AC_C.bDone AND GroupFx.step_BD_C.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError OR GroupFx.step_BD_C.bError THEN
			step := step + 10000;
		END_IF
		
	643:
		step := 650;
		
		

	650:
		GroupFx.B_Press();
		GroupFx.D_Press();
		step := step + 1;
	
	651:
		IF (GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			(GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError)
			THEN
			step := step + 1;
		END_IF
		
		
	652:
		IF GroupFx.step_B_P.bDone AND GroupFx.step_D_P.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_B_P.bError OR GroupFx.step_D_P.bError THEN
			step := step + 10000;
		END_IF
		
	653:
		step := 670;

(*	===============================================
			整料結束，退開 AC下壓 與 AC夾輪
	===============================================*) 
	660:
		GroupFx.A_UnPress();
		GroupFx.C_UnPress();
		step := step + 1;
	
	661:
		IF (GroupFx.step_A_P.bBuzy OR GroupFx.step_A_P.bError) AND
			(GroupFx.step_C_P.bBuzy OR GroupFx.step_C_P.bError) THEN
			step := step + 1;
		END_IF
		
		
	662:
		IF GroupFx.step_A_P.bDone AND GroupFx.step_C_P.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_A_P.bError OR GroupFx.step_C_P.bError THEN
			step := step + 10000;
		END_IF
		
	663:
		step := 670;
		
	670: // 退開 AC夾輪
		GroupFx.AC_UnClamp(10);
		step := step + 1;
	
	671:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) THEN
			step := step + 1;
		END_IF
		
		
	672:
		IF GroupFx.step_AC_C.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError THEN
			step := step + 10000;
		END_IF
		
	673:
		step := 680;


(*	============================
			工件原點整定
	============================*) 
	680:
		GroupFx.Fx_Home();
		step := step + 1;
		
	681:
		IF (GroupFx.bBuzy OR GroupFx.bError) THEN
			step := step + 1;
		END_IF
		
		
	682:
		IF GroupFx.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError THEN
			step := step + 10000;
		END_IF
	
	683:
		step := 690;
		
(*	============================
		工件進料結束 標示進料結束
	============================*) 
	690:
		Last_Pos := 0;
		IF  ReadSQLData.Set_Steel_Start(ProjectData.Now_Steel.uid) THEN
			step := step + 1;
		END_IF
		
	691:
		step := 700;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_0700_AutoMode_GoPrintPoint" Id="{3ddf49fc-b8c3-43b2-aa40-0220e552ab46}" FolderPath="自動流程500_1000\">
      <Implementation>
        <ST><![CDATA[CASE step OF
(*	===================================
				搜尋 X工作點
	===================================*)
	700:
		IF ReadSQLData.Get_X_NextPos(0) THEN
			step := step + 1;
		END_IF
		
	701:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	702:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	703:
		Last_Pos := ReadSQLData.fNext_XPos;
		_debug_X_NextPos[_debug_X_NextPos_count] := Last_Pos;
		_debug_X_NextPos_count := 1;
		step := step + 1;
		
	704:
		step := 710;
		
(*	==========================================
				取得區間的打標工作
	==========================================*)
	710:
		IF ProjectData.Now_Steel.Height > 200 THEN
			ReadSQLData.Get_Payload(Start_Pos := Last_Pos, End_Pos := Last_Pos + 300);
		ELSE
			ReadSQLData.Get_Payload(Start_Pos := Last_Pos, End_Pos := Last_Pos + 75);
		END_IF
		step := step + 1;
		
	711:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	712:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	713:
		step := 720;

(*	==========================================
			設定各軸組 並 預移到打標點
	==========================================*)
	720: // 設定 各軸組 X參考座標
		GroupA.Set_X_Ref(Value := Last_Pos);
		GroupB.Set_X_Ref(Value := Last_Pos);
		GroupC.Set_X_Ref(Value := Last_Pos);
		GroupD.Set_X_Ref(Value := Last_Pos);
		step := step + 1;
		
	721: // 設定 各軸組 X參考座標
		GroupA.Set_Y_Ref(Value := MaCfg.laserA_Y_ReferencePos - ProjectData.Now_Steel.Width);
		GroupB.Set_Y_Ref(Value := MaCfg.laserB_Y_ReferencePos - ProjectData.Now_Steel.Height);
		GroupC.Set_Y_Ref(Value := MaCfg.laserC_Y_ReferencePos);
		GroupD.Set_Y_Ref(Value := MaCfg.laserD_Y_ReferencePos);
		step := step + 1;
	
	722: // 關閉打標 (讓 流程暫停 在 開始打標 前)
		GroupA.ReadyToPrint := FALSE;
		GroupB.ReadyToPrint := FALSE;
		GroupC.ReadyToPrint := FALSE;
		GroupD.ReadyToPrint := FALSE;
		
		GroupA.ReadyToMove := FALSE;
		GroupB.ReadyToMove := FALSE;
		GroupC.ReadyToMove := FALSE;
		GroupD.ReadyToMove := FALSE;
		step := step + 1;
		

	
	723: // 載入區域工作內容 + 預移動開始
		GroupA.Do_WorkList();
		GroupB.Do_WorkList();
		GroupC.Do_WorkList();
		GroupD.Do_WorkList();
		step := step + 1;
		
	724:
		IF (GroupA.bBuzy OR GroupA.bError OR ProjectData.Now_Steel_Payload_A_DataNumber = 0) AND
			(GroupB.bBuzy OR GroupB.bError OR ProjectData.Now_Steel_Payload_B_DataNumber = 0) AND
			(GroupC.bBuzy OR GroupC.bError OR ProjectData.Now_Steel_Payload_C_DataNumber = 0) AND
			(GroupD.bBuzy OR GroupD.bError OR ProjectData.Now_Steel_Payload_D_DataNumber = 0) THEN
				step := step + 1;
		END_IF
		
	725:
		step := 730;
		
(*	================================
		出料輸送滾輪有工件未吊離
	================================*)
	730:
		IF ExpConver.Out_sensor > 1 AND Last_Pos > 500 THEN
			hmi.State := MachineState.auto_mode_wait;
			step := step + 1;
		ELSE
			step := 732;
		END_IF
		
	731:
		IF ExpConver.Out_sensor > 1 THEN
			Button.StartButton_Light := 0;
		ELSE
			Button.StartButton_Light := 2;
			IF Button.StartButton THEN
				step := step + 1;
			END_IF
		END_IF
		
		
	732:
		hmi.State := MachineState.auto_mode;
		Button.StartButton_Light := 1;
		step := 740;

(*	===================================
				Fx 前往 X工作點
	===================================*)
	740:
		GroupFx.Fx_Move(Last_Pos);
		GaZ.AbsMove(posc.GaZ_P_Limite, spdc.HighSpeed);
		step := step + 1;
		
	741:
		IF (GroupFx.bBuzy OR GroupFx.bError) AND (GaZ.bBuzy OR GaZ.bError) THEN
			step := step + 1;
		END_IF
		
		
	742:
		IF GroupFx.bDone AND GaZ.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError OR GaZ.bError THEN
			step := step + 10000;
		END_IF
		
	743:
		step := 750;
		
	750:
		
		GroupB.FindZ();
		GroupC.FindZ();
		GroupD.FindZ();
		step := step + 1;
		
	751:
		IF 	(GroupB.StepA.bBuzy OR GroupB.StepA.bError) AND
			(GroupC.StepA.bBuzy OR GroupC.StepA.bError) AND
			(GroupD.StepA.bBuzy OR GroupD.StepA.bError) THEN
				step := step + 1;
		END_IF
		
	752:
		IF 	(GroupB.StepA.bDone) AND
			(GroupC.StepA.bDone) AND 
			(GroupD.StepA.bDone) THEN
				GroupB_Now_Z := GroupB.Az.Pos;	// 記錄軸組B的雷射距離，小於200的料使用
			 	step := step + 1;
		ELSIF 
			(GroupB.StepA.bError) OR 
			(GroupC.StepA.bError) OR 
			(GroupD.StepA.bError) THEN
				step := step + 10000;
		END_IF
		
	753:
		GroupA.FindZ();
		
		step := step + 1;
		
	754:
		IF 	(GroupA.StepA.bBuzy OR GroupA.StepA.bError) THEN
				step := step + 1;
		END_IF
		
	755:
		IF 	(GroupA.StepA.bDone) THEN
			step := step + 1;
		ELSIF 
			(GroupA.StepA.bError) THEN
				step := step + 10000;
		END_IF
		
	756:
		GroupA.ReadyToMove := TRUE;
		GroupB.ReadyToMove := TRUE;
		GroupC.ReadyToMove := TRUE;
		GroupD.ReadyToMove := true;
		step := 760;
		
(*	=============================================
				開始各組區域打標
	=============================================*)
	760: 
		tmr01.PT := T#2S;
		tmr01.IN := NOT ExpConver.In_Moter_Running;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	761:
		GroupA.ReadyToPrint := TRUE;
		GroupB.ReadyToPrint := TRUE;
		GroupC.ReadyToPrint := TRUE;
		GroupD.ReadyToPrint := TRUE;
		step := step + 1;
		
	762:
		IF GroupA.bDone AND GroupB.bDone AND GroupC.bDone AND GroupD.bDone THEN
			step := step + 1;
		ELSIF GroupA.bError OR GroupB.bError OR GroupC.bError OR GroupD.bError THEN
			step := step + 10000;
		END_IF
		
	763:
		step := 770;
		
(*	================================
		出料輸送滾輪有工件未吊離
	================================*)
	770:
		IF ExpConver.Out_sensor > 1 AND Last_Pos < 500 THEN
			hmi.State := MachineState.auto_mode_wait;
			step := step + 1;
		ELSE
			step := 772;
		END_IF
		
	771:
		IF ExpConver.Out_sensor > 1 THEN
			Button.StartButton_Light := 0;
			Button.StopButton_Light := 2;
		ELSE
			Button.StartButton_Light := 2;
			Button.StopButton_Light := 0;
			IF Button.StartButton THEN
				step := step + 1;
			END_IF
		END_IF
		
		
	772:
		
		hmi.State := MachineState.auto_mode;
		Button.StartButton_Light := 1;
		IF ProjectData.Now_Steel.Height > 200 THEN
			step := 800;
		ELSE
			step := 900;
		END_IF
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_0800_AutoMode_GoPrintPoint_Cycle_200_UP" Id="{b9ee8044-d68a-43ca-8ce0-75cc1609900c}" FolderPath="自動流程500_1000\">
      <Implementation>
        <ST><![CDATA[(*=====================================
				搜尋 X工作點
=======================================*)

CASE step OF
(*	===================================
				搜尋 X工作點
	===================================*)
	800:
		IF ReadSQLData.Get_X_NextPos(Last_Pos + 200) THEN
			step := step + 1;
		END_IF
		
	801:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	802:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	803:
		Last_Pos := ReadSQLData.fNext_XPos;
		
		_debug_X_NextPos[_debug_X_NextPos_count] := Last_Pos;
		_debug_X_NextPos_count := _debug_X_NextPos_count + 1;
		
		step := step + 1;
		
	804:
		IF Last_Pos = -1 THEN
			step := 1000;
		ELSE
			step := step + 1;
		END_IF
		
	805:
		step := 810;
		
(*	==========================================
				取得區間的打標工作
	==========================================*)
	810:
		ReadSQLData.Get_Payload(Start_Pos := Last_Pos, End_Pos := Last_Pos + 200);
		step := step + 1;
		
	811:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	812:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	813:
		Last_Pos := Last_Pos - 10;
		step := 820;

(*	==========================================
			設定各軸組 並 預移到打標點
	==========================================*)
	820: // 設定 各軸組 X參考座標
		GroupA.Set_X_Ref(Value := Last_Pos);
		GroupB.Set_X_Ref(Value := Last_Pos);
		GroupC.Set_X_Ref(Value := Last_Pos);
		GroupD.Set_X_Ref(Value := Last_Pos);
		step := step + 1;
		
	821:
		GroupA.ReadyToPrint := FALSE;
		GroupB.ReadyToPrint := FALSE;
		GroupC.ReadyToPrint := FALSE;
		GroupD.ReadyToPrint := FALSE;
		
		GroupA.ReadyToMove := FALSE;
		GroupB.ReadyToMove := FALSE;
		GroupC.ReadyToMove := FALSE;
		GroupD.ReadyToMove := FALSE;
		step := step + 1;
		

	
	822: // 載入區域工作內容 + 預移動開始
		GroupA.Do_WorkList();
		GroupB.Do_WorkList();
		GroupC.Do_WorkList();
		GroupD.Do_WorkList();
		step := step + 1;
		
	823:
		IF (GroupA.bBuzy OR GroupA.bError OR ProjectData.Now_Steel_Payload_A_DataNumber = 0) AND
			(GroupB.bBuzy OR GroupB.bError OR ProjectData.Now_Steel_Payload_B_DataNumber = 0) AND
			(GroupC.bBuzy OR GroupC.bError OR ProjectData.Now_Steel_Payload_C_DataNumber = 0) AND
			(GroupD.bBuzy OR GroupD.bError OR ProjectData.Now_Steel_Payload_D_DataNumber = 0) THEN
				step := step + 1;
		END_IF
		
	824:
		step := 830;
		
(*	===================================
			判斷是否走快到結尾
			如果是則交換編碼器
	===================================*)
	830: // 判斷是否走快到結尾
		IF (Last_Pos + 1200) > ProjectData.Now_Steel.Length AND NOT GroupFx.b_AC_Clamp THEN
			IF Fx.fPos < 1200 THEN
				step := step + 1;
			ELSE
				step := 835;
			END_IF
		ELSIF (Last_Pos + 100) >= ProjectData.Now_Steel.Length THEN
			Last_Pos := Last_Pos - 100;
			GroupA.Set_X_Ref(Value := Last_Pos);
			GroupB.Set_X_Ref(Value := Last_Pos);
			GroupC.Set_X_Ref(Value := Last_Pos);
			GroupD.Set_X_Ref(Value := Last_Pos);
			step := 850;
		ELSE
			step := 850;
		END_IF
		
		
	831:
		SensorTest.MovePos[0] := Sensor.sensor_test_pos;
		SensorTest.MovePos[1] := FxA_Exp_Pos;
		SensorTest.MovePos[2] := FxB_Exp_Pos;
		
		GroupFx.Fx_Move(1200);
		step := step + 1;
		
	832:
		IF (GroupFx.bBuzy OR GroupFx.bError) THEN
			step := step + 1;
		END_IF
		
		
	833:
		IF GroupFx.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError THEN
			step := step + 10000;
		END_IF
		
	834:
		step := 835;
		
	835:
		SensorTest.MovePos[4] := Sensor.sensor_test_pos;
		SensorTest.MovePos[5] := FxA_Exp_Pos;
		SensorTest.MovePos[6] := FxB_Exp_Pos;
		
		GroupFx.Fx_Set_A_Enc();
		GroupB.FindZ();
		step := step + 1;
		
	836:
		IF (GroupFx.bBuzy OR GroupFx.bError) AND (GroupB.StepA.bBuzy OR GroupB.StepA.bError) THEN
			step := step + 1;
		END_IF
		
	837:
		IF GroupFx.bDone AND GroupB.StepA.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError OR GroupB.StepA.bError THEN
			step := step + 10000;
		END_IF
		
	838:
		step := 840;
(*	===================================
				BD夾 換 AC夾
	===================================*)
	840:
		SensorTest.MovePos[7] := Sensor.sensor_test_pos;
		SensorTest.MovePos[8] := FxA_Exp_Pos;
		SensorTest.MovePos[9] := FxB_Exp_Pos;
	
		GroupFx.AC_Clamp();
		GroupFx.B_UnPress();
		GroupFx.D_UnPress();
		step := step + 1;
		
	841:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) AND
			(GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			 (GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError) THEN
			step := step + 1;
		END_IF
		
	842:
		IF GroupFx.step_AC_C.bDone AND GroupFx.step_B_P.bDone AND GroupFx.step_D_P.bDone  THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError OR GroupFx.step_B_P.bError OR GroupFx.step_D_P.bError THEN
			step := step + 10000;
		END_IF
		
	843:
		tmr01.PT := T#1S;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	844:
		SensorTest.MovePos[10] := Sensor.sensor_test_pos;
		SensorTest.MovePos[11] := FxA_Exp_Pos;
		SensorTest.MovePos[12] := FxB_Exp_Pos;
	
		GroupFx.BD_UnClamp(20);
		GroupFx.A_Press();
		GroupFx.C_Press();
		step := step + 1;
		
	845:
		IF (GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError) AND
			(GroupFx.step_A_P.bBuzy OR GroupFx.step_A_P.bError) AND
			 (GroupFx.step_C_P.bBuzy OR GroupFx.step_C_P.bError)  THEN
			step := step + 1;
		END_IF
		
	846:
		IF GroupFx.step_BD_C.bDone  THEN
			GroupFx.B_Press();
			GroupFx.D_Press();
			step := step + 1;
		ELSIF GroupFx.step_BD_C.bError THEN
			step := step + 10000;
		END_IF
		
	847:
		IF (GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			 (GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError)  THEN
			step := step + 1;
		END_IF
		
	848:
		IF GroupFx.step_BD_C.bDone AND GroupFx.step_A_P.bDone AND GroupFx.step_B_P.bDone AND GroupFx.step_C_P.bDone AND GroupFx.step_D_P.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_BD_C.bError OR GroupFx.step_A_P.bError OR GroupFx.step_B_P.bError OR GroupFx.step_C_P.bError OR GroupFx.step_D_P.bError THEN
			step := step + 10000;
		END_IF
	
		
	849:
		step := 850;
(*	===================================
				Fx 前往 X工作點
	===================================*)
	850:
		SensorTest.MovePos[13] := Sensor.sensor_test_pos;
		SensorTest.MovePos[14] := FxA_Exp_Pos;
		SensorTest.MovePos[15] := FxB_Exp_Pos;
		
		// BH有接縫工件
		IF ProjectData.Joint_Pos > 0 THEN
			IF Last_Pos + 1300 > ProjectData.Joint_Pos AND Fx_Exp_Pos + 1100 < ProjectData.Joint_Pos THEN
				step := step + 1;
			ELSE
				step := 855;
			END_IF
		ELSE
			step := 855;
		END_IF
	
	851:
		GroupFx.Fx_Move(ProjectData.Joint_Pos - 1400);
		step := step + 1;
		
	852:
		IF (GroupFx.bBuzy OR GroupFx.bError) THEN
			step := step + 1;
		END_IF
		
		
	853:
		IF GroupFx.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError THEN
			step := step + 10000;
		END_IF
		
	854:
		IF GroupFx.Fx_Sync_EncA_2_EncB() THEN
			step := 855;
		END_IF
		
	855:
		SensorTest.MovePos[17] := Sensor.sensor_test_pos;
		SensorTest.MovePos[18] := FxA_Exp_Pos;
		SensorTest.MovePos[19] := FxB_Exp_Pos;
		
		GroupFx.Fx_Move(Last_Pos);
		step := step + 1;
		
	856:
		IF (GroupFx.bBuzy OR GroupFx.bError) THEN
			step := step + 1;
		END_IF
		
		
	857:
		IF GroupFx.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError THEN
			step := step + 10000;
		END_IF
		
	858:
		step := 860;
		
	
		
(*	===================================
		Fx 定位後，各組測高開始
	===================================*)
	860:
		IF ProjectData.Now_Steel_Payload_A_DataNumber > 0 THEN
			GroupA.FindZ();
		END_IF
		IF ProjectData.Now_Steel_Payload_B_DataNumber > 0 THEN
			GroupB.FindZ();
		END_IF
		IF ProjectData.Now_Steel_Payload_C_DataNumber > 0 THEN
			GroupC.FindZ();
		END_IF
		IF ProjectData.Now_Steel_Payload_D_DataNumber > 0 THEN
			GroupD.FindZ();
		END_IF
		step := step + 1;
		
	861:
		IF (GroupA.StepA.bBuzy OR GroupA.StepA.bError OR ProjectData.Now_Steel_Payload_A_DataNumber = 0) AND
			(GroupB.StepA.bBuzy OR GroupB.StepA.bError OR ProjectData.Now_Steel_Payload_B_DataNumber = 0) AND
			(GroupC.StepA.bBuzy OR GroupC.StepA.bError OR ProjectData.Now_Steel_Payload_C_DataNumber = 0) AND
			(GroupD.StepA.bBuzy OR GroupD.StepA.bError OR ProjectData.Now_Steel_Payload_D_DataNumber = 0) THEN
				step := step + 1;
		END_IF
		
	862:
		GroupA.ReadyToMove := GroupA.StepA.bDone;
		GroupB.ReadyToMove := GroupB.StepA.bDone;
		GroupC.ReadyToMove := GroupC.StepA.bDone;
		GroupD.ReadyToMove := GroupD.StepA.bDone;
		IF (GroupA.StepA.bDone OR ProjectData.Now_Steel_Payload_A_DataNumber = 0) AND
			(GroupB.StepA.bDone OR ProjectData.Now_Steel_Payload_B_DataNumber = 0) AND
			(GroupC.StepA.bDone OR ProjectData.Now_Steel_Payload_C_DataNumber = 0) AND 
			(GroupD.StepA.bDone OR ProjectData.Now_Steel_Payload_D_DataNumber = 0) THEN
			 	step := step + 1;
		ELSIF 
			(GroupA.StepA.bError AND ProjectData.Now_Steel_Payload_A_DataNumber > 0) OR
			(GroupB.StepA.bError AND ProjectData.Now_Steel_Payload_B_DataNumber > 0) OR 
			(GroupC.StepA.bError AND ProjectData.Now_Steel_Payload_C_DataNumber > 0) OR 
			(GroupD.StepA.bError AND ProjectData.Now_Steel_Payload_D_DataNumber > 0) THEN
				step := step + 10000;
		END_IF
		
	863:
		step := 870;
		
(*	=============================================
				開始各組區域打標
	=============================================*)
	870: 
		tmr01.PT := T#1S;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	871:
		GroupA.ReadyToPrint := TRUE;
		GroupB.ReadyToPrint := TRUE;
		GroupC.ReadyToPrint := TRUE;
		GroupD.ReadyToPrint := TRUE;
		step := step + 1;
		
	872:
		IF GroupA.bDone AND GroupB.bDone AND GroupC.bDone AND GroupD.bDone THEN
			step := step + 1;
		ELSIF GroupA.bError OR GroupB.bError OR GroupC.bError OR GroupD.bError THEN
			step := step + 10000;
		END_IF
		
	873:
		step := 880;
		
	
	880:
		step := 800;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_0900_AutoMode_GoPrintPoint_Cycle_200_Down" Id="{93b20725-0dc6-4893-8408-c5a0e7cf97fe}" FolderPath="自動流程500_1000\">
      <Implementation>
        <ST><![CDATA[(*=====================================
				搜尋 X工作點
=======================================*)

CASE step OF
(*	===================================
				搜尋 X工作點
	===================================*)
	900:
		IF ReadSQLData.Get_X_NextPos(Last_Pos) THEN
			step := step + 1;
		END_IF
		
	901:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	902:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	903:
		Last_Pos := ReadSQLData.fNext_XPos;
		
		_debug_X_NextPos[_debug_X_NextPos_count] := Last_Pos;
		_debug_X_NextPos_count := _debug_X_NextPos_count + 1;
		
		step := step + 1;
		
	904:
		IF Last_Pos = -1 THEN
			step := 906;
		ELSE
			step := step + 1;
		END_IF
		
	905:
		step := 910;
		
	906:
		GroupB.ToStanby(Speed:= SpdC.HighSpeed);
		step := step + 1;
		
	907:
		IF GroupB.StepA.bBuzy OR GroupB.StepA.bError THEN
			step := step + 1;
		END_IF
		
	908:
		IF GroupB.StepA.bDone THEN
			step := step + 1;
		ELSIF GroupB.StepA.bError THEN
			step := step + 10000;
		END_IF
		
	909:
		step := 1000;
		
(*	==========================================
				取得區間的打標工作
	==========================================*)
	910:
		ReadSQLData.Get_Payload(Start_Pos := Last_Pos, End_Pos := Last_Pos + 1);
		step := step + 1;
		
	911:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	912:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	913:
		step := 920;

(*	==========================================
			設定各軸組 並 預移到打標點
	==========================================*)
	920: // 設定 各軸組 X參考座標
		GroupA.Set_X_Ref(Value := Last_Pos);
		GroupB.Set_X_Ref(Value := Last_Pos);
		GroupC.Set_X_Ref(Value := Last_Pos);
		GroupD.Set_X_Ref(Value := Last_Pos);
		step := step + 1;
		
	921:
		GroupA.ReadyToPrint := FALSE;
		GroupB.ReadyToPrint := FALSE;
		GroupC.ReadyToPrint := FALSE;
		GroupD.ReadyToPrint := FALSE;
		
		GroupA.ReadyToMove := FALSE;
		GroupB.ReadyToMove := FALSE;
		GroupC.ReadyToMove := FALSE;
		GroupD.ReadyToMove := FALSE;
		step := step + 1;
		

	
	922: // 載入區域工作內容 + 預移動開始
		GroupA.Do_WorkList();
		GroupB.Do_WorkList();
		GroupC.Do_WorkList();
		GroupD.Do_WorkList();
		step := step + 1;
		
	923:
		IF (GroupA.bBuzy OR GroupA.bError OR ProjectData.Now_Steel_Payload_A_DataNumber = 0) AND
			(GroupB.bBuzy OR GroupB.bError OR ProjectData.Now_Steel_Payload_B_DataNumber = 0) AND
			(GroupC.bBuzy OR GroupC.bError OR ProjectData.Now_Steel_Payload_C_DataNumber = 0) AND
			(GroupD.bBuzy OR GroupD.bError OR ProjectData.Now_Steel_Payload_D_DataNumber = 0) THEN
				step := step + 1;
		END_IF
		
	924:
		step := 930;
		
(*	===================================
			判斷是否走快到結尾
			如果是則交換編碼器
	===================================*)
	930: // 判斷是否走快到結尾
		IF (Last_Pos + 1100) > ProjectData.Now_Steel.Length AND NOT GroupFx.b_AC_Clamp THEN
			IF Fx.fPos < 1000 THEN
				// 料還沒到 前端
				step := step + 1;
			ELSE
				// 料已超過 前端
				step := 935;
			END_IF
		ELSE
			step := 950;
		END_IF
		
		
	931:
		SensorTest.MovePos[0] := Sensor.sensor_test_pos;
		SensorTest.MovePos[1] := FxA_Exp_Pos;
		SensorTest.MovePos[2] := FxB_Exp_Pos;
		
		GroupFx.Fx_Move(1000);
		step := step + 1;
		
	932:
		IF (GroupFx.bBuzy OR GroupFx.bError) THEN
			step := step + 1;
		END_IF
		
		
	933:
		IF GroupFx.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError THEN
			step := step + 10000;
		END_IF
		
	934:
		step := 935;
		
	935:
		SensorTest.MovePos[4] := Sensor.sensor_test_pos;
		SensorTest.MovePos[5] := FxA_Exp_Pos;
		SensorTest.MovePos[6] := FxB_Exp_Pos;
		
		GroupFx.Fx_Set_A_Enc();
		GroupB.ToStanby(Speed:= SpdC.HighSpeed);
		step := step + 1;
		
	936:
		IF (GroupFx.bBuzy OR GroupFx.bError) AND 
			(GroupB.StepA.bBuzy OR GroupB.StepA.bError) THEN
			step := step + 1;
		END_IF
		
	937:
		IF GroupFx.bDone AND GroupB.StepA.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError OR GroupB.StepA.bError THEN
			step := step + 10000;
		END_IF
		
	938:
		step := 940;
(*	===================================
				BD夾 換 AC夾
	===================================*)
	940:
		SensorTest.MovePos[7] := Sensor.sensor_test_pos;
		SensorTest.MovePos[8] := FxA_Exp_Pos;
		SensorTest.MovePos[9] := FxB_Exp_Pos;
	
		GroupFx.AC_Clamp();
		GroupFx.B_UnPress();
		GroupFx.D_UnPress();
		step := step + 1;
		
	941:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) AND
			(GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			 (GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError) THEN
			step := step + 1;
		END_IF
		
	942:
		IF GroupFx.step_AC_C.bDone AND GroupFx.step_B_P.bDone AND GroupFx.step_D_P.bDone  THEN
			step := step + 1;
		ELSIF GroupFx.step_AC_C.bError OR GroupFx.step_B_P.bError OR GroupFx.step_D_P.bError THEN
			step := step + 10000;
		END_IF
		
	943:
		tmr01.PT := T#1S;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	944:
		SensorTest.MovePos[10] := Sensor.sensor_test_pos;
		SensorTest.MovePos[11] := FxA_Exp_Pos;
		SensorTest.MovePos[12] := FxB_Exp_Pos;
	
		GroupFx.BD_UnClamp(20);
		GroupFx.A_Press();
		GroupFx.C_Press();
		step := step + 1;
		
	945:
		IF (GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError) AND
			(GroupFx.step_A_P.bBuzy OR GroupFx.step_A_P.bError) AND
			 (GroupFx.step_C_P.bBuzy OR GroupFx.step_C_P.bError)  THEN
			step := step + 1;
		END_IF
		
	946:
		IF GroupFx.step_BD_C.bDone THEN
			GroupFx.B_Press();
			GroupFx.D_Press();
			step := step + 1;
		ELSIF GroupFx.step_BD_C.bError THEN
			step := step + 10000;
		END_IF
		
	947:
		IF (GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND (GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError)  THEN
			step := step + 1;
		END_IF
		
	948:
		IF GroupFx.step_A_P.bDone AND GroupFx.step_B_P.bDone AND GroupFx.step_C_P.bDone AND GroupFx.step_D_P.bDone THEN
			step := step + 1;
		ELSIF GroupFx.step_A_P.bError OR GroupFx.step_B_P.bError OR GroupFx.step_C_P.bError OR GroupFx.step_D_P.bError THEN
			step := step + 10000;
		END_IF
		
	949:
		step := 950;
		
	950:
		GbZ.AbsMove(GroupB_Now_Z, spdc.HomeSpeed);
		step := step + 1;
		
	951:
		IF (GbZ.bBuzy OR GbZ.bError)  THEN
			step := step + 1;
		END_IF
		
	952:
		step := 970;
(*	===================================
				Fx 前往 X工作點
	===================================*)
	970:
		SensorTest.MovePos[13] := Sensor.sensor_test_pos;
		SensorTest.MovePos[14] := FxA_Exp_Pos;
		SensorTest.MovePos[15] := FxB_Exp_Pos;
		
		GroupFx.Fx_Move(Last_Pos);
		step := step + 1;
		
	971:
		IF (GroupFx.bBuzy OR GroupFx.bError) THEN
			step := step + 1;
		END_IF
		
		
	972:
		IF GroupFx.bDone AND GbZ.bDone THEN
			step := step + 1;
		ELSIF GroupFx.bError AND GbZ.bError THEN
			step := step + 10000;
		END_IF
		
	973:
		SensorTest.MovePos[17] := Sensor.sensor_test_pos;
		SensorTest.MovePos[18] := FxA_Exp_Pos;
		SensorTest.MovePos[19] := FxB_Exp_Pos;
		step := 980;
		
(*	===================================
		原測高動作，小隻的料不做
	===================================*)

		
(*	=============================================
				開始各組區域打標
	=============================================*)
	980: 
		tmr01.PT := T#1S;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	981:
		GroupA.ReadyToMove := TRUE;
		GroupB.ReadyToMove := TRUE;
		GroupC.ReadyToMove := TRUE;
		GroupD.ReadyToMove := TRUE;
		GroupA.ReadyToPrint := TRUE;
		GroupB.ReadyToPrint := TRUE;
		GroupC.ReadyToPrint := TRUE;
		GroupD.ReadyToPrint := TRUE;
		step := step + 1;
		
	982:
		IF GroupA.bDone AND GroupB.bDone AND GroupC.bDone AND GroupD.bDone THEN
			step := step + 1;
		ELSIF GroupA.bError OR GroupB.bError OR GroupC.bError OR GroupD.bError THEN
			step := step + 10000;
		END_IF
		
	983:
		step := 990;
		
	
	990:
		step := 900;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_1000_AutoPrgEnd" Id="{d4a54de3-d318-4b44-9a1a-75a485fce4e2}" FolderPath="自動流程500_1000\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	1000:
		uRunCounter := uRunCounter + 1;
		GroupA.Oil();
		GroupB.Oil();
		GroupC.Oil();
		GroupD.Oil();
		ReadSQLData.Set_Steel_Finish(uid := ProjectData.Now_Steel.uid);
		step := step + 1;
		
	1001:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	1002:
		IF ReadSQLData.bDone OR ReadSQLData.bError THEN
			ProjectData.WorkOrder_Now.steel_id := '';
			step := step + 1;
		END_IF
		
	1003:
		step := 1010;
		

	1010:
		ReadSQLData.Get_Steel_Num_On_Wait();
		
		GroupA.ToStanby(spdc.HighSpeed);
		GroupB.ToStanby(spdc.HighSpeed);
		GroupC.ToStanby(spdc.HighSpeed);
		GroupD.ToStanby(spdc.HighSpeed);
		
		IF (fx.fPos < 1800) THEN
			GroupFx.Fx_Move(1800);
		ELSE
			fx.Stop();
		END_IF
		
		step := step + 1;
		
	1011:
		IF (GroupA.StepA.bBuzy OR GroupA.StepA.bError) AND 
			(GroupB.StepA.bBuzy OR GroupB.StepA.bError) AND
			(GroupC.StepA.bBuzy OR GroupC.StepA.bError) AND
			(GroupD.StepA.bBuzy OR GroupD.StepA.bError) AND
			(GroupFx.bBuzy OR GroupFx.bError OR fx.fPos >= 1800) THEN
				step := step + 1;
		END_IF
		
	1012:
		IF GroupB.StepA.bDone AND (GroupFx.bDone OR fx.fPos >= 1800) THEN
			step := step + 1;
		ELSIF GroupA.StepA.bError OR GroupB.StepA.bError OR GroupC.StepA.bError OR GroupD.StepA.bError OR GroupFx.bError THEN
			step := step + 10000;
		END_IF
		
	1013:
		
		step := 1020;
		
	1020:
		GroupFx.A_UnPress();
		GroupFx.B_UnPress();
		GroupFx.C_UnPress();
		GroupFx.D_UnPress();
		step := step + 1;
		
	1021:
		IF (GroupFx.step_A_P.bBuzy OR GroupFx.step_A_P.bError) AND
			(GroupFx.step_B_P.bBuzy OR GroupFx.step_B_P.bError) AND
			(GroupFx.step_C_P.bBuzy OR GroupFx.step_C_P.bError) AND
			(GroupFx.step_D_P.bBuzy OR GroupFx.step_D_P.bError) THEN
				step := step + 1;
		END_IF
		
	1022:
		tmr01.PT:= T#2S;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
// 		IF GroupFx.step_A_P.bDone AND 
// 			GroupFx.step_B_P.bDone AND 
// 			GroupFx.step_C_P.bDone AND 
// 			GroupFx.step_D_P.bDone THEN
// 				step := step + 1;
// 		ELSIF GroupFx.step_A_P.bError AND 
// 			GroupFx.step_B_P.bError AND 
// 			GroupFx.step_C_P.bError AND 
// 			GroupFx.step_D_P.bError THEN
// 				step := step + 10000;
// 		END_IF
		
	1023:
		step := 1030;
		
		
	1030:
		GroupFx.AC_UnClamp(10);
		GroupFx.BD_UnClamp(10);
		step := step + 1;
		
	1031:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) AND
			(GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError) THEN
				step := step + 1;
		END_IF
		
	1032:
		tmr01.PT := T#2S;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	1033:
		IF ReadSQLData.bDone OR ReadSQLData.bError THEN
			step := 1040;
		END_IF
		
	1040:
		ExpConver.OutRollerStart();
		step := step + 1;
		
	1041:
		IF ExpConver.Out_Moter_Running THEN
			step := step + 1;
		END_IF
		
	1042:
		IF ProjectData.Now_Steel.Length < 11000 THEN
			tmr01.PT := T#2S;
		ELSE
			tmr01.PT := T#0.5S;
		END_IF
		tmr01.IN := NOT io.i709;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	1043:
		ExpConver.OutRollerStop();
		step := step + 1;
		
	1044:
		IF NOT ExpConver.Out_Moter_Running THEN
			step := step + 1;
		END_IF
		
	1045:
		step := 1050;
		
		
		
	1050:
		IF ReadSQLData.bDone OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	1051:
		IF ProjectData.WorkOrder_Num_On_Wait > 0 THEN
			step := step + 1;
		ELSE
			step := 1090;
		END_IF
		
	1052:	
		IF NOT ExpConver.Feed_bBuzy THEN
			ExpConver.FeedAutoStart();
			Hmi_Web.Auto_Start := FALSE;
			step := step + 1;
		END_IF
		
	1053:
		IF ExpConver.Feed_bBuzy OR ExpConver.Feed_bError THEN
			step := step + 1;
		END_IF
		
	1054:
		IF ExpConver.Feed_bDone THEN
			step := step + 1;
		ELSIF ExpConver.Feed_bError THEN
			step := step + 10000;
		END_IF
		
	1055:
		step := 1060;


(*	========================================
			讀取資料庫 取得排程資料
	========================================*)
	1060:
		ReadSQLData.Get_WorkkOrder();
		step := step + 1;
			
	1061:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
			
	1062:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	1063:
		IF LEN(STR:=ProjectData.WorkOrder_inSide.steel_id) > 0 THEN
			// 已經有 料的狀態 是 在輸送滾輪上(inSide)
			ProjectData.WorkOrder_Now := ProjectData.WorkOrder_inSide;
			step := 1070;
		ELSE
			// 沒有 料的狀態 是 在輸送滾輪上(inSide)
			step := 1090;
		END_IF
		

(*	========================================
				有進料完成的料
	========================================*)
	1070:
		ReadSQLData.Get_SteelData(ProjectData.WorkOrder_Now.steel_id);
		step := step + 1;
			
	1071:
		IF ReadSQLData.bBuzy OR ReadSQLData.bError THEN
			step := step + 1;
		END_IF
		
	1072:
		IF ReadSQLData.bDone THEN
			step := step + 1;
		ELSIF ReadSQLData.bError THEN
			step := step + 10000;
		END_IF
		
	1073:
		
		step := 600;
		
		
	1090:
		GroupFx.AC_UnClamp();
		GroupFx.BD_UnClamp();
		step := step + 1;
		
	1091:
		IF (GroupFx.step_AC_C.bBuzy OR GroupFx.step_AC_C.bError) AND
			(GroupFx.step_BD_C.bBuzy OR GroupFx.step_BD_C.bError) THEN
				step := step + 1;
		END_IF
		
	1092:
		tmr01.PT := T#2S;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	1093:
		step := 0;
		
	step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
