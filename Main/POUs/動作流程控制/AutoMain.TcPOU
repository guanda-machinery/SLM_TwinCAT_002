			step := 7520;
		ELSE
			
			iCount := iCount + 1;
			step := step + 1;
		END_IF
		
	7541:
		GcX.AbsMove(fPointStart[1],80);
		GcY.AbsMove(fPointStart[2],80);
		step := step + 1;
		
	7542:
		IF (GcX.bBuzy OR GcX.bError) AND (GcY.bBuzy OR GcY.bError) THEN
			step := step + 1;
		END_IF
		
	7543:
		IF GcX.bDone AND GcY.bDone THEN
			step := step + 1;
		ELSIF GcX.bError OR GcY.bError THEN
			step := step + 10000;
		END_IF
		
	7544:
		iCount := 0;
		step := 8010;

		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step_7600_test_mask_D" Id="{0b9c3ef3-9254-45dc-bc49-5cb485e2f771}" FolderPath="測試用區域\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	7600:
		iCount := 1;
		fPointStart[1] := GdX.Pos;
		fPointStart[2] := GdY.Pos;
		step := 7610;
		
	7610:// 載入DXF專案
		LaserMark.laserD.Load_Project('dxf');
		step := step + 1;
		
	7611:
		IF LaserMark.laserD.bBuzy OR LaserMark.laserD.bError THEN
			step := step + 1;
		END_IF
		
	7612:
		IF LaserMark.laserD.bDone THEN
			step := step + 1;
		ELSIF LaserMark.laserD.bError THEN
			step := step + 10000;
		END_IF
		
	7613:
		step := 7620;
		
	7620: // 移X軸
		GdX.RelMove(fPoint[iCount,1],80);
		GdY.RelMove(fPoint[iCount,2],80);
		LaserMark.laserD.Edit_Object(Name := 'dxf', Content := sFilename[iCount]);
		step := step + 1;
		
	7621:
		IF (GdX.bBuzy OR GdX.bError) AND (GdY.bBuzy OR GdY.bError) AND (LaserMark.laserD.bBuzy OR LaserMark.laserD.bError) THEN
			step := step + 1;
		END_IF
		
	7622:
		IF GdX.bDone AND GdY.bDone THEN
			step := step + 1;
		ELSIF GdX.bError OR GdY.bError THEN
			step := step + 10000;
		END_IF
		
	7623:
		step := 7630;
		
	7630: // 換置 DXF檔案
		step := step + 1;
		
	7631:
		IF LaserMark.laserD.bDone THEN
			step := step + 1;
		ELSIF LaserMark.laserD.bError THEN
			step := step + 10000;
		END_IF
		
	7632:
		tmr01.IN := TRUE;
		tmr01.PT := T#500MS;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := 7635;
		END_IF
		
		
	7635: // 打雷射
		LaserMark.laserD.Mark();
		step := step + 1;
		
	7636:
		IF LaserMark.laserD.bBuzy OR LaserMark.laserD.bError THEN
			step := step + 1;
		END_IF
		
	7637:
		IF LaserMark.laserD.bDone THEN
			step := step + 1;
		ELSIF LaserMark.laserD.bError THEN
			step := step + 10000;
		END_IF
		
	7638:
		tmr01.PT := T#500MS;
		tmr01.IN := TRUE;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	7639:
		step := 7640;
		
	7640:
		IF iCount < 9 THEN
			iCount := iCount + 1;
			step := 7620;
		ELSE
			iCount := 1;
			step := step + 1;
		END_IF
		
	7641:
		GdX.AbsMove(fPointStart[1],80);
		GdY.AbsMove(fPointStart[2],80);
		step := step + 1;
		
	7642:
		IF (GdX.bBuzy OR GdX.bError) AND (GdY.bBuzy OR GdY.bError) THEN
			step := step + 1;
		END_IF
		
	7643:
		IF GdX.bDone AND GdY.bDone THEN
			step := step + 1;
		ELSIF GdX.bError OR GdY.bError THEN
			step := step + 10000;
		END_IF
		
	7644:
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
