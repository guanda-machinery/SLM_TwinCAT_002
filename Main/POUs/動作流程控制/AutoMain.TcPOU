    <Action Name="step_9700_Jog_SetLimit" Id="{b2fe7821-cf3c-4702-8677-8a39e991af14}" FolderPath="JOG流程8100_9400\">
      <Implementation>
        <ST><![CDATA[(*====================================
				設定極限
  ====================================*) 

CASE step OF
	9700:
		IF Hmi.Jog_GroupSelect > 0 THEN
			IF Hmi.Set_X_P_Limite THEN
				step := 9710;
			ELSIF Hmi.Set_X_Home THEN
				step := 9720;
			ELSIF Hmi.Set_Y_P_Limite THEN
				step := 9730;
			ELSIF Hmi.Set_Y_Home THEN
				step := 9740;
			ELSIF Hmi.Set_Z_P_Limite THEN
				step := 9750;
			ELSIF Hmi.Set_Z_Home THEN
				step := 9760;
			ELSE
				step := step + 1;
			END_IF
		ELSE
			Hmi.Set_X_P_Limite := FALSE;
			Hmi.Set_X_Home := FALSE;
			Hmi.Set_Y_P_Limite := FALSE;
			Hmi.Set_Y_Home := FALSE;
			Hmi.Set_Z_P_Limite := FALSE;
			Hmi.Set_Z_Home := FALSE;
			step := step + 1;
		END_IF
		
	9701:
		IF Hmi.Mode_Select = 1 THEN
			step := 8000;
		ELSIF Hmi.Mode_Select = 2 THEN
			step := 8010;
		ELSE
			step := 0;
		END_IF
		


(*====================================
				X+
  ====================================*)
	9710:
		CASE Hmi.Jog_GroupSelect OF
			1:
				posc.GaX_P_Limite := GaX.Pos + 2;
				GaX.SetLimit();
				step := step + 1;
				
			2:
				posc.GbX_P_Limite := GbX.Pos + 2;
				GbX.SetLimit();
				step := step + 1;
				
			3:
				posc.GcX_P_Limite := GcX.Pos + 2;
				GcX.SetLimit();
				step := step + 1;
				
			4:
				posc.GdX_P_Limite := GdX.Pos + 2;
				GdX.SetLimit();
				step := step + 1;
				
			ELSE
				step := 9700;
		END_CASE
		
		
	9711:
