		END_IF
		
	2101:
		o_AC_Encoder_enable :=FALSE;
		step := step + 1;
		
	2102:
		step := 2110;
		
		
	2110:
		Fx.RelMove( 20, spdc.HomeSpeed);	
		step := step + 1;
		
	2111:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2112:
