		step := 2120;
		
	2120:
		Fx.RelMove( -40, spdc.HomeSpeed);	
		step := step + 1;
		
	2121:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2122:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2123:
		step := 2130;
		
