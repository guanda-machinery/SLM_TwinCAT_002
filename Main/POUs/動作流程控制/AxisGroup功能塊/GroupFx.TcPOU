    </Method>
    <Method Name="Fx_Sync_EncA_2_EncB" Id="{e829be8c-b607-4d3e-8478-eb0a7e7ed4b2}">
      <Declaration><![CDATA[METHOD Fx_Sync_EncA_2_EncB : BOOL
VAR_INPUT
END_VAR


]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF 
	Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value <> Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value AND
	NOT Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done 
	THEN
		Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := 
				Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value;
		Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := TRUE;
		Fx_Sync_EncA_2_EncB := FALSE;
ELSIF 
	Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value <> Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value AND 
	Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done 
	THEN
		Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		Fx_Sync_EncA_2_EncB := FALSE;
ELSIF
	Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value = Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value
	THEN
		Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		Fx_Sync_EncA_2_EncB := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Fx_Sync_EncB_2_EncA" Id="{037cd22a-7760-48cb-bdcd-2cc26854975e}">
      <Declaration><![CDATA[METHOD Fx_Sync_EncB_2_EncA : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF 
	Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value <> Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value AND
	NOT Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done 
	THEN
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := 
				Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value;
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := TRUE;
		Fx_Sync_EncB_2_EncA := FALSE;
ELSIF 
	Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value <> Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value AND 
	Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done 
	THEN
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		Fx_Sync_EncB_2_EncA := FALSE;
ELSIF
	Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value = Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value
	THEN
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		Fx_Sync_EncB_2_EncA := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Action Name="input" Id="{3348f645-a80a-4e01-80ba-b842c76980d7}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[// 下壓A 原點
pressureA_home_sensor := NOT IO.i501;
// 下壓B 原點
pressureB_home_sensor  := NOT IO.i502;
// 下壓C 原點
pressureC_home_sensor  := NOT IO.i503;
// 下壓D 原點
pressureD_home_sensor  := NOT IO.i504;


// 下壓A 壓力
pressureA_pressure_sensor := IO.i505;
// 下壓B 壓力
pressureB_pressure_sensor  := IO.i506;
// 下壓C 壓力
pressureC_pressure_sensor  := IO.i507;
// 下壓D 壓力
pressureD_pressure_sensor  := IO.i508;


// 油壓幫浦過載
Oli_Pump_Overload := IO.i209;
// 油壓散熱幫浦過載
OliCooling_Pump_Overload := IO.i210;
// 油壓幫浦已開啟
OliCooling_Pump_PowerOn := NOT Oli_Pump_Overload AND NOT Oli_Pump_Overload AND o_Oil_Pressure_Pump;


// A側 夾輪內側  (材料整料點)
// AC_in_sensor  := IO.i512;		// 原始設計 (26.01.28)
AC_in_sensor  := IO.i713;		// 換sick	(26.01.28) 轉極性
// AC_in_sensor  := IO.i710;			// 新增下方原點		(26.01.28) X會被上方鋁件干擾
AC_out_sensor := IO.i709;

// B側 夾輪內側 (材料脫離點)
BD_in_sensor  := IO.i511;
BD_out_sensor  := IO.i711;


// AC 夾輪座原點
AC_Home_sensor	:= IO.i509;
// BD 夾輪座原點
BD_Home_sensor	:= IO.i510;

]]></ST>
      </Implementation>
    </Action>
    <Action Name="output" Id="{0610ef06-308c-45b7-b722-7dde8f757d39}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[// 下壓A 放鬆
IO.q208 := o_PressureA_Up;
// 下壓A 夾緊
IO.q209 := o_PressureA_Dn;

// 下壓B 放鬆
IO.q211 := o_PressureB_Up;
// 下壓B 夾緊
IO.q210 := o_PressureB_Dn;

// 下壓C 放鬆
IO.q213 := o_PressureC_Up;
// 下壓C 夾緊
IO.q212 := o_PressureC_Dn;

// 下壓D 放鬆
IO.q215 := o_PressureD_Up;
// 下壓D 夾緊
IO.q214 := o_PressureD_Dn;




// AC側 夾輪 夾緊
IO.q301 := o_AC_Clamp_Close;
// AC側 夾輪 放鬆
IO.q302 := o_AC_Clamp_Open;

IO.q311 := o_AC_Encoder_enable;
IO.q312 := o_AC_Encoder_disable;

IF o_AC_Encoder_enable THEN
	AC_Encoder_Active := TRUE;
ELSIF o_AC_Encoder_disable THEN
	AC_Encoder_Active := FALSE; 
END_IF

// BD側 夾輪 夾緊
IO.q303 := o_BD_Clamp_Close;
// BD側 夾輪 放鬆
IO.q304 := o_BD_Clamp_Open;

IO.q313 := o_BD_Encoder_enable;
IO.q314 := o_BD_Encoder_disable;
IF o_BD_Encoder_enable THEN
	BD_Encoder_Active := TRUE;
ELSIF o_BD_Encoder_disable THEN
	BD_Encoder_Active := FALSE; 
END_IF

// 油壓機
IO.q202 := o_Oil_Pressure_Pump;

]]></ST>
      </Implementation>
    </Action>
    <Action Name="Pump_Close" Id="{ee3cc342-089f-451e-b205-f6c55611b14d}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[tmr_Oil_Pressure_Pump(
	IN := 
		IO.q208 OR IO.q209 OR IO.q210 OR IO.q211 OR
		IO.q212 OR IO.q213 OR IO.q214 OR IO.q215 OR
		IO.q301 OR IO.q302 OR IO.q303 OR IO.q304,
	PT := T#30M );
// 油壓閒置關閉
IF o_Oil_Pressure_Pump AND NOT tmr_Oil_Pressure_Pump.Q THEN
	o_Oil_Pressure_Pump := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_00_Start_Pump" Id="{13b8780f-5eb8-47c8-b239-6bbbc8e2f222}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[{}
CASE step OF
	// FxA動作前檢查檢查
	1: 
		IF NOT  Oli_Pump_Overload THEN
			step := step + 1;
		ELSE
			pMsg.Push_Error("油壓幫浦保護器異常 ");
		END_IF
		
	2:
		IF NOT  OliCooling_Pump_Overload THEN
			step := step + 1;
		ELSE
			pMsg.Push_Error("油壓散熱幫浦保護器異常 ");
		END_IF
		
	3:
		step := 10;
		
		
	10: // 確認油壓機啟動狀態
		IF o_Oil_Pressure_Pump THEN
			step := 20;
		ELSE
			step := step + 1;
		END_IF
		
		
	11: // 設定閥體位置，防止油壓開啟時誤動作
		// FxA
		o_AC_Clamp_Close	:= FALSE;
		o_AC_Clamp_Open		:= FALSE;
		// FxB
		o_BD_Clamp_Close	:= FALSE;
		o_BD_Clamp_Open		:= FALSE;
		step := step + 1;
		
	12:
		tmr01.IN := TRUE;
		tmr01.PT := T#200MS;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	13:// 開啟油壓
		o_Oil_Pressure_Pump := TRUE;
		step := step + 1;
		
	14:
		tmr01.IN := TRUE;
		tmr01.PT := T#1S;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	15:
		step := 20;
		
	20:
		bdone := TRUE;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_10_MoveTo" Id="{05bea816-0b26-4c20-afcd-6a449c739678}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	1000:
		step := 1010;
		
(*	================================
				移到點位
	================================*)
	1010:
		Fx.AbsMove(_TargetPos - 10, spdc.HighSpeed_FX);
		step := step + 1;
		
	1011:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	1012:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	1013:
		tmr01.IN := NOT Fx.bBuzy;
		tmr01.PT := T#1.5S;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	1014:
		LogFx.Write(  fx_a_pos := Fx.Pos, ex_enc_pos := Fx_Exp_Pos);
		step := 1020;

(*	================================
				位置補償(修正)
	================================*)
	1020:
		IF ABS(_TargetPos - Fx_Exp_Pos) > 0.5  THEN
			step := step + 1;
		ELSE
			step := 1030;
		END_IF
		
	1021: // 移動鋼樑到 材料整料點 慢速
		Fx.RelMove(_TargetPos - Fx_Exp_Pos, 20);
		step := step + 1;
		
	1022:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	1023:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	1024:
		tmr01.IN := NOT Fx.bBuzy;
		tmr01.PT := T#500MS;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	1025:
		step := 1020;
		
		
(*	================================
				移動結束
	================================*)
	1030:
		Fx.SetPos(Fx_Exp_Pos);
		step := step + 1;
		
	1031:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	1032:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	1033:
		step := 1040;
		
	1040:
		IF IO.i709 AND NOT AC_Encoder_Active THEN
			step := step + 1;
		ELSE
			step := 1050;
		END_IF
		
	1041:
		o_AC_Encoder_enable :=TRUE;
		o_AC_Encoder_disable :=FALSE;
		
		tmr01.IN := TRUE;
		tmr01.PT := T#2S;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	1042:
		o_AC_Encoder_enable :=FALSE;
		step := step + 1;
		
	1043:
		IF Fx_Sync_EncB_2_EncA() THEN
			step := step + 1;
		END_IF
		
	1044:
		step := 1050;
		
		
	1050:
		bDone := TRUE;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_20_Find_Home" Id="{6efa487d-5a05-493e-a182-1b9c14fca49e}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	// FxA動作前檢查檢查
	2000: // 確認材料進入FxA的夾輪
		IF o_BD_Clamp_Close THEN
			step := step + 1;
		ELSE
			step := step + 10000;
			pMsg.Push_Error(WStrConcat(name, ":BD夾輪未夾緊 "));
		END_IF
		
	2001:
		IF NOT o_AC_Clamp_Close THEN
			step := step + 1;
		ELSE
			step := step + 10000;
			pMsg.Push_Error(WStrConcat(name, ":AC夾輪已夾緊 "));
		END_IF
		
	2002:
		_UserEncA := FALSE;
		step := 2010;
		
(*	================================
		快速後退 材料 到 脫離原點
	================================*)
	2010:
		IF AC_in_sensor THEN
			step := step + 1;
		ELSE
			step := 2020;
		END_IF
		
	2011:
		o_BD_Encoder_enable		:= TRUE;
		o_BD_Encoder_disable	:= FALSE;
		Fx.RelMove(-10000, SpdC.HighSpeed_FX);
		step := step + 1;
		
	2012:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2013:
		IF NOT AC_in_sensor THEN
			step := step + 1;
			Fx.Stop(SpdC.HighSpeed_FX);
		ELSIF Fx.bDone THEN
			step := step + 10000;
			pMsg.Push_Error(WStrConcat(name, ":未找到材料脫離點 "));
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2014:
		step := 2020;

(*	================================
		慢速前進 材料 到 進入原點
	================================*)
	2020:
		IF NOT Fx.bBuzy THEN
			step := step + 1;
		END_IF
		
	2021: // 移動鋼樑到 材料整料點 慢速
		Fx.RelMove(800, SpdC.HighSpeed_FX / 4);
		step := step + 1;
		
	2022:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2023:
		IF AC_in_sensor THEN
			step := step + 1;
			Fx.Stop(SpdC.HighSpeed_FX);
		ELSIF Fx.bDone THEN
			step := step + 10000;
			pMsg.Push_Error(WStrConcat(name, ":未找到材料脫離點 "));
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2024:
		tmr01.IN := NOT Fx.bBuzy;
		tmr01.PT := T#500MS;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	2025:
		step := 2030;
		
		
(*	================================
		爬行(超慢速)後退 材料 到 離開原點
	================================*)
	2030:
		Fx.RelMove(-500, SpdC.DotSpeed);
		step := step + 1;
		
	2031:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2032:
		IF NOT AC_in_sensor THEN
			step := step + 1;
			Fx.Stop(SpdC.HighSpeed_FX);
		ELSIF Fx.bDone THEN
			step := step + 10000;
			pMsg.Push_Error(WStrConcat(name, ":未找到材料脫離點 "));
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2033:
		tmr01.IN := NOT Fx.bBuzy;
		tmr01.PT := T#500MS;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	2034:
		step := 2040;
		
(*	================================
		移動鋼樑 到 原點偏移位置
	================================*)
	2040:  // 
		Fx.RelMove(posc.Fx_HomeOffset, SpdC.HighSpeed_FX);
		step := step + 1;
		
	2041:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2042:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2043:
		tmr01.IN := TRUE;
		tmr01.PT := T#500MS;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	2044:
		step := 2050;

(*	================================
			歸零FX位置
	================================*)
	2050:
		Fx.Homing();
		step := step + 1;
		
	2051:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2052:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2053:
		step := 2060;

(*	================================
			歸零測長盤
	================================*)

	2060:
		tmr01.IN := TRUE;
		tmr01.PT := T#500MS;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	2061:
		o_BD_Encoder_enable		:= FALSE;
		step := step + 1;
		
	2062:
		step := 2070;
		
	2070:
		Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := 100000;
		Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := TRUE;
		step := step + 1;
		
	2071:
		IF Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			Encoder_FxB_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
			step := step + 1;
		END_IF
		
	2072:
		step := 2090;
		
		
	2090:
		bDone := TRUE;
		AC_moveDis := 0;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_21_Set_A_Enc" Id="{d87e476b-11ac-4904-b119-81aa7725eabf}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	2100:
		o_AC_Encoder_enable :=TRUE;
		o_AC_Encoder_disable :=FALSE;
		
		tmr01.IN := TRUE;
		tmr01.PT := T#2S;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	2101:
		o_AC_Encoder_enable :=FALSE;
		step := step + 1;
		
	2102:
		step := 2110;
		
		
	2110:
		Fx.RelMove( 20, spdc.HomeSpeed);	
		step := step + 1;
		
	2111:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2112:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2113:
		step := 2120;
		
	2120:
		Fx.RelMove( -40, spdc.HomeSpeed);	
		step := step + 1;
		
	2121:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2122:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2123:
		step := 2130;
		
	2130:
		Fx.RelMove( 20, spdc.HomeSpeed);	
		step := step + 1;
		
	2131:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2132:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2133:
		step := 2140;	
	
	2140:
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := TO_UDINT(FxB_Exp_Pos / 0.144625) + 100000;
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := TRUE;
		step := step + 1;
		
	2141:
		IF Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
			step := step + 1;
		END_IF
		
	2142:
		_UserEncA := TRUE;
		step := 2150;
		
		
	2150:
		o_BD_Encoder_enable		:= FALSE;
		o_BD_Encoder_disable	:= TRUE;
		
		tmr01.IN := TRUE;
		tmr01.PT := T#1S;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	2151:
		o_BD_Encoder_disable := FALSE;
		step := step + 1;
		
	2152:
		step := 2160;
		
	2160:
		bDone := TRUE;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
