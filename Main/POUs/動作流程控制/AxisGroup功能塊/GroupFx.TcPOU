		Fx.RelMove( 20, spdc.HomeSpeed);	
		step := step + 1;
		
	2131:
		IF Fx.bBuzy OR Fx.bError THEN
			step := step + 1;
		END_IF
		
	2132:
		IF Fx.bDone THEN
			step := step + 1;
		ELSIF Fx.bError THEN
			step := step + 10000;
		END_IF
		
	2133:
		step := 2140;	
	
	2140:
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := TO_UDINT(FxB_Exp_Pos / 0.144625) + 100000;
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := TRUE;
		step := step + 1;
		
	2141:
		IF Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
			step := step + 1;
		END_IF
		
	2142:
		_UserEncA := TRUE;
		step := 2150;
		
		
	2150:
		o_BD_Encoder_enable		:= FALSE;
		o_BD_Encoder_disable	:= TRUE;
		
		tmr01.IN := TRUE;
		tmr01.PT := T#1S;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step := step + 1;
		END_IF
		
	2151:
		o_BD_Encoder_disable := FALSE;
		step := step + 1;
		
	2152:
		step := 2160;
		
	2160:
		bDone := TRUE;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_A_Push_UnPush" Id="{43e4df2b-dfe6-42cd-b295-8067ed034c41}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_A_P.Step OF
(*	================================
				A下壓
 	================================*)	

	// FxA動作前檢查檢查
	1: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		IF GbZ.fPos >= 500 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_A_P.Step := step_A_P.Step + 1;
		ELSE
			step_A_P.Step := step_A_P.Step + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(".A_Push");
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	2:
		tmr111.IN := TRUE;
		tmr111.PT := T#10S;
		IF o_Oil_Pressure_Pump OR tmr111.Q THEN
			tmr111.IN := FALSE;
			IF o_Oil_Pressure_Pump THEN
				step_A_P.Step := step_A_P.Step + 1;
			ELSIF tmr111.Q THEN
				pMsg.Push_Error(WStrConcat(name, ".A_Push:下壓A等待油壓系統啟動逾時"));
				step_A_P.Step := step_A_P.Step + 10000;
			END_IF
		END_IF
		
	3:
		step_A_P.Step := 10;
		
		
	10: // 下壓啟動
		o_PressureA_Up := FALSE;
		o_PressureA_Dn := TRUE;
		step_A_P.Step := step_A_P.Step + 1;
		
		
	11:
		tmr101.IN := TRUE;
		tmr101.PT := T#500MS;
		IF tmr101.q THEN
			tmr101.IN := FALSE;
			step_A_P.Step := step_A_P.Step + 1;
		END_IF
		
	12:
		o_PressureA_Dn := FALSE;
		step_A_P.Step := step_A_P.Step + 1;
		
	13:
		tmr101.IN := pressureA_pressure_sensor;
		tmr101.PT := T#500MS;
		tmr111.IN := TRUE;
		tmr111.PT := T#10S;
		IF tmr101.q OR tmr111.q THEN
			tmr101.IN := FALSE;
			tmr111.IN := FALSE;
			step_A_P.Step := step_A_P.Step + 1;
		END_IF
		
	14:
		step_A_P.bDone := TRUE;
		step_A_P.Step := 0;


(*	================================
				A放開
 	================================*)
	// FxA動作前檢查檢查
	100: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		IF GbZ.fPos >= 500 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_A_P.Step := step_A_P.Step + 1;
		ELSE
			step_A_P.Step := step_A_P.Step + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(".A_Push");
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	101:
		tmr111.IN := TRUE;
		tmr111.PT := T#10S;
		IF o_Oil_Pressure_Pump OR tmr111.Q THEN
			tmr111.IN := FALSE;
			IF o_Oil_Pressure_Pump THEN
				step_A_P.Step := step_A_P.Step + 1;
			ELSIF tmr111.Q THEN
				pMsg.Push_Error(WStrConcat(name, ".A_Push:下壓A等待油壓系統啟動逾時"));
				step_A_P.Step := step_A_P.Step + 10000;
			END_IF
		END_IF
		
	102:
		step_A_P.Step := 110;
		
		
	110: // 放開啟動
		o_PressureA_Up := TRUE;
		o_PressureA_Dn := FALSE;
		step_A_P.Step := step_A_P.Step + 1;
		
		
	111:
		tmr101.IN := TRUE;
		tmr101.PT := T#500MS;
		IF tmr101.q THEN
			tmr101.IN := FALSE;
			step_A_P.Step := step_A_P.Step + 1;
		END_IF
		
	112:
		o_PressureA_Up := FALSE;
		step_A_P.Step := step_A_P.Step + 1;
		
	113:
		tmr101.IN := pressureA_home_sensor;
		tmr101.PT := T#500MS;
		tmr111.IN := TRUE;
		tmr111.PT := T#10S;
		IF tmr01.q OR tmr111.q THEN
			tmr101.IN := FALSE;
			tmr111.IN := FALSE;
			step_A_P.Step := step_A_P.Step + 1;
		END_IF
		
	114:
		step_A_P.bDone := TRUE;
		step_A_P.Step := 0;
END_CASE

step_A_P.bBuzy := step_A_P.Step > 0 AND step_A_P.Step < 10000;
step_A_P.bError := step_A_P.Step >= 10000;

IF step_A_P.bError OR step_A_P.bBuzy THEN
	step_A_P.bDone := FALSE;
END_IF

]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_AC_00_Clamp" Id="{6a89065b-7938-4874-a363-a1c0f80c8805}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_AC_C.Step  OF
	// FxA動作前檢查檢查
	1:  // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		tmr01.IN := FALSE;
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		IF GbZ.fPos >= 490 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		ELSE
			step_AC_C.Step  := step_AC_C.Step  + 20000;
			strmem1.WRITE(name);
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
		// 確認AC下壓位置
//		IF pressureA_home_sensor AND pressureC_home_sensor THEN
//			step_AC_C.Step  := step_AC_C.Step  + 1;
//		ELSE
//			step_AC_C.Step  := step_AC_C.Step  + 10000;
//			pMsg.Push_Error(StrConcat_2(name, ":下壓A or 下壓C 未停在原點，動作取消 "));
//		END_IF
		
	2: // 確認材料進入FxA的夾輪
		IF NOT (AC_in_sensor XOR AC_out_sensor) OR Hmi.Jog_UnLimite OR AC_moveDis > 0 THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		ELSE
			step_AC_C.Step  := step_AC_C.Step  + 20000;
			pMsg.Push_Error(WStrConcat(name, ":未感應到原料，動作取消 "));
		END_IF
		
	3:
		IF o_Oil_Pressure_Pump THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
	4:
		IF AC_moveDis = 0 OR NOT b_AC_HOME THEN
			// 夾緊
			step_AC_C.Step  := 10; 
		ELSE
			// 進到設定距離
			step_AC_C.Step  := 40;
		END_IF
		
		
	10: // AC夾輪夾
		o_AC_Clamp_Open		:= FALSE;
		o_AC_Clamp_Close	:= TRUE;
		
		// 編碼器歸零
		IF NOT b_AC_HOME AND NOT io.i509 THEN
			Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := TRUE;
			Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Set_counter_value := 10000;
		END_IF
		
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	11: 
		// 編碼器歸零完成
		IF Axis.Encoder_FxA_Clamp.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
			b_AC_HOME := TRUE;
		END_IF
		
		IF b_AC_HOME AND AC_moveDis > 0 THEN
			step_AC_C.Step  := 41;
		END_IF
		
		// 確定BD夾輪停止移動
		tmr105.IN := ABS(FxA_Clamp_Spd) <= 1;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
		
	12:
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	13:
		step_AC_C.Step  := 90;
		
{region "============= 進到設定位置  ============="}
	40: // 判斷前進後退
		IF AC_moveDis - FxA_Clamp_Pos > 0 THEN
			// 目標大於現在位置
			o_AC_Clamp_Close	:= FALSE;
			o_AC_Clamp_Open		:= TRUE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		ELSIF AC_moveDis - FxA_Clamp_Pos < 0 THEN
			// 目標小於現在位置
			o_AC_Clamp_Close	:= TRUE;
			o_AC_Clamp_Open		:= FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		ELSE
			step_AC_C.Step  := 90;
		END_IF
		
	41: // 設定位置 - 目前位置 (接近0表示位置到達) <= 停止位移補償(移動速度 * 停止時間) 
		IF ABS(AC_moveDis - FxA_Clamp_Pos) <= (ABS(FxA_Clamp_Spd) * 0.1) THEN
			o_AC_Clamp_Close	:= FALSE;
			o_AC_Clamp_Open		:= FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
		// 靜止1秒後，標示為功能完成
		tmr105.IN := ABS(FxA_Clamp_Spd) <= 1;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
			 
	42:
		o_AC_Clamp_Close		:= FALSE;
		o_AC_Clamp_Open			:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
			 
	43:
		 step_AC_C.Step  := 90;
	
{endregion}
	
		
	90:
		AC_moveDis := 0;
		step_AC_C.bDone := TRUE;
		step_AC_C.Step  := 0;
END_CASE

IF o_AC_Clamp_Open THEN
	b_AC_Clamp := FALSE;
ELSIF step_AC_C.Step  = 90 THEN
	b_AC_Clamp := TRUE;
END_IF

step_AC_C.bBuzy := step_AC_C.Step > 0 AND step_AC_C.Step < 10000;
step_AC_C.bError := step_AC_C.Step >= 10000;

IF step_AC_C.bError OR step_AC_C.bBuzy THEN
	step_AC_C.bDone := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_AC_01_UnClamp" Id="{b1386a97-5c6b-4392-a236-0ccc7b605ce6}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_AC_C.Step  OF
	// FxA動作前檢查檢查
	100: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		tmr01.IN := FALSE;
		IF GbZ.fpos > 500 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		ELSE
			step_AC_C.Step  := step_AC_C.Step  + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	101:
		IF o_Oil_Pressure_Pump THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
	102:
		step_AC_C.Step  := 110;
		
		// 確認BD下壓位置
//		IF pressureA_home_sensor AND pressureC_home_sensor THEN
//			step_AC_C.Step  := step_AC_C.Step  + 1;
//		ELSE
//			step_AC_C.Step  := step_AC_C.Step  + 10000;
//			pMsg.Push_Error(StrConcat_2(name, ":下壓A or 下壓C 未停在原點，動作取消 "));
//		END_IF
		

		
		
	110: // 放開選擇
		o_AC_Encoder_enable :=FALSE;
		o_AC_Encoder_disable :=TRUE;
		IF AC_moveDis = 0 THEN
			// 退到原點
			step_AC_C.Step  := 120; 
		ELSE
			// 退到設定距離
			step_AC_C.Step  := 140;
		END_IF

	{region "============= 退到原點  ============="}
	120: // 放開BD夾輪夾
		o_AC_Clamp_Close	:= FALSE;
		o_AC_Clamp_Open		:= TRUE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	121: // 確定BD夾輪停止移動
		tmr105.IN := ABS(FxA_Clamp_Spd) <= 1;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
	122:
		o_AC_Clamp_Open		:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	123: 
		step_AC_C.Step  := 130;
		
	130:
		
		step_AC_C.Step  := 190;
	{endregion}		
		
		
		
	{region "============= 退到設定距離  ============="}
	140: // 紀錄開始位置
		AC_StartPos := FxA_Clamp_Pos;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	141: // 開始後退
		o_AC_Clamp_Close	:= FALSE;
		o_AC_Clamp_Open		:= TRUE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	142: // 大於設定的距離 ( 開始位置 - 目前位置 ) >= 移動距離 - 停止位移補償(移動速度 * 停止時間)
		IF ABS(AC_StartPos - FxA_Clamp_Pos) >= ABS(AC_moveDis) - ( ABS(FxA_Clamp_Spd) * 0.1) THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
		tmr105.IN := ABS(FxA_Clamp_Spd) <= 1;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
			 
	143:
		o_AC_Clamp_Open		:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
			 
	144:
		 step_AC_C.Step  := 190;
	
	{endregion}
	190:
		o_AC_Encoder_enable :=FALSE;
		o_AC_Encoder_disable :=FALSE;
		o_AC_Clamp_Open		:= FALSE;
		step_AC_C.bDone := TRUE;
		step_AC_C.Step  := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_AC_02_Stop" Id="{40063994-3613-489b-b220-e33809770781}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_AC_C.Step OF
	// FxA動作前檢查檢查
	200: 
		step_AC_C.Step := 210;
		
		
	210: // BD夾輪夾
		o_AC_Clamp_Open		:= FALSE;
		o_AC_Clamp_Close	:= FALSE;
		step_AC_C.Step := step_AC_C.Step + 1;
		
	211: 
		step_AC_C.Step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_AC_03_Home" Id="{c3c71fb5-4ccb-482e-b003-303bedcbc7a9}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_AC_C.Step  OF
	// FxA動作前檢查檢查
	300:  // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		tmr01.IN := FALSE;
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		IF GbZ.fPos >= 490 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		ELSE
			step_AC_C.Step  := step_AC_C.Step  + 20000;
			strmem1.WRITE(name);
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
		// 確認AC下壓位置
//		IF pressureA_home_sensor AND pressureC_home_sensor THEN
//			step_AC_C.Step  := step_AC_C.Step  + 1;
//		ELSE
//			step_AC_C.Step  := step_AC_C.Step  + 10000;
//			pMsg.Push_Error(StrConcat_2(name, ":下壓A or 下壓C 未停在原點，動作取消 "));
//		END_IF
		
	301: 
		IF o_Oil_Pressure_Pump THEN
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
	302:
		IF IO.i509 THEN
			step_AC_C.Step  := 310; 
		ELSE
			step_AC_C.Step  := 320; 
		END_IF
		
		
		
	310: // AC夾輪夾
		o_AC_Clamp_Open		:= TRUE;
		o_AC_Clamp_Close	:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	311:
		tmr105.IN := NOT IO.i509;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
	312:
		o_AC_Clamp_Open		:= FALSE;
		o_AC_Clamp_Close	:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	313:
		step_AC_C.Step  := 320;
		
		
	320:
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := TRUE;
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Set_counter_value := 10000;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	321:
		o_AC_Clamp_Open		:= FALSE;
		o_AC_Clamp_Close	:= TRUE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
			
	322:
		// 編碼器歸零完成
		IF Axis.Encoder_FxA_Clamp.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
			b_AC_HOME := TRUE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF

	323:
		o_AC_Clamp_Open		:= FALSE;
		o_AC_Clamp_Close	:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
		
	324:
		step_AC_C.Step  := 330;
	
	330:
		o_AC_Clamp_Open		:= TRUE;
		o_AC_Clamp_Close	:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	331:
		tmr105.IN := NOT IO.i509;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_AC_C.Step  := step_AC_C.Step  + 1;
		END_IF
		
	332:
		o_AC_Clamp_Open		:= FALSE;
		o_AC_Clamp_Close	:= FALSE;
		step_AC_C.Step  := step_AC_C.Step  + 1;
		
	333:
		step_AC_C.bDone := TRUE;
		step_AC_C.Step  := 0;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_B_Push_UnPush" Id="{9c858001-e0f2-40c9-aa15-c276d1e6be63}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_B_P.Step  OF
(*	================================
				B下壓
 	================================*)	

	// FxA動作前檢查檢查
	1: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		IF GbZ.fPos >= 500 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_B_P.Step  := step_B_P.Step  + 1;
		ELSE
			step_B_P.Step  := step_B_P.Step  + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(".B_Push");
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	2:
		tmr112.IN := TRUE;
		tmr112.PT := T#10S;
		IF o_Oil_Pressure_Pump OR tmr112.Q THEN
			tmr112.IN := FALSE;
			IF o_Oil_Pressure_Pump THEN
				step_B_P.Step  := step_B_P.Step  + 1;
			ELSIF tmr112.Q THEN
				pMsg.Push_Error(WStrConcat(name, ".B_Push:下壓B等待油壓系統啟動逾時"));
				step_B_P.Step  := step_B_P.Step  + 10000;
			END_IF
		END_IF
		
	3:
		step_B_P.Step  := 10;
		
		
	10: // 下壓啟動
		o_PressureB_Up := FALSE;
		o_PressureB_Dn := TRUE;
		step_B_P.Step  := step_B_P.Step  + 1;
		
	11:
		tmr102.IN := TRUE;
		tmr102.PT := T#500MS;
		IF tmr102.q THEN
			tmr102.IN := FALSE;
			step_B_P.Step  := step_B_P.Step  + 1;
		END_IF
		
	12:
		o_PressureB_Dn := FALSE;
		step_B_P.Step  := step_B_P.Step  + 1;
		
	13:
		tmr102.IN := pressureB_pressure_sensor;
		tmr102.PT := T#500MS;
		tmr112.IN := TRUE;
		tmr112.PT := T#10S;
		IF tmr102.q OR tmr112.q THEN
			tmr102.IN := FALSE;
			tmr112.IN := FALSE;
			step_B_P.Step  := step_B_P.Step  + 1;
		END_IF
		
	14:
		step_B_P.bDone := TRUE;
		step_B_P.Step  := 0;


(*	================================
				B放開
 	================================*)
	// FxA動作前檢查檢查
	100: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		IF GbZ.fPos >= 500 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_B_P.Step  := step_B_P.Step  + 1;
		ELSE
			step_B_P.Step  := step_B_P.Step  + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(".B_Push");
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	101:
		IF o_Oil_Pressure_Pump OR tmr112.Q THEN
			tmr112.IN := FALSE;
			IF o_Oil_Pressure_Pump THEN
				step_B_P.Step  := step_B_P.Step  + 1;
			ELSIF tmr112.Q THEN
				pMsg.Push_Error(WStrConcat(name, ".B_Push:下壓B等待油壓系統啟動逾時"));
				step_B_P.Step  := step_B_P.Step  + 10000;
			END_IF
		END_IF
		
	102:
		step_B_P.Step  := 110;
		
		
	110: // 放開啟動
		o_PressureB_Up := TRUE;
		o_PressureB_Dn := FALSE;
		step_B_P.Step  := step_B_P.Step  + 1;
		
	111:
		tmr102.IN := TRUE;
		tmr102.PT := T#500MS;
		IF tmr102.q THEN
			tmr102.IN := FALSE;
			step_B_P.Step  := step_B_P.Step  + 1;
		END_IF
		
	112:
		o_PressureB_Up := FALSE;
		step_B_P.Step  := step_B_P.Step  + 1;
		
	113:
		tmr102.IN := pressureB_home_sensor;
		tmr102.PT := T#500MS;
		tmr112.IN := TRUE;
		tmr112.PT := T#10S;
		IF tmr102.q OR tmr112.q THEN
			tmr102.IN := FALSE;
			tmr112.IN := FALSE;
			step_B_P.Step  := step_B_P.Step  + 1;
		END_IF
		
	114:
		step_B_P.bDone := TRUE;
		step_B_P.Step  := 0;
END_CASE

step_B_P.bBuzy := step_B_P.Step > 0 AND step_B_P.Step < 10000;
step_B_P.bError := step_B_P.Step >= 10000;

IF step_B_P.bError OR step_B_P.bBuzy THEN
	step_B_P.bDone := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_BD_00_Clamp" Id="{8507acf2-42ba-4836-ae67-3588c9830f22}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_BD_C.Step  OF
	// FxA動作前檢查檢查
	1: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		tmr01.IN := FALSE;
		IF GbZ.fPos > 490 OR GbX.fPos < 50 OR NOT Hmi.Jog_UnLimite THEN
			step_BD_C.Step  := step_BD_C.Step  + 1;
		ELSE
			step_BD_C.Step  := step_BD_C.Step  + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
		
	2: // 確認材料進入FxB的夾輪
		IF NOT (BD_in_sensor XOR BD_out_sensor)  OR Hmi.Jog_UnLimite OR BD_moveDis > 0 THEN
			step_BD_C.Step  := step_BD_C.Step  + 1;
		ELSE
			step_BD_C.Step  := step_BD_C.Step  + 10000;
			pMsg.Push_Error(WStrConcat(name, ":未感應到原料，動作取消 "));
		END_IF
		
//	102: // 確認BD下壓位置
//		IF pressureB_home_sensor AND pressureD_home_sensor THEN
//			step_BD_C.Step  := step_BD_C.Step  + 1;
//		ELSE
//			step_BD_C.Step  := step_BD_C.Step  + 10000;
//			pMsg.Push_Error(StrConcat_2(name, ":下壓B or 下壓D 未停在原點，動作取消 "));
//		END_IF
		
	3: 
		IF o_Oil_Pressure_Pump THEN
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
	4:
		IF BD_moveDis = 0 OR NOT b_BD_HOME THEN
			// 夾緊
			step_BD_C.Step  := 10; 
		ELSE
			// 進到設定距離
			step_BD_C.Step  := 40;
		END_IF
		
		
	10: // BD夾輪夾
		Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
		Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= TRUE;
		
		// 編碼器歸零
		IF NOT b_BD_HOME AND NOT io.i510 THEN
			Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := TRUE;
			Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Set_counter_value := 10000;
		END_IF
		
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	11: 
		// 編碼器歸零完成
		IF Axis.Encoder_FxB_Clamp.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
			b_BD_HOME := TRUE;
		END_IF
		
		IF b_BD_HOME AND BD_moveDis > 0 THEN
			step_BD_C.Step  := 41;
		END_IF
		
		// 確定BD夾輪停止移動
		tmr106.IN := ABS(FxB_Clamp_Spd) <= 1;
		tmr106.PT := T#1S;
		IF tmr106.Q THEN
			tmr106.IN := FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
		
	12:
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	13:
		step_BD_C.Step  := 90;
		
	{region "============= 進到設定位置  ============="}
	40: // 判斷前進後退
		IF BD_moveDis - FxB_Clamp_Pos > 0 THEN
			// 目標大於現在位置
			o_BD_Clamp_Close	:= FALSE;
			o_BD_Clamp_Open		:= TRUE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		ELSIF BD_moveDis - FxB_Clamp_Pos < 0 THEN
			// 目標小於現在位置
			o_BD_Clamp_Close	:= TRUE;
			o_BD_Clamp_Open		:= FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		ELSE
			step_BD_C.Step  := 90;
		END_IF
		
	41: // 設定位置 - 目前位置 (接近0表示位置到達) <= 停止位移補償(移動速度 * 停止時間) 
		IF ABS(BD_moveDis - FxB_Clamp_Pos) <= (ABS(FxB_Clamp_Spd) * 0.1) THEN
			o_BD_Clamp_Close		:= FALSE;
			o_BD_Clamp_Open		:= FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
		// 靜止1秒後，標示為功能完成
		tmr106.IN := ABS(FxB_Clamp_Spd) <= 1;
		tmr106.PT := T#1S;
		IF tmr106.Q THEN
			tmr106.IN := FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
			 
	42:
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
			 
	43:
		 step_BD_C.Step  := 90;
	
{endregion}
		
	90:
		BD_moveDis := 0;
		step_BD_C.bDone := TRUE;
		step_BD_C.Step  := 0;
END_CASE

IF o_BD_Clamp_Open THEN
	b_BD_Clamp := FALSE;
ELSIF step_BD_C.Step  = 90 THEN
	b_BD_Clamp := TRUE;
END_IF

step_BD_C.bBuzy := step_BD_C.Step > 0 AND step_BD_C.Step < 10000;
step_BD_C.bError := step_BD_C.Step >= 10000;

IF step_BD_C.bError OR step_BD_C.bBuzy THEN
	step_BD_C.bDone := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_BD_01_UnClamp" Id="{75d4a37a-df64-4629-ab62-9ac7014b8a8f}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_BD_C.Step  OF
	// FxA動作前檢查檢查
	100: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		tmr01.IN := FALSE;
		IF GbZ.pos > 500 OR GbX.fPos < 50 OR NOT Hmi.Jog_UnLimite THEN
			step_BD_C.Step  := step_BD_C.Step  + 1;
		ELSE
			step_BD_C.Step  := step_BD_C.Step  + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	101: 
		IF o_Oil_Pressure_Pump THEN
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
	102:
		step_BD_C.Step  := 110;
	
		// 確認BD下壓位置
//		IF pressureB_home_sensor AND pressureD_home_sensor THEN
//			step_BD_C.Step  := step_BD_C.Step  + 1;
//		ELSE
//			step_BD_C.Step  := step_BD_C.Step  + 10000;
//			pMsg.Push_Error(StrConcat_2(name, ":下壓B or 下壓D 未停在原點，動作取消 "));
//		END_IF
		
		
		
	110: // 放開選擇
		o_BD_Encoder_enable		:= FALSE;
		o_BD_Encoder_disable	:= TRUE;
		IF BD_moveDis = 0 THEN
			// 退到原點
			step_BD_C.Step  := 120; 
		ELSE
			// 退到設定距離
			step_BD_C.Step  := 140;
		END_IF

	{region "============= 退到原點  ============="}
	120: // 放開BD夾輪夾
		o_BD_Clamp_Close	:= FALSE;
		o_BD_Clamp_Open		:= TRUE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	121: // 確定BD夾輪停止移動
		tmr106.IN := ABS(FxB_Clamp_Spd) <= 1 ;
		tmr106.PT := T#1S;
		IF tmr106.Q THEN
			tmr106.IN := FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
	122:
		o_BD_Clamp_Open		:= FALSE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	123: 
		step_BD_C.Step  := 130;
		
	130:
		step_BD_C.Step  := 190;
	{endregion}		
		
		
		
	{region "============= 退到設定距離  ============="}
	140: // 紀錄開始位置
		BD_StartPos := FxB_Clamp_Pos;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	141: // 開始後退
		o_BD_Clamp_Close	:= FALSE;
		o_BD_Clamp_Open		:= TRUE;
		step_BD_C.Step := step_BD_C.step + 1;
		
	142: // 大於設定距離
		IF ABS(BD_StartPos - FxB_Clamp_Pos)  >= ABS(BD_moveDis) - ( ABS(FxB_Clamp_Spd) * 0.1) THEN
			o_BD_Clamp_Open		:= FALSE;
			step_BD_C.step := step_BD_C.step + 1;
		END_IF
		
		tmr106.IN := ABS(FxB_Clamp_Spd) <= 1 ;
		tmr106.PT := T#1S;
		IF tmr01.Q THEN
			tmr106.IN := FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
			 
	143:
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.step := step_BD_C.step + 1;
			 
	144:
		 step_BD_C.step := 190;
	
	{endregion}
	190:
		o_BD_Encoder_enable		:= FALSE;
		o_BD_Encoder_disable	:= FALSE;
		o_BD_Clamp_Open		:= FALSE;
		step_BD_C.bDone := TRUE;
		step_BD_C.step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_BD_02_Stop" Id="{98372c22-8675-4e33-8460-9c41651d3909}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_BD_C.step OF
	// FxA動作前檢查檢查
	200: 
		step_BD_C.step := 210;
		
		
	210: // BD夾輪夾
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.step := step_BD_C.step + 1;
		
	211: 
		step_BD_C.step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_BD_03_Home" Id="{b1097727-222d-4404-a79e-f80833b21600}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_BD_C.Step  OF
	// FxA動作前檢查檢查
	300:  // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		tmr01.IN := FALSE;
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
		Axis.Encoder_FxA_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter := FALSE;
		IF GbZ.fPos >= 490 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_BD_C.Step  := step_BD_C.Step  + 1;
		ELSE
			step_BD_C.Step  := step_BD_C.Step  + 20000;
			strmem1.WRITE(name);
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
		// 確認AC下壓位置
//		IF pressureA_home_sensor AND pressureC_home_sensor THEN
//			step_BD_C.Step  := step_BD_C.Step  + 1;
//		ELSE
//			step_BD_C.Step  := step_BD_C.Step  + 10000;
//			pMsg.Push_Error(StrConcat_2(name, ":下壓A or 下壓C 未停在原點，動作取消 "));
//		END_IF
		
	301: 
		IF o_Oil_Pressure_Pump THEN
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
	302:
		IF IO.i510 THEN
			step_BD_C.Step  := 310; 
		ELSE
			step_BD_C.Step  := 320; 
		END_IF
		
		
		
	310: // AC夾輪夾
		o_BD_Clamp_Open		:= TRUE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	311:
		tmr105.IN := NOT IO.i510;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
	312:
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	313:
		step_BD_C.Step  := 320;
		
		
	320:
		Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := TRUE;
		Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Set_counter_value := 10000;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	321:
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= TRUE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
			
	322:
		// 編碼器歸零完成
		IF Axis.Encoder_FxB_Clamp.MDP5001_511_Input.MDP5001_511_Status.Set_counter_done THEN
			Axis.Encoder_FxB_Clamp.MDP5001_511_Output.MDP5001_511_Control.Set_counter_on_latch_C := FALSE;
			b_BD_HOME := TRUE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF

	323:
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
		
	324:
		step_BD_C.Step  := 330;
	
	330:
		o_BD_Clamp_Open		:= TRUE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	331:
		tmr105.IN := NOT IO.i510;
		tmr105.PT := T#1S;
		IF tmr105.Q THEN
			tmr105.IN := FALSE;
			step_BD_C.Step  := step_BD_C.Step  + 1;
		END_IF
		
	332:
		o_BD_Clamp_Open		:= FALSE;
		o_BD_Clamp_Close	:= FALSE;
		step_BD_C.Step  := step_BD_C.Step  + 1;
		
	333:
		step_BD_C.bDone := TRUE;
		step_BD_C.Step  := 0;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step_C_Push_UnPush" Id="{26236847-5d32-470a-961f-e4d90f6e2448}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step_C_P.Step OF
(*	================================
				C下壓
 	================================*)	

	// FxA動作前檢查檢查
	1: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		IF GbZ.fPos >= 500 OR GbX.fPos > 50 OR NOT Hmi.Jog_UnLimite THEN
			step_C_P.Step  := step_C_P.Step  + 1;
		ELSE
			step_C_P.Step  := step_C_P.Step  + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(".C_Push");
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	2:
		tmr114.IN := TRUE;
		tmr114.PT := T#10S;
		IF o_Oil_Pressure_Pump OR tmr113.Q THEN
			tmr113.IN := FALSE;
			IF o_Oil_Pressure_Pump THEN
				step_C_P.Step  := step_C_P.Step  + 1;
			ELSIF tmr113.Q THEN
				pMsg.Push_Error(WStrConcat(name, ".C_Push:下壓B等待油壓系統啟動逾時"));
				step_C_P.Step  := step_C_P.Step  + 10000;
			END_IF
		END_IF
		
	3:
		step_C_P.Step  := 10;
		
		
	10: // 下壓啟動
		o_PressureC_Up := FALSE;
		o_PressureC_Dn := TRUE;
		step_C_P.Step  := step_C_P.Step  + 1;
		
	11:
		tmr103.IN := TRUE;
		tmr103.PT := T#500MS;
		IF tmr103.q THEN
			tmr103.IN := FALSE;
			step_C_P.Step  := step_C_P.Step  + 1;
		END_IF
		
	12:
		o_PressureC_Dn := FALSE;
		step_C_P.Step  := step_C_P.Step  + 1;
		
	13:
		tmr103.IN := pressureC_pressure_sensor;
		tmr103.PT := T#500MS;
		tmr113.IN := TRUE;
		tmr113.PT := T#10S;
		IF tmr103.q OR tmr113.q THEN
			tmr103.IN := FALSE;
			tmr113.IN := FALSE;
			step_C_P.Step  := step_C_P.Step  + 1;
		END_IF
		
	14:
		step_C_P.bDone := TRUE;
		step_C_P.Step  := 0;


(*	================================
				C放開
 	================================*)
	// FxA動作前檢查檢查
	100: // 檢查Group B Z軸位置，需在桁架中間 (Z pos > 500 )
		IF GbZ.pos >= 500 OR GbX.fPos < 50 OR Hmi.Jog_UnLimite THEN
			step_C_P.Step  := step_C_P.Step  + 1;
		ELSE
			step_C_P.Step  := step_C_P.Step  + 10000;
			strmem1.WRITE(name);
			strmem1.APPEND(".C_Push");
			strmem1.APPEND(":Group B 位置錯誤,再非安全位置:");
			strmem1.APPEND(STR := WCONCAT("(X:", TO_WSTRING(GbX.pos)));
			strmem1.APPEND(STR := WCONCAT(",Y:", TO_WSTRING(GbY.pos)));
			strmem1.APPEND(STR := WCONCAT(",Z:", TO_WSTRING(GbZ.pos)));
			strmem1.APPEND(")");
			pMsg.Push_Error(strmem1.READ);
		END_IF
		
	101:
		IF o_Oil_Pressure_Pump OR tmr113.Q THEN
			tmr113.IN := FALSE;
			IF o_Oil_Pressure_Pump THEN
				step_C_P.Step  := step_C_P.Step  + 1;
			ELSIF tmr113.Q THEN
				pMsg.Push_Error(WStrConcat(name, ".C_Push:下壓B等待油壓系統啟動逾時"));
				step_C_P.Step  := step_C_P.Step  + 10000;
			END_IF
		END_IF
		
	102:
		step_C_P.Step  := 110;
		
		
	110: // 放開啟動
		o_PressureC_Up := TRUE;
		o_PressureC_Dn := FALSE;
		step_C_P.Step  := step_C_P.Step  + 1;
		
	111:
		tmr103.IN := TRUE;
		tmr103.PT := T#500MS;
		IF tmr103.q THEN
			tmr103.IN := FALSE;
			step_C_P.Step  := step_C_P.Step  + 1;
		END_IF
		
	112:
		o_PressureC_Up := FALSE;
		step_C_P.Step  := step_C_P.Step  + 1;
		
	113:
		tmr103.IN := pressureC_home_sensor;
		tmr103.PT := T#500MS;
		tmr113.IN := TRUE;
		tmr113.PT := T#10S;
		IF tmr103.q OR tmr113.q THEN
			tmr103.IN := FALSE;
			tmr113.IN := FALSE;
			step_C_P.Step  := step_C_P.Step  + 1;
		END_IF
		
	114:
		step_C_P.bDone := TRUE;
		step_C_P.Step  := 0;
END_CASE

step_C_P.bBuzy := step_C_P.Step  > 0 AND step_C_P.Step  < 10000;
step_C_P.bError := step_C_P.Step  >= 10000;

IF step_C_P.bBuzy OR step_C_P.bError THEN
	step_C_P.bDone := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
