    <Action Name="Step_22_SyncEncA_2_EncB" Id="{109d3279-e534-43da-a575-775cca3103f1}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	2200:
		Encoder_FxA_ExPosEnc.MDP5001_511_Output.MDP5001_511_Set_counter_value := 
			Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value;
