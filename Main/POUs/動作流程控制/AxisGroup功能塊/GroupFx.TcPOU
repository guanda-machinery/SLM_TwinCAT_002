      <Implementation>
        <ST><![CDATA[CASE step OF
	2100:
		o_AC_Encoder_enable :=TRUE;
		o_AC_Encoder_disable :=FALSE;
		
		tmr01.IN := TRUE;
		tmr01.PT := T#2S;
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
