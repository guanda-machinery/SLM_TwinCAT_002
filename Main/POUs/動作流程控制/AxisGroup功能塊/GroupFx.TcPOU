    <Action Name="Encoder" Id="{56963486-1f8f-4658-9e5b-d9917bc3cfb6}" FolderPath="內部功能\">
      <Implementation>
        <ST><![CDATA[(* =============== 夾輪位置 =============== *)
FxA_Clamp_Pos := 
	MaCfg.FxA_Clamp_Zero_Pos - (UDINT_TO_REAL(Axis.Encoder_FxA_Clamp.MDP5001_511_Input.MDP5001_511_Counter_value) - 10000) * 0.01;

FxB_Clamp_Pos := 
	MaCfg.FxB_Clamp_Zero_Pos - ((UDINT_TO_REAL(Axis.Encoder_FxB_Clamp.MDP5001_511_Input.MDP5001_511_Counter_value) - 10000) * 0.01);

FxA_Clamp_Spd := (FxA_Clamp_Pos - FxA_Clamp_OldPos) * 100;

FxB_Clamp_Spd := (FxB_Clamp_Pos - FxB_Clamp_OldPos) * 100;

FxA_Clamp_OldPos := FxA_Clamp_Pos;

FxB_Clamp_OldPos := FxB_Clamp_Pos;

FxA_Exp_Pos := (TO_LREAL(axis.Encoder_FxA_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value) - 100000) * MaCfg.FxA_Enc_Ext_Scale;

FxB_Exp_Pos := (TO_LREAL(axis.Encoder_FxB_ExPosEnc.MDP5001_511_Input.MDP5001_511_Counter_value) - 100000) * MaCfg.FxB_Enc_Ext_Scale;

IF _UserEncA THEN
	Fx_Exp_Pos := FxA_Exp_Pos;
ELSE
	Fx_Exp_Pos := FxB_Exp_Pos;
END_IF
]]></ST>
      </Implementation>
    </Action>
