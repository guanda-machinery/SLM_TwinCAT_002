<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="GroupFx" Id="{cd7905a7-ae1f-43d2-aaa0-c41f5ea6d6c3}" SpecialFunc="None">
    <Declaration><![CDATA[// B -> A
PROGRAM GroupFx 
VAR_INPUT
	// 模塊名稱 (錯誤警報用)
	name : WSTRING := "FxA_Move";

	
END_VAR
VAR_OUTPUT
	bDone : BOOL;
	bError : BOOL;
	bBuzy : BOOL;
	
	b_AC_Clamp		: BOOL;
	b_BD_Clamp		: BOOL;
	
	// 下壓A動作流程
	step_A_P: Sub_Step;
	// 下壓B動作流程
	step_B_P: Sub_Step;
	// 下壓C動作流程
	step_C_P: Sub_Step;
	// 下壓D動作流程
	step_D_P: Sub_Step;
	// 下壓C動作流程
	step_AC_C: Sub_Step;
	// 下壓D動作流程
	step_BD_C: Sub_Step;
END_VAR
VAR
	step : INT;
	
	
{region "============= 輸入  ============="}
	// 下壓A 原點
	pressureA_home_sensor		: BOOL; 
	// 下壓A 壓力
	pressureA_pressure_sensor	: BOOL; 
	// 下壓B 原點
	pressureB_home_sensor		: BOOL; 
	// 下壓B 壓力
	pressureB_pressure_sensor	: BOOL; 
	// 下壓C 原點
	pressureC_home_sensor		: BOOL; 
	// 下壓C 壓力
	pressureC_pressure_sensor	: BOOL; 
	// 下壓D 原點
	pressureD_home_sensor		: BOOL; 
	// 下壓D 壓力
	pressureD_pressure_sensor	: BOOL;
	
	// 油壓幫浦過載
	Oli_Pump_Overload: BOOL;
	// 油壓散熱幫浦過載
	OliCooling_Pump_Overload: BOOL;
	// 油壓幫浦已開啟
	OliCooling_Pump_PowerOn: BOOL;
	
	
	// A側 夾輪內側  ( 材料原點A )
	AC_in_sensor : BOOL;
	// A側 夾輪外側  ( A側入口感應器 )
	AC_out_sensor : BOOL;
	
  	// B側 夾輪內側  ( 材料原點B )
	BD_in_sensor : BOOL;
	// B側 夾輪外側  ( B側入口感應器 )
	BD_out_sensor : BOOL;
	
// 被動夾輪A 油壓位置
	FxA_Clamp_Pos: LREAL;
	// 被動夾輪B 油壓位置
	FxB_Clamp_Pos: LREAL;

{region "============= 輸出  ============="}
	o_PressureA_Up:BOOL;
	o_PressureA_Dn:BOOL;
	
	o_PressureB_Up:BOOL;
	o_PressureB_Dn:BOOL;
	
	o_PressureC_Up:BOOL;
	o_PressureC_Dn:BOOL;
	
	o_PressureD_Up:BOOL;
	o_PressureD_Dn:BOOL;
	
	o_AC_Clamp_Close	: BOOL;
	o_AC_Clamp_Open	: BOOL;
	o_BD_Clamp_Close	: BOOL;
	o_BD_Clamp_Open	: BOOL;

	o_Oil_Pressure_Pump	:BOOL;
		
	o_AC_Encoder_enable: BOOL;
	o_AC_Encoder_disable: BOOL;
	o_BD_Encoder_enable: BOOL;
	o_BD_Encoder_disable: BOOL;
	
{endregion}
		 
 	tmr01: TON;
	tmr02: TON;
	
	tmr101: TON;
	tmr102: TON;
	tmr103: TON;
	tmr104: TON;
	tmr105: TON;
	tmr106: TON;
	
	tmr111: TON;
	tmr112: TON;
	tmr113: TON;
	tmr114: TON;
	tmr115: TON;
	tmr116: TON;
	
	tmr_wdt : TON;
	
	tmr_Oil_Pressure_Pump : TOF;


	
	// 上次AC夾輪位置
	FxA_Clamp_OldPos: LREAL;
	// 上次BD夾輪位置
	FxB_Clamp_OldPos: LREAL;
	
	// AC移動位置
	AC_moveDis : LREAL := 0;
	
	// BD移動位置
	BD_moveDis : LREAL := 0;
	
	
	
	AC_Home_sensor: BOOL;
	BD_Home_sensor: BOOL;
	
	AC_Outsite_sensor: BOOL;
	BD_Outsite_sensor: BOOL;
	
	b_AC_HOME		: BOOL;
	b_BD_HOME		: BOOL;
	
	
	
	AC_StartPos: LREAL;
	BD_StartPos: LREAL;
	
	

	
	boot : BOOL := TRUE;
	FxA_Clamp_Spd: LREAL;
	FxB_Clamp_Spd: LREAL;
	Estop_Trig: R_TRIG;
	
	// 使用編碼器切換
	_UserEncA: BOOL;
	
	_TargetPos	: LREAL;
	
	strmem1 : WStrMem;
	
	AC_Encoder_Active: BOOL;
	BD_Encoder_Active: BOOL;
END_VAR

]]></Declaration>
    <Implementation>
      <ST><![CDATA[input();
Encoder();




bBuzy := step > 0 AND step < 10000;
bError :=  step >= 10000;
IF bBuzy OR bError THEN
	bDone := FALSE;
END_IF

IF (EStop OR SystemError) THEN
	IF bBuzy THEN
		step := step  + 10000;
	END_IF
	
	IF step_A_P.bBuzy THEN
		step_A_P.step := step_A_P.step  + 10000;
	END_IF
	
	IF step_B_P.bBuzy THEN
		step_B_P.step := step_B_P.step  + 10000;
	END_IF
	
	IF step_C_P.bBuzy THEN
		step_C_P.step := step_C_P.step  + 10000;
	END_IF
	
	IF step_D_P.bBuzy THEN
		step_D_P.step := step_D_P.step  + 10000;
	END_IF
	
	IF step_AC_C.bBuzy THEN
		step_AC_C.step := step_AC_C.step  + 10000;
	END_IF
	
	IF step_BD_C.bBuzy THEN
		step_BD_C.step := step_BD_C.step  + 10000;
	END_IF
END_IF

IF Fx.bBuzy THEN
	IF o_AC_Clamp_Close AND NOT IO.i509 THEN
		o_AC_Clamp_Close := FALSE;
		pMsg.Push_Error("GroupFX:工件已脫離AC夾輪感應器");
	ELSIF o_BD_Clamp_Close AND NOT IO.i510 THEN
		o_BD_Clamp_Close := FALSE;
		pMsg.Push_Error("GroupFX:工件已脫離BD夾輪感應器");
	END_IF
END_IF


IF (EStop OR SystemError) THEN
	bDone := FALSE;
	o_PressureA_Up		:=FALSE;
	o_PressureA_Dn		:=FALSE;
	o_PressureB_Up		:=FALSE;
	o_PressureB_Dn		:=FALSE;
	o_PressureC_Up		:=FALSE;
	o_PressureC_Dn		:=FALSE;
	o_PressureD_Up		:=FALSE;
	o_PressureD_Dn		:=FALSE;
	
	o_AC_Clamp_Close	:=FALSE;
	o_AC_Clamp_Open		:=FALSE;
	o_BD_Clamp_Close	:=FALSE;
	o_BD_Clamp_Open		:=FALSE;
	
	o_Oil_Pressure_Pump :=FALSE;
END_IF

Pump_Close();



Step_00_Start_Pump();
Step_BD_00_Clamp();
Step_BD_01_UnClamp();
Step_BD_02_Stop();
Step_BD_03_Home();

Step_AC_00_Clamp();
Step_AC_01_UnClamp();
Step_AC_02_Stop();
Step_AC_03_Home();

Step_10_MoveTo();
Step_20_Find_Home();
Step_21_Set_A_Enc();

Step_A_Push_UnPush();
Step_B_Push_UnPush();
Step_C_Push_UnPush();
Step_D_Push_UnPush();

timer();

output();

]]></ST>
    </Implementation>
    <Folder Name="內部功能" Id="{460ccaff-f0de-4f4a-ae51-469198ad2c0c}" />
