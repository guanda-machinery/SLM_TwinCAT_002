<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="Button" Id="{7491b716-6991-4370-adff-ecba3ca04987}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Button
VAR
	// 系統開機指示燈
	_SystemPowerButton_Light : USINT := 1;
	// 程式開始指示燈
	_StartButton_Light : USINT;
	// 程式暫停指示燈
	_StopButton_Light : USINT;
	// 程式暫停指示燈
	_ResetButton_Light : USINT;
	// 原點指示燈
	_HomeButton_Light : USINT;
	// 手動模式指示燈
	_JogButtonLight : USINT; 
	// 單節模式指示燈
	_StepModeButtonLight : USINT; 
	// 自動模式指示燈
	_AutoModeButtonLight : USINT; 
	
	pc_Shutdown: NT_Shutdown;
	pc_AbortShutdown: NT_AbortShutdown;
	pc_Shutdown2: NT_Shutdown;
	pc_AbortShutdown2: NT_AbortShutdown;
	flash_clk: BOOL;
	jogbtn_trig: R_TRIG;
	StepButton: R_TRIG;
	StartButton_LDP: F_TRIG;
	SystemPowerButton_Ldp: R_TRIG;
END_VAR

VAR_OUTPUT
	// 系統電源
	SystemPowerButton : BOOL;
	// 程式開始
	StartButton : BOOL;
	// 程式暫停
	StopButton : BOOL;
	// 重置
	ResetButton : BOOL;
	// 原點
	HomeButton : BOOL;
	// 手動模式
	JogButton : BOOL; 
	// 單節模式
	StepModeButton : BOOL; 
	// 自動模式
	AutoModeButton : BOOL; 
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SystemPowerButton	:= IO.i102;
StartButton			:= IO.i104;
StopButton			:= IO.i103;
ResetButton			:= IO.i105;
HomeButton			:= IO.i106;
JogButton			:= IO.i108;
StepModeButton		:= IO.i109;
AutoModeButton		:= IO.i110;

flash_clk := LightTower.clk;


CASE _SystemPowerButton_Light OF
	0:
		io.q101 := FALSE;
	
	1:
		io.q101 := TRUE;
		
	2:
		io.q101 := flash_clk;
END_CASE

CASE _StopButton_Light OF
	0:
		io.q102 := FALSE;
	
	1:
		io.q102 := TRUE;
		
	2:
		io.q102 := flash_clk;
END_CASE

CASE _StartButton_Light OF
	0:
		io.q103 := FALSE;
	
	1:
		io.q103 := _StopButton_Light = 0;
		
	2:
		io.q103 := _StopButton_Light = 0 and flash_clk;
END_CASE


CASE _ResetButton_Light OF
	0:
		io.q104 := FALSE;
	
	1:
		io.q104 := TRUE;
		
	2:
		io.q104 := flash_clk;
END_CASE


CASE _HomeButton_Light OF
	0:
		io.q105 := FALSE;
	
	1:
		io.q105 := TRUE;
		
	2:
		io.q105 := flash_clk;
END_CASE


CASE _JogButtonLight OF
	0:
		io.q107 := FALSE;
	
	1:
		io.q107 := TRUE;
		
	2:
		io.q107 := flash_clk;
END_CASE


CASE _StepModeButtonLight OF
	0:
		io.q108 := FALSE;
	
	1:
		io.q108 := TRUE;
		
	2:
		io.q108 := flash_clk;
END_CASE

CASE _AutoModeButtonLight OF
	0:
		io.q109 := FALSE;
	
	1:
		io.q109 := TRUE;
		
	2:
		io.q109 := flash_clk;
END_CASE

PowerButtonAction();
StartButtonAction();
ResetButtonAction();


HomeButtonAction();
JogButtonAction();]]></ST>
    </Implementation>
    <Folder Name="動作" Id="{dad45fd5-fd54-4946-8957-9a803a79cd5a}" />
    <Action Name="AutoModeButtonAction" Id="{8a4bf85a-24fd-4113-bff5-5b138a0cdeca}" FolderPath="動作\">
      <Implementation>
        <ST><![CDATA[IF AutoMain.step = 0 OR AutoMain.step > 2000 THEN
	Button.AutoModeButtonLight := 0;
END_IF]]></ST>
      </Implementation>
    </Action>
