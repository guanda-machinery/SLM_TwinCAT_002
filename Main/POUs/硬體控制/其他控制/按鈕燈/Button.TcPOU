    <Action Name="ResetButtonAction" Id="{16a051a1-8ea8-4922-a3e2-111f54544ee2}" FolderPath="動作\">
      <Implementation>
        <ST><![CDATA[IF SystemError THEN
	ResetButton_Light := 2;
ELSE
	ResetButton_Light := 0;
END_IF

IF ResetButton AND SystemError THEN
	SystemError := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Property Name="StartButton_Light" Id="{a5cef510-23b9-4493-8fa1-4330a59fed93}">
      <Declaration><![CDATA[PROPERTY StartButton_Light : usint]]></Declaration>
      <Get Name="Get" Id="{6949e6de-cc0a-4ffc-92e2-f7af2d45d8bc}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[StartButton_Light := _StartButton_Light;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{689807a6-cd13-4ec7-a3bc-956a5d41468c}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[_StartButton_Light := StartButton_Light;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Action Name="StartButtonAction" Id="{7a2fd946-892f-419e-921b-468286655992}" FolderPath="動作\">
      <Implementation>
        <ST><![CDATA[IF AutoMain.step = 0 OR AutoMain.step > 2000 THEN
	Button.StartButton_Light := 0;
END_IF

StartButton_LDP(CLK:=StartButton);
IF StartButton_LDP.q AND LEN(ProjectData.WorkOrder_Now.steel_id) > 0 AND 
	_StartButton_Light = 0 AND NOT AutoMain.bBuzy THEN
	AutoMain.ReStart();
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="StepButtonAction" Id="{09bcff2b-934c-4f47-ab3a-475aeba40679}" FolderPath="動作\">
      <Implementation>
        <ST><![CDATA[IF NOT Hmi_Web.Auto_Step_mode_Enable THEN
	Button.StartButton_Light := 0;
ELSE
	IF Hmi_Web.Auto_Step_active THEN
		Button.StartButton_Light := 1;
	ELSE
		Button.StartButton_Light := 2;
	END_IF
END_IF

// StepButton(CLK := StepButton);
IF jogbtn_trig.Q THEN
	IF AutoMain.step > 0 AND AutoMain.step < 2000 THEN
		AutoMain.JogMode();
	ELSIF AutoMain.step = 8001 THEN
		AutoMain.JogMode_Exit();
	END_IF
END_IF]]></ST>
      </Implementation>
    </Action>
