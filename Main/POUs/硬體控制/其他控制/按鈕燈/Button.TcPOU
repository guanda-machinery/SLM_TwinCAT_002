      </Set>
    </Property>
    <Property Name="HomeButton_Light" Id="{af49bf77-9290-4b88-93f9-c95501b8d72b}">
      <Declaration><![CDATA[PROPERTY HomeButton_Light : USINT]]></Declaration>
      <Get Name="Get" Id="{0482e8ab-899d-42aa-b8f4-6328b58f9386}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[HomeButton_Light := _HomeButton_Light;]]></ST>
