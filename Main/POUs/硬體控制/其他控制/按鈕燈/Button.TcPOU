    </Property>
    <Action Name="HomeButtonAction" Id="{ce71c10c-f4c0-4bb3-bd28-5da37927f909}" FolderPath="動作\">
      <Implementation>
        <ST><![CDATA[IF HomeButton THEN
	IF NOT AutoMain.bBuzy THEN
		AutoMain.Homming();
	END_IF
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="JogButtonAction" Id="{3d9d4597-3647-4763-8bb3-37904525932c}" FolderPath="動作\">
      <Implementation>
        <ST><![CDATA[IF AutoMain.step >= 8000 AND AutoMain.step < 8100 THEN
	Button.JogButtonLight := 1;
ELSIF AutoMain.step >= 8100 AND AutoMain.step < 9800 THEN
	Button.JogButtonLight := 2;
ELSE
	Button.JogButtonLight := 0;
END_IF


jogbtn_trig(CLK := JogButton);
IF jogbtn_trig.Q THEN
	IF AutoMain.step = 0 THEN
		AutoMain.JogMode();
	ELSIF AutoMain.step = 8001 THEN
		AutoMain.JogMode_Exit();
	END_IF
END_IF]]></ST>
      </Implementation>
    </Action>
    <Property Name="JogButtonLight" Id="{4ba56b42-4226-4d10-81f5-9b757171d7b4}">
      <Declaration><![CDATA[PROPERTY JogButtonLight : USINT]]></Declaration>
      <Get Name="Get" Id="{e3d90845-e75d-4cd9-9d6f-5d33bdec3bf3}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[JogButtonLight := _JogButtonLight;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{500bac67-15b4-4a85-89ae-cf4f024e4e2c}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[_JogButtonLight := JogButtonLight;
]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Action Name="PowerButtonAction" Id="{2700c65c-a1a7-4c97-9129-ffea9ca89110}" FolderPath="動作\">
      <Implementation>
        <ST><![CDATA[SystemPowerButton_Ldp(CLK:=SystemPowerButton);


IF SystemPowerButton_Ldp.Q THEN
	IF SystemPowerButton_Light <> 2 THEN
		pc_Shutdown.START := TRUE;
		pc_Shutdown2.START := TRUE;
		SystemPowerButton_Light := 2;
	ELSIF SystemPowerButton_Light = 2 THEN
		pc_AbortShutdown.START := TRUE;
		pc_AbortShutdown2.START := TRUE;
		SystemPowerButton_Light := 1;
	END_IF
END_IF

IF pc_Shutdown.BUSY THEN
	pc_Shutdown.START := FALSE;
END_IF

IF pc_Shutdown2.BUSY THEN
	pc_Shutdown2.START := FALSE;
END_IF

IF pc_AbortShutdown.BUSY THEN
	pc_AbortShutdown.START := FALSE;
END_IF

IF pc_AbortShutdown2.BUSY  THEN
	pc_AbortShutdown2.START := FALSE;
END_IF

pc_Shutdown(
	NETID:= '169.254.139.155.1.1', 
	DELAY:= 10
);

pc_Shutdown2(
	NETID:= '0.0.0.0.1.1', 
	DELAY:= 15
);

pc_AbortShutdown(
	NETID:= '169.254.139.155.1.1'
);

pc_AbortShutdown2(
	NETID:= '0.0.0.0.1.1'
);]]></ST>
      </Implementation>
    </Action>
