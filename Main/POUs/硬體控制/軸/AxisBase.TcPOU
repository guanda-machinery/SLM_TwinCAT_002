    <Property Name="State" Id="{6f269ead-535f-4ad6-918b-e53ead305303}">
      <Declaration><![CDATA[PROPERTY State : Sub_Step
]]></Declaration>
      <Get Name="Get" Id="{c16a6fcf-fc7e-466a-be0b-6e1921289e75}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[State.bBuzy := bBuzy;
State.bError := bError;
State.bDone := bDone;
State.Step := step;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Action Name="Step0_Start" Id="{bc1878ef-2e1d-44d1-812d-da129561a225}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*============================
				啟動馬達
	  ============================*)
CASE step OF
	
	1://開始移動流程
		// 設定狀態
		bDone := FALSE;
		tmrWdt.IN := FALSE;
//		SetDyn(bJogMode);
		Axis1Reset.Execute :=FALSE;
		
		IF NOT bDone THEN
			step := 10;
		END_IF
		
	10:
		IF axis1.Status.Error THEN
			step := step + 1;
		ELSE
			step := 20;
		END_IF
		
	11:
		Axis1Reset.Execute :=TRUE;
		step := step + 1;
		
	12:
		IF NOT axis1.Status.Error AND Axis1Reset.Done THEN
			Axis1Reset.Execute :=FALSE;
			step := 20;
		ELSIF Axis1Reset.Error THEN
			pMsg.Push_Error(
					ErrorCodeConver.Str(str0:= scAxisName, str1:= ": 馬達無法重置", ErrorCode:= Axis1Reset.ErrorID)
			);
			Axis1Reset.Execute :=FALSE;
			step:=step + 10000;
		END_IF
		
	20: // 檢查馬達1是否已啟動
		IF NOT Axis1Power.Status  THEN
			step := step + 1;
		ELSE
			step := 60;
		END_IF
		
	21:// 啟動馬達1
		Axis1Power.Enable := TRUE;
		tmrWdt.IN := TRUE;
		step := step + 1;
		
	22:// 等待馬達啟動完成
		IF Axis1Power.Status THEN
			step := step + 1;
			tmrWdt.IN := FALSE;
			
		ELSIF tmrWdt.Q OR Axis1Power.Error THEN
			pMsg.Push_Error(
					ErrorCodeConver.Str(str0:= scAxisName, str1:= ": 啟動失敗", ErrorCode:= Axis1Power.ErrorID)
			);
			tmrWdt.IN := FALSE;
			step:=step + 10000;
		END_IF
		
	23:// 馬達啟動後延遲
		tmr1.in:=TRUE;
		IF tmr1.Q THEN
			tmr1.IN:=FALSE;
			step:=60;
		END_IF
		
	
			

	60: 
		fb_BacklashCompensation.Enable := FALSE;
		step := step + 1;
		
		
	61:	
		// 背隙值 (mm)
		fb_BacklashCompensation.Backlash := 0.05;
		// 正向補償 (往正方向移動時補償，預設是反方向移動時補償)
		fb_BacklashCompensation.CompensationInPositiveDirection := FALSE;
		// 背隙補償的速度 (mm/s)
		fb_BacklashCompensation.Ramp := 1;
		// 解除時機
		fb_BacklashCompensation.DisableMode  := E_DisableMode.DisableModeReset;
		// 功能啟動
		fb_BacklashCompensation.Enable := TRUE;
		step := step + 1;
		
	62:
		IF fb_BacklashCompensation.Enabled THEN
			step := step + 1;
		ELSIF fb_BacklashCompensation.Error THEN
			fb_BacklashCompensation.Enable := FALSE;
			step := step + 1;
		END_IF
		
	63:
		step := 80;
		
	80: //模式選擇
		CASE Mode OF
			ActionMode.AbsMove:
				step := 100;
				
			ActionMode.RelMove:
				step := 200;
				
			ActionMode.Home:
				step := 300;
				
			ActionMode.Find:
				step := 400;
				
			ActionMode.DoNothing:
				step := step + 1;
		END_CASE
		
	81:
		bdone := TRUE;
		step := 0;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step1_1_AbsMove" Id="{42d640a5-e8aa-48ec-8c01-1dc9650dec20}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*========================================
					開始移動
	=========================================*)	
CASE step OF
	100:
		fb_AbsMove.Execute := FALSE;
		Axis1Halt.Execute := FALSE;
		Axis1Stop.Execute := FALSE;
		step := step + 1;
		
	101:
		IF Velocity = 0 THEN
			pMsg.Push_Error( WStrConcat(str0:= scAxisName, str1:= ": Abs設定速度為0")
			);
		ELSE
			step := step + 1;
		END_IF
		
	102:
		IF fPos > TargetPos - 0.1 AND fPos < TargetPos + 0.1 THEN 
			step:= 190;
		ELSE
			step := step + 1;
		END_IF
		
	103:
		IF Axis1.Status.HasJob THEN
			Axis1Halt.Deceleration := 0;
			Axis1Halt.Execute := TRUE;
			step := step + 1;
		ELSE
			step:= 109;
		END_IF
		
	104:
		IF Axis1Halt.Busy OR Axis1Halt.Done OR Axis1Halt.Error THEN
			step:=step + 1;
		END_IF
		
	105:
		IF Axis1Halt.Done THEN
			Axis1Halt.Execute := FALSE;
			step:=step + 1;
		ELSIF Axis1Halt.Error THEN
			Axis1Halt.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	106:
		step:= 109;
		
	109:
		step:= 110;
		

	110: // 設定移動位置
		fb_AbsMove.Position := TargetPos;
		fb_AbsMove.Velocity:= Velocity;
		fb_AbsMove.BufferMode:= MC_Aborting;
		step:=step + 1;
		
	111:
		fb_AbsMove.Execute := TRUE;
		step:=step + 1;
		
	112:
		IF fb_AbsMove.Busy OR fb_AbsMove.Done OR fb_AbsMove.Error THEN
			step:=step + 1;
		END_IF
		
	113:
		IF fb_AbsMove.Done OR (TargetPos <= 0 AND pos < 2 AND Origin) THEN
			fb_AbsMove.Execute := FALSE;
			step:=step + 1;
		ELSIF fb_AbsMove.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str(str0:= scAxisName, str1:= ": Abs移動失敗", ErrorCode:= fb_AbsMove.ErrorID)
			);
			fb_AbsMove.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	114:
		step := 190;
		
	190:
		bDone := TRUE;
		step:=890;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step1_2_RelMove" Id="{ead45a52-fc74-418f-a27c-54623d26ad80}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*========================================
					開始移動
	=========================================*)	
CASE step OF
	200:
		fb_RelMove.Execute := FALSE;
		Axis1Halt.Execute := FALSE;
		Axis1Stop.Execute := FALSE;
		step := step + 1;
		
	201:
		IF Velocity = 0 THEN
			pMsg.Push_Error(
				WStrConcat(scAxisName, ":Rel設定速度為0")
			);
		ELSE
			step := step + 1;
		END_IF
		
	202:
		IF TargetPos = 0 THEN 
			step:= 280;
		ELSE
			step := step + 1;
		END_IF
		
	203:
		IF Axis1.Status.HasJob THEN
			Axis1Halt.Deceleration := 0;
			Axis1Halt.Execute := TRUE;
			step := step + 1;
		ELSE
			step:= 209;
		END_IF
		
	204:
		IF Axis1Halt.Busy OR Axis1Halt.Done OR Axis1Halt.Error THEN
			step:=step + 1;
		END_IF
		
	205:
		IF Axis1Halt.Done THEN
			Axis1Halt.Execute := FALSE;
			step:=step + 1;
		ELSIF Axis1Halt.Error THEN
			Axis1Halt.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	206:
		step:= 209;
		
	209:
		step:= 210;
		

	210: // 設定移動位置
		fb_RelMove.Distance := TargetPos;
		fb_RelMove.Velocity:= Velocity;
		fb_RelMove.BufferMode:= MC_Aborting;
		step:=step + 1;
		
	211:
		fb_RelMove.Execute := TRUE;
		step:=step + 1;
		
	212:
		IF fb_RelMove.Busy OR fb_RelMove.Done OR fb_RelMove.Error THEN
			step:=step + 1;
		END_IF
		
	213:
		IF fb_RelMove.Done THEN
			fb_RelMove.Execute := FALSE;
			step:=step + 1;
		ELSIF fb_RelMove.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str(str0:= scAxisName, str1:= ":Rel移動失敗", ErrorCode:= fb_RelMove.ErrorID)
			);
			fb_RelMove.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	214:
		step:=290;
		
	280:
		tmr1.PT := T#500MS;
		tmr1.IN := TRUE;
		IF tmr1.Q THEN
			tmr1.IN := FALSE;
			step:=step + 1;
		END_IF
		
	281:
		step := 290;
		
	290:
		bDone := TRUE;
		step:=890;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step1_3_Home" Id="{b2035636-cb34-485b-be84-8ff968707bdb}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[(*========================================
				歸零
=========================================*)	
CASE step OF
	300:
		fb_Axis1_NcIoOutput.Execute := FALSE;
		fb_Home.Execute := FALSE;
		step := step + 1;
		
	301: // 關閉負軟體極限
		fb_WriteBoolParameter.ParameterNumber := MC_AxisParameter.EnableLimitNeg;
		fb_WriteBoolParameter.Value := FALSE;
		fb_WriteBoolParameter.Execute := TRUE;
		step := step + 1;
		
	302:
		IF fb_WriteBoolParameter.Done OR fb_WriteBoolParameter.Error THEN
			fb_WriteBoolParameter.Execute := FALSE;
			IF fb_WriteBoolParameter.Error THEN
				pMsg.Push_Alarm_NoPause(
					ErrorCodeConver.Str(str0:= scAxisName, str1:= ": 寫入 使用負方向極限 參數發生錯誤", str2:= ws_step, ErrorCode := fb_WriteBoolParameter.ErrorID)
					);
			END_IF
			step := step + 1;
		END_IF
	
	303:
		Origin_pos := Pos;
		step:= 340;
		
// 	310: // 尋找負極限訊號
// 		fb_RelMove.Distance := -9999;
// 		fb_RelMove.Velocity:= 1;
// 		fb_RelMove.BufferMode:= MC_Aborting;
// 		fb_RelMove.Execute := TRUE;
// 		step:=step + 1;
// 		
// 	311:
// 		IF fb_RelMove.Busy OR fb_RelMove.Error THEN
// 			fb_RelMove.Execute := FALSE;
// 			step:=step + 1;
// 		END_IF
// 		
// 	312:
// 		IF NOT inLimiter THEN
// 			Axis1Halt.Execute := TRUE;
// 			step:=step + 1;
// 		ELSIF fb_RelMove.Done THEN
// 			pmsg.Push_Error(ErrorCodeConver.Str2(scAxisName, ":無法找到負極限訊號", 0));
