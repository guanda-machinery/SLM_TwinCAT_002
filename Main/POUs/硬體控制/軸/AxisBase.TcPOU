// 		
// 	326:
// 		step := 330;
// 		
// 	330:
// 		fb_RelMove.Distance := 2;
// 		fb_RelMove.Velocity:= 2;
// 		fb_RelMove.BufferMode:= MC_Aborting;
// 		fb_RelMove.Execute := TRUE;
// 		step:=step + 1;
// 		
// 	331:
// 		IF fb_RelMove.Busy OR fb_RelMove.Error THEN
// 			fb_RelMove.Execute := FALSE;
// 			step:=step + 1;
// 		END_IF
// 		
// 	332:
// 		IF fb_RelMove.Done THEN
// 			step:=step + 1;
// 		ELSIF fb_RelMove.Error THEN
// 			pmsg.Push_Error(ErrorCodeConver.Str2(scAxisName, ":歸零移動時發生錯誤", fb_RelMove.ErrorID));
// 			step:=step + 10000;
// 		END_IF
// 		
// 	333:
// 		tmr200.in :=TRUE;
// 		IF tmr200.q THEN
// 			tmr200.in :=FALSE;
// 			step := step + 1;
// 		END_IF
// 		
// 	334:
// 		step := 350;
		
	340:
		fb_Axis1_NcIoOutput.BitSelectMask := 128;
		fb_Axis1_NcIoOutput.BitValues := 128;
		fb_Axis1_NcIoOutput.Execute := TRUE;
		IF fb_Axis1_NcIoOutput.Done THEN
			step := step + 1;
			fb_Axis1_NcIoOutput.Execute := FALSE;
		ELSIF fb_Axis1_NcIoOutput.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str(str0:= scAxisName, str1:= ":Home寫入驅動器失敗", str2:= ws_step, ErrorCode := fb_Axis1_NcIoOutput.ErrorID)
			);
			fb_Axis1_NcIoOutput.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	341:
		fb_Axis1_NcIoOutput.BitSelectMask := 128;
		fb_Axis1_NcIoOutput.BitValues := 0;
		fb_Axis1_NcIoOutput.Execute := TRUE;
		IF fb_Axis1_NcIoOutput.Done THEN
			step := step + 1;
			fb_Axis1_NcIoOutput.Execute := FALSE;
		ELSIF fb_Axis1_NcIoOutput.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str(str0:= scAxisName, str1:= ":Home寫入驅動器失敗", str2:= ws_step, ErrorCode := fb_Axis1_NcIoOutput.ErrorID)
			);
			fb_Axis1_NcIoOutput.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	342:
		tmr200.in :=TRUE;
		IF tmr200.q THEN
			tmr200.in :=FALSE;
			step := step + 1;
		END_IF
		
	343:
		Axis1Power.Enable := FALSE;
		tmrWdt.IN := TRUE;
		IF NOT Axis1Power.Status THEN
			step := step + 1;
			tmrWdt.IN := FALSE;
			
		ELSIF tmrWdt.Q OR Axis1Power.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str(str0:= scAxisName, str1:= ":關閉失敗", str2:= ws_step, ErrorCode := Axis1Power.ErrorID)
			);
			step:=step + 10000;
		END_IF	
		
	344:
		tmr200.in :=TRUE;
		IF tmr200.q THEN
			tmr200.in :=FALSE;
			step := step + 1;
		END_IF
		
	345:
		step:= 350;
		
	
			
		
	350:// 設定原點
		fb_Home.Execute := TRUE;
		step:=step + 1;
		
	351:
		IF fb_Home.Done THEN
			fb_Home.Execute := FALSE;
			bHome := TRUE;
			step:=step + 1;
		ELSIF fb_Home.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str(str0:= scAxisName, str1:= ":位置清除失敗", str2:= ws_step, ErrorCode := fb_Home.ErrorID)
			);
			fb_Home.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	352:
		Axis1Power.Enable := TRUE;
		tmrWdt.IN := TRUE;
		IF Axis1Power.Status THEN
			step := step + 1;
			tmrWdt.IN := FALSE;
		ELSIF tmrWdt.Q OR Axis1Power.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str(str0:= scAxisName, str1:= ":啟動失敗", str2:= ws_step, ErrorCode := Axis1Power.ErrorID)
			);
			step:=step + 10000;
		END_IF	
			
	353:
		tmr200.in :=TRUE;
		IF tmr200.q THEN
			tmr200.in :=FALSE;
			step:=step + 1;
		END_IF
		
	354:
		step:= 360;
		
	360:// 設定移動位置
		step:= 390;
	
			
	390://延遲
		tmr200.in :=TRUE;
		IF tmr200.q THEN
			tmr200.in :=FALSE;
			bDone := TRUE;
			step:=890;
		END_IF
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step8_End" Id="{b5accc1e-d2b4-424a-9cd6-b5985785ae31}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*======================================
					關閉馬達
	  ======================================*)
CASE step OF
	800:
		Axis1Reset.Execute	:= FALSE;
		Axis1Stop.Execute	:= FALSE;
		Axis1Halt.Execute	:= FALSE;
		fb_AbsMove.Execute	:=FALSE;
		fb_RelMove.Execute	:=FALSE;
		fb_Home.Execute		:=FALSE;
		step := step + 1;
			
	// ============== 停止 + 關閉==============
	801:
		IF Axis1.Status.Moving THEN
			step := step + 1;
		ELSE
			step := 810;
		END_IF
	
	802:
		Axis1Stop.Execute := TRUE;
		step := step + 1;
		
	803:
		Axis1Stop.Execute := TRUE;
		step := step + 1;
		
	804:
		IF Axis1Stop.Done OR Axis1Stop.Error THEN
			Axis1Stop.Execute := FALSE;
			step := step + 1;
		END_IF
		
	805:
		tmr800.PT := T#1S;
		tmr800.in:=TRUE;
		IF tmr800.Q THEN
			tmr800.IN:=FALSE;
			step := step + 1;
		END_IF
		
	806:
		step:=810;
		
	810:
		Axis1Power.Enable := FALSE;
		IF Axis1.Status.Disabled THEN
			step := step + 1;
		END_IF
		
			
	811:// 馬達關閉後延遲
		tmr800.in:=TRUE;
		IF tmr800.Q THEN
			tmr800.IN:=FALSE;
			step := step + 1;
		END_IF
		
	812:
		Mode := ActionMode.DoNothing;
		step:=890;
		
		
// ==============停止==============
	850:
		Axis1Stop.Deceleration := Dec;
		Axis1Stop.Execute := FALSE;
		step := step + 1;
		
	851:
		Axis1Stop.Execute := TRUE;
		step := step + 1;
		
	852:
		IF Axis1Stop.Done OR Axis1Stop.Error THEN
			Axis1Stop.Execute := FALSE;
			step := step + 1;
		END_IF
		
	853:
		tmr800.PT := T#1S;
		tmr800.in:=TRUE;
		IF tmr800.Q THEN
			tmr800.IN:=FALSE;
			step := step + 1;
		END_IF
		
	854:
		step:=890;
		
		
			
	890:// 結束程式
		Mode := ActionMode.DoNothing;
		step:=0;

END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step9_SetLimit" Id="{8506be86-679a-460a-81a3-b340471ebc45}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[CASE stepA OF
	1:
		fb_WriteParameter.Execute := FALSE;
		fb_WriteBoolParameter.Execute := FALSE;
		stepA := stepA + 1;
		
	2:
		stepA := 10;
	
(* ================ 設定正方向極限 ================ *)		
		
	10: // 設定是否使用 正方向極限 數值為0設為false
		fb_WriteBoolParameter.ParameterNumber := MC_AxisParameter.EnableLimitPos;
		fb_WriteBoolParameter.Value := PosC.GaX_P_Limite <> 0;
		fb_WriteBoolParameter.Execute := TRUE;
		stepA := stepA + 1;
		
		
	11:
		IF fb_WriteBoolParameter.Done OR fb_WriteBoolParameter.Error THEN
			fb_WriteBoolParameter.Execute := FALSE;
			IF fb_WriteBoolParameter.Error THEN
				pMsg.Push_Alarm_NoPause(
					ErrorCodeConver.Str(str0:= scAxisName, str1:= ": 寫入 使用正方向極限 參數發生錯誤", ErrorCode:= fb_WriteBoolParameter.ErrorID)
					);
			END_IF
			stepA := stepA + 1;
		END_IF
		
	12:
		IF PosC.GaX_P_Limite <> 0 THEN
			stepA := 20;
		ELSE
			stepA := 30;
		END_IF
			
		
	20: // 設定正方向極限
		fb_WriteParameter.ParameterNumber := MC_AxisParameter.SWLimitPos;
		fb_WriteParameter.Value := REAL_TO_LREAL(PosC.GaX_P_Limite);
		fb_WriteParameter.Execute := TRUE;
		stepA := stepA + 1;
		
		
	21:
		IF fb_WriteParameter.Done OR fb_WriteParameter.Error THEN
			fb_WriteParameter.Execute := FALSE;
			IF fb_WriteParameter.Error THEN
				pMsg.Push_Alarm_NoPause(
					ErrorCodeConver.Str(str0:= scAxisName, str1:= ": 寫入 正方向極限位置 參數發生錯誤", ErrorCode:= fb_WriteParameter.ErrorID)
					);
			END_IF
			stepA := stepA + 1;
		END_IF
		
	22:
		stepA := 30;
		
(* ================ 設定負方向極限 ================ *)		
		
	30: // 設定是否使用 負方向極限 數值為0設為false
		fb_WriteBoolParameter.ParameterNumber := MC_AxisParameter.EnableLimitNeg;
		fb_WriteBoolParameter.Value := PosC.GaX_N_Limite <> 0;
		fb_WriteBoolParameter.Execute := TRUE;
		stepA := stepA + 1;
		
		
	31:
		IF fb_WriteBoolParameter.Done OR fb_WriteBoolParameter.Error THEN
			fb_WriteBoolParameter.Execute := FALSE;
			IF fb_WriteBoolParameter.Error THEN
				pMsg.Push_Alarm_NoPause(
					ErrorCodeConver.Str(str0:= scAxisName, str1:= ": 寫入 使用負方向極限 參數發生錯誤", ErrorCode:= fb_WriteBoolParameter.ErrorID)
					);
			END_IF
			stepA := stepA + 1;
		END_IF
		
	32:
		IF PosC.GaX_N_Limite <> 0 THEN
			stepA := 40;
		ELSE
			stepA := 50;
		END_IF
			
		
	40: // 設定負方向極限
		fb_WriteParameter.ParameterNumber := MC_AxisParameter.SWLimitNeg;
		fb_WriteParameter.Value := REAL_TO_LREAL(PosC.GaX_N_Limite);
		fb_WriteParameter.Execute := TRUE;
		stepA := stepA + 1;
		
		
	41:
		IF fb_WriteParameter.Done OR fb_WriteParameter.Error THEN
			fb_WriteParameter.Execute := FALSE;
			IF fb_WriteParameter.Error THEN
				pMsg.Push_Alarm_NoPause(
					ErrorCodeConver.Str(str0:= scAxisName, str1:= ": 寫入 負方向極限位置 參數發生錯誤", ErrorCode:= fb_WriteParameter.ErrorID)
					);
			END_IF
			stepA := stepA + 1;
		END_IF
		
	42:
		stepA := 50;
		
(* ================ 設定結束 ================ *)	
	50:
		stepA := 0;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Method Name="Stop" Id="{fb57ff47-9fde-4f82-b195-1f8910f36a08}">
      <Declaration><![CDATA[METHOD Stop : BOOL
VAR_INPUT
	Dec : LREAL := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*===============================
			關閉馬達
  ===============================*)
step:=850;]]></ST>
      </Implementation>
    </Method>
    <Action Name="timer" Id="{45651d54-971b-44ff-80fe-eafc3ced79d7}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[tmr1();
tmr2();
tmr100(PT:=T#50MS);
tmr200();
tmr201();
tmr800();
tmrWdt();]]></ST>
      </Implementation>
    </Action>
  </POU>
</TcPlcObject>