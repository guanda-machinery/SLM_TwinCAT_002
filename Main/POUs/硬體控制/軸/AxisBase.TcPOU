<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="AxisBase" Id="{4a28df5e-6b04-4f5b-94ef-e0241a482fc8}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK AxisBase IMPLEMENTS I_Axis
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	// 模式
	Mode: ActionMode;
	// 步進
	step: INT;
	stepA: INT;
	// 發生錯誤步
	ws_step: WSTRING;
	// 目標位置
	TargetPos: LREAL;
	// 動作速度
	Velocity: LREAL;
	// 動作減速度
	Dec : LREAL := 0;
(*=======================================
				計時器
=======================================*)
	
	tmr1: TON := (PT := TIME#100MS);
	tmr2: TON := (PT := TIME#100MS);
	tmr100: TON;
	tmr200: TON := (PT := TIME#1S);
	tmr201: TON := (PT := TIME#1S);
	tmr800: TON := (PT := TIME#100MS);
	
	// 超時監視計時器
	tmrWdt: Ton := (PT := TIME#10S0MS);
  	
	
(*=======================================
				軸IO
=======================================*)

	
	Estop_Old: BOOL;
	
	Estop_Trig : R_TRIG;

(*==============================================
					MC 功能快
==============================================*)
	

	Axis1Power	: MC_Power;
	Axis1Reset	: MC_Reset;
	Axis1Stop	: MC_Stop;
	Axis1Halt	: MC_Halt;
	
	fb_AbsMove	: MC_MoveAbsolute;
	fb_RelMove	: MC_MoveRelative;
	fb_Home		: MC_Home;
	fb_BacklashCompensation	: MC_BacklashCompensation;
	
	fb_Axis1_NcIoOutput : MC_WriteNcIoOutput;
	
	
	fb_WriteBoolParameter : MC_WriteBoolParameterPersistent;
	fb_WriteParameter: MC_WriteParameterPersistent;
(*==============================================*)

	Origin_pos: LREAL;
	
	// 軸名稱
	scAxisName : WSTRING;
	
	// 運動距離
	total_Move : POINTER TO LREAL;
	
	
	move_Start_Pos : LREAL;
	move_RTrig : R_TRIG;
	move_FTrig : F_TRIG;
END_VAR

VAR_OUTPUT
	// 功能執行中
	bBuzy 	: BOOL;
	// 功能結束
	bDone	: BOOL;
	// 發生錯誤
	bError	: BOOL;
	// 錯誤步驟
	iErrorID	: INT;
	// 功能錯誤碼
	iFbErrorID	: INT;
	// 已歸零
	bHome	: BOOL;
	// 位置
	fPos : LREAL;
	
	b_ISVALIDREF : BOOL;
END_VAR

VAR_INPUT
	bJogMode: BOOL;
	// 移動軸
	Axis1: REFERENCE TO AXIS_REF;
	// 負極限
	inLimiter: BOOL;
	// 正極限
	outLimiter: BOOL;
	// 原點
	origin : BOOL;
	
	
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF __ISVALIDREF(Axis1) THEN
	b_ISVALIDREF := TRUE;
	Main();
END_IF]]></ST>
    </Implementation>
    <Folder Name="內部程式" Id="{6297c5c6-8a76-4616-a358-09d84e0022a7}" />
    <Folder Name="設定" Id="{406c011a-222e-4998-a714-244a8cbc48eb}" />
    <Method Name="AbsMove" Id="{6b35f866-9611-483b-aa45-8bbce575d68d}">
      <Declaration><![CDATA[METHOD AbsMove : BOOL
VAR_INPUT
	// 目標位置
	_Position : LREAL;
	
	// 移動速度
	_Velocity : LREAL := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bDone := FALSE;
step:=1;
Mode := ActionMode.AbsMove;
TargetPos := _Position;

IF _Velocity = 0 THEN
	Velocity := 10;
ELSE
	Velocity := _Velocity;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="Axis_States" Id="{df6e4bcd-8d81-4f11-a5a4-6246208ce1fe}">
      <Declaration><![CDATA[PROPERTY Axis_States : ST_AxisStatus]]></Declaration>
      <Get Name="Get" Id="{02f07e73-7f55-4c7a-895b-4799f6b65f0e}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Axis1.ReadStatus();
Axis_States := Axis1.Status;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Homing" Id="{abce250f-ea38-4fb8-80e0-ef1eeaec195c}">
      <Declaration><![CDATA[METHOD Homing : BOOL
VAR
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[bDone := FALSE;
step:=1;
Mode := ActionMode.Home;]]></ST>
      </Implementation>
    </Method>
    <Action Name="Main" Id="{d6d523ce-605f-4fc7-b327-0b4f9cd44eef}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[Estop_Trig(CLK:= (SystemError OR Estop) AND bBuzy );

IF Estop_Trig.Q THEN
	iErrorId := step;
	step:=800;
	bDone := FALSE;
END_IF

bBuzy := step > 0 AND step < 10000;
berror := step >= 10000;
IF bBuzy OR berror THEN
	bDone := FALSE;
END_IF
IF bError THEN
	iErrorID := step - 10000;
	
END_IF

ws_step := INT_TO_WSTRING(step);

CASE step OF
	0://程式待命
		tmr1.IN					:= FALSE;
		tmr100.IN				:= FALSE;
		tmr200.IN				:= FALSE;
		tmr201.IN				:= FALSE;
		tmr800.IN				:= FALSE;
		tmrWdt.in 				:= FALSE;
		
END_CASE

IF step > 0 THEN
	Step0_Start();
	Step1_1_AbsMove();
	Step1_2_RelMove();
	Step1_3_Home();
	Step8_End();
END_IF

IF stepA > 0 THEN
	Step9_SetLimit();
END_IF

MC_FB();
fPos := LREAL_TO_REAL(Axis1.NcToPlc.ActPos);
timer();


move_RTrig(CLK := Axis1.Status.Moving);
move_FTrig(CLK := Axis1.Status.Moving);
IF move_RTrig.Q THEN
	move_Start_Pos := fPos;
END_IF 

IF move_FTrig.Q AND total_Move <> 0 THEN
	total_Move^ := total_Move^ + ABS(fPos - move_Start_Pos);
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="MC_FB" Id="{c73e9891-8da6-4f44-aaa3-828dea3e5949}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[// 正轉極限
Axis1Power.Enable_Positive:= OutLimiter;
// 反轉極限
Axis1Power.Enable_Negative:= inLimiter;

Axis1.ReadStatus();

// 軸速度百分比
IF hmi.Auto_Pause THEN
	Axis1Power.Override := 0;
ELSE
	Axis1Power.Override := Axis.Override;
END_IF


(*===================== 軸電源 =====================*)
Axis1Power(Axis:= Axis1);


(*===================== 軸重置 =====================*)
Axis1Reset(Axis:= Axis1);


(*===================== 軸停止 =====================*)
Axis1Stop(Axis:= Axis1);


(*===================== 軸命令取消 =====================*)
Axis1Halt(Axis:= Axis1);


(*===================== 軸絕對移動 =====================*)
fb_AbsMove(Axis:= Axis1);


(*===================== 軸相對移動 =====================*)
fb_RelMove(Axis:= Axis1);

(*===================== 軸歸零 =====================*)
fb_Axis1_NcIoOutput(Axis:= Axis1, Device := NcIoDeviceDrive, NcIoOutput := NcIoOutputnCtrl2);

(*===================== 軸歸零 =====================*)
fb_Home(Axis:= Axis1, HomingMode:= MC_Direct);

(*===================== 軸寫入BOOL參數 =====================*)
fb_WriteBoolParameter(Axis:= Axis1);

(*===================== 軸寫入參數 =====================*)
fb_WriteParameter(Axis:= Axis1);

(*===================== 背隙補償 =====================*)
fb_BacklashCompensation(Axis:= Axis1);]]></ST>
      </Implementation>
    </Action>
