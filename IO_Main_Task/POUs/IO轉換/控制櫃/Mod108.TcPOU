  <POU Name="Mod108" Id="{73916ff3-7785-40d0-80be-95ae5ccdcea3}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Mod108
VAR
	IO_f : ARRAY [1..16] OF IO_force;
	
	i: SINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[	// 輸入模組1
	FOR i := 1 TO 16 DO
		IO_f[i](Raw_IO := MainIO.IO108.Out[i], Out => EtherCAT.MainMod_8.Output[i]);
	END_FOR
	
	
	MainIO.IO108_s.0 := IO_f[1].Out;
	MainIO.IO108_s.1 := IO_f[2].Out;
	MainIO.IO108_s.2 := IO_f[3].Out;
	MainIO.IO108_s.3 := IO_f[4].Out;
	MainIO.IO108_s.4 := IO_f[5].Out;
	MainIO.IO108_s.5 := IO_f[6].Out;
	MainIO.IO108_s.6 := IO_f[7].Out;
	MainIO.IO108_s.7 := IO_f[8].Out;
	MainIO.IO108_s.8 := IO_f[9].Out;
	MainIO.IO108_s.9 := IO_f[10].Out;
	MainIO.IO108_s.10 := IO_f[11].Out;
	MainIO.IO108_s.11 := IO_f[12].Out;
	MainIO.IO108_s.12 := IO_f[13].Out;
	MainIO.IO108_s.13 := IO_f[14].Out;
	MainIO.IO108_s.14 := IO_f[15].Out;
	MainIO.IO108_s.15 := IO_f[16].Out;
	
	MainIO.IO108_f.0 := IO_f[1].ForceEnable;
	MainIO.IO108_f.1 := IO_f[2].ForceEnable;
	MainIO.IO108_f.2 := IO_f[3].ForceEnable;
	MainIO.IO108_f.3 := IO_f[4].ForceEnable;
	MainIO.IO108_f.4 := IO_f[5].ForceEnable;
	MainIO.IO108_f.5 := IO_f[6].ForceEnable;
	MainIO.IO108_f.6 := IO_f[7].ForceEnable;
	MainIO.IO108_f.7 := IO_f[8].ForceEnable;
	MainIO.IO108_f.8 := IO_f[9].ForceEnable;
	MainIO.IO108_f.9 := IO_f[10].ForceEnable;
	MainIO.IO108_f.10 := IO_f[11].ForceEnable;
	MainIO.IO108_f.11 := IO_f[12].ForceEnable;
	MainIO.IO108_f.12 := IO_f[13].ForceEnable;
	MainIO.IO108_f.13 := IO_f[14].ForceEnable;
	MainIO.IO108_f.14 := IO_f[15].ForceEnable;
	MainIO.IO108_f.15 := IO_f[16].ForceEnable;
]]></ST>
