    <Method Name="Str5" Id="{47978ed9-f405-41ed-b234-d7b39e2ad857}">
      <Declaration><![CDATA[METHOD Str5 : WSTRING
VAR_INPUT
	str0 : WSTRING := "";
	str1 : WSTRING := "";
	str2 : WSTRING := "";
	str3 : WSTRING := "";
	str4 : WSTRING := "";
	ErrorCode :DWORD;
END_VAR

VAR
	strtmp1: STRING;
	strtmp2: WSTRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ErrorCode > 16#FFFF THEN
	strtmp1 := DWORD_TO_HEXSTR(in:= ErrorCode, iPrecision:= 8, bLoCase:= FALSE);
ELSE
