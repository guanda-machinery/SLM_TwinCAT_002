    <Action Name="step_6_CarLift_Down" Id="{f4557512-4a81-4185-864f-aadb60eddb91}" FolderPath="內部動作\">
      <Implementation>
        <ST><![CDATA[CASE step OF
	600:
		IF (CarLift_Select AND 16#F) = 0 THEN
			CarLift_Select := 15;
		END_IF
		step := step + 1;
	
	601:
		io.q301 := TRUE;
		IF CarLift_Select.0 THEN
			stepA := 600;
		END_IF
		
		IF CarLift_Select.1 THEN
			stepB := 600;
		END_IF
		
		IF CarLift_Select.2 THEN
			stepC := 600;
		END_IF
		
		IF CarLift_Select.3 THEN
			stepD := 600;
		END_IF
		
		step := step + 1;
		
	602:
		IF stepA = 0 AND stepB = 0 AND stepC = 0 AND stepD = 0 THEN
			step := step + 1;
		ELSIF stepA > 10000 OR stepB > 10000 OR stepC > 10000 OR stepD > 10000 THEN
			step := step + 10000;
		END_IF
		
	603:
		io.q301 := FALSE;
		CarLift_Select := 0;
		bDone := TRUE;
		step := 0;
		
END_CASE

{region "============= 台車A下降  ============="}
CASE stepA OF
	600: // 啟動上升
		io.q201 := FALSE;
		io.q202 := TRUE;
		stepA := stepA + 1;
		
	601: // 啟動超時計時器
		tmrA_10.PT := T#20S;
		tmrA_10.IN := TRUE;
		stepA := stepA + 1;
		
	602: // 等待
		IF NOT io.i203 OR tmrA_10.q THEN
			tmrA_10.in := FALSE;
			
			IF NOT io.i203 THEN
				stepA := stepA + 1;
			ELSIF tmrA_10.q THEN
				io.q202 := FALSE;
				stepA := stepA + 10000;
			END_IF
		END_IF
		
	603: // 成功之後等待1秒
		tmrA_1.PT := T#1S;
		tmrA_1.IN := TRUE;
		IF tmrA_1.Q THEN
			tmrA_1.IN := FALSE;
			io.q202 := FALSE;
			stepA := stepA + 1;
		END_IF
		
	604:
		stepA := 0;
		
END_CASE
{endregion}

{region "============= 台車B下降  ============="}
CASE stepB OF
	600: // 啟動上升
		io.q203 := FALSE;
		io.q204 := TRUE;
		stepB := stepB + 1;
		
	601: // 啟動超時計時器
		tmrB_10.PT := T#20S;
		tmrB_10.IN := TRUE;
		stepB := stepB + 1;
		
	602: // 等待
		IF NOT io.i206 OR tmrB_10.q THEN
			tmrB_10.in := FALSE;
			
			IF NOT io.i206 THEN
				stepB := stepB + 1;
			ELSIF tmrB_10.q THEN
				io.q204 := FALSE;
				stepB := stepB + 10000;
			END_IF
		END_IF
		
	603: // 成功之後等待1秒
		tmrB_1.PT := T#1S;
		tmrB_1.IN := TRUE;
		IF tmrB_1.Q THEN
			io.q204 := FALSE;
			stepB := stepB + 1;
		END_IF
		
	604:
		stepB := 0;
		
END_CASE
{endregion}

{region "============= 台車C下降  ============="}
CASE stepC OF
	600: // 啟動上升
		io.q205 := FALSE;
