      </Implementation>
    </Action>
    <Action Name="step1_1_Pull_over" Id="{37305d7b-9267-4840-bfe3-b66d71cdb976}" FolderPath="內部動作\">
      <Implementation>
        <ST><![CDATA[CASE step1 OF
	100:// 檢查
		TryCount := 0;
		step1 := step1 + 1;
		
	101:
		step1 := 110;
		
	110: // 啟動靠邊油壓閥
		io.q302 := TRUE;
		IF NOT bbuzy THEN
			io.q301 := TRUE;
		END_IF
		step1 := step1 + 1;
		
	111: // 確定原點已脫離
		IF io.i401 THEN
			step1 := step1 + 1;
		END_IF
		
	112: // 程序暫停5秒
		tmr1_01.PT := T#4S;
		tmr1_01.IN := io.i402 AND io.i404;
		
		tmr1_02.PT := T#6S;
		tmr1_02.IN := TRUE;
		IF tmr1_01.Q OR tmr1_02.q THEN
			tmr1_01.IN := FALSE;
			tmr1_02.IN := FALSE;
			
			IF tmr1_01.q THEN
				step1 := 190;
			ELSIF tmr1_02.Q THEN
				step1 := step1 + 1;
			END_IF
		END_IF
		
	113:
		step1 := 120;
		
	120:// 沒推到待命位置
		io.q302 := FALSE;
		step1 := step1 + 1;
		
	121: // 等待回原點
		tmr01.PT := T#1S;
		tmr01.IN := (NOT io.i401 AND NOT io.i403 AND NOT io.i405 AND NOT io.i407);
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step1 := step1 + 1;
		END_IF
		
	122: 
		
		IF TryCount < 4 THEN
			TryCount := TryCount + 1;
			step1 := 110;
		ELSE
			TryCount := 0;
			step1 := step1 + 10000;
		END_IF
		
		
	190:
		
		tmr1_01.PT := T#6S;
		tmr1_01.IN := TRUE;
		IF tmr1_01.Q THEN
			tmr1_01.IN := FALSE;
			step1 := step1 + 1;
		END_IF
		
	191:
		io.q302 := FALSE;
		bdone1 := TRUE;
		step1 := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="step1_2_Pull_over_Jog" Id="{7a1bd5d6-45c2-4260-aa4f-f2d121955929}" FolderPath="內部動作\">
      <Implementation>
        <ST><![CDATA[CASE step1 OF
	200:// 檢查
		step1 := step1 + 1;
		
	201:
		IF io.q302 THEN
			step1 := 220;
		ELSE
			step1 := 210;
		END_IF
		
		
	210: // 啟動靠邊油壓閥
		io.q302 := TRUE;
		IF NOT bbuzy THEN
			io.q301 := TRUE;
		END_IF
		step1 := step1 + 1;
		
	211: // 確定原點已脫離
		tmr01.PT := T#4S;
		tmr01.IN := (io.i401 AND io.i403 AND io.i405 AND io.i407);
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step1 := step1 + 1;
		END_IF
		
	212:
		step1 := 290;
		
	220: // 關閉靠邊油壓閥
		io.q302 := FALSE;
		IF NOT bbuzy THEN
			io.q301 := TRUE;
		END_IF
		step1 := step1 + 1;
		
	221: // 等待回原點
		tmr01.PT := T#4S;
		tmr01.IN := (NOT io.i401 AND NOT io.i403 AND NOT io.i405 AND NOT io.i407);
		IF tmr01.Q THEN
			tmr01.IN := FALSE;
			step1 := step1 + 1;
		END_IF
		
	222: 
		step1 := 290;
		
		
	290:
		bdone1 := TRUE;
		io.q301 := FALSE;
		step1 := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Method Name="Stop" Id="{3b895035-9a2b-4cf4-ad98-a75185892c62}">
      <Declaration><![CDATA[METHOD Stop : BOOL
VAR_INPUT
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[step := 100;]]></ST>
      </Implementation>
    </Method>
