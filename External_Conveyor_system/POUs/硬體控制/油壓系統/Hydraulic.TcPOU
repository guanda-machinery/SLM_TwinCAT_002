		tmrC_1.IN := TRUE;
		IF tmrC_1.Q THEN
			io.q206 := FALSE;
			stepC := stepC + 1;
		END_IF
		
	604:
		stepC := 0;
		
END_CASE
{endregion}

{region "============= 台車D下降  ============="}
CASE stepD OF
	600: // 啟動上升
		io.q207 := FALSE;
		io.q208 := TRUE;
		stepD := stepD + 1;
		
