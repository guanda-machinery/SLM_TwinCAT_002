    <Method Name="PowerOff" Id="{d2f94300-ceeb-4b63-9e63-74910ce0fb3e}">
      <Declaration><![CDATA[METHOD PowerOff : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*===============================
			關閉馬達
  ===============================*)
step:=800;]]></ST>
