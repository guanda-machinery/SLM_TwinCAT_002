<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="AxisBase" Id="{13ea42af-3a80-4fbf-9e20-9c8cb1fe6aa6}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK AxisBase
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	// 模式
	Mode: ActionMode;
	// 步進
	step: INT;
	stepA: INT;
	// 發生錯誤步
	ws_step: WSTRING;
	// 目標位置
	TargetPos: LREAL;
	// 動作速度
	Velocity: LREAL;
	// 動作減速度
	Dec : LREAL := 0;
(*=======================================
				計時器
=======================================*)
	
	tmr1: TON := (PT := TIME#100MS);
	tmr2: TON := (PT := TIME#100MS);
	tmr100: TON;
	tmr200: TON := (PT := TIME#1S);
	tmr201: TON := (PT := TIME#1S);
	tmr800: TON := (PT := TIME#100MS);
	
	// 超時監視計時器
	tmrWdt: Ton := (PT := TIME#10S0MS);
  	
	
(*=======================================
				軸IO
=======================================*)

	
	Estop_Old: BOOL;
	
	Estop_Trig : R_TRIG;

(*==============================================
					MC 功能快
==============================================*)
	

	Axis1Power	: MC_Power;
	Axis1Reset	: MC_Reset;
	Axis1Stop	: MC_Stop;
	Axis1Halt	: MC_Halt;
	
	fb_AbsMove	: MC_MoveAbsolute;
	fb_RelMove	: MC_MoveRelative;
	fb_Home		: MC_Home;
	fb_BacklashCompensation	: MC_BacklashCompensation;
	
	fb_Axis1_NcIoOutput : MC_WriteNcIoOutput;
	
	
	fb_WriteBoolParameter : MC_WriteBoolParameterPersistent;
	fb_WriteParameter: MC_WriteParameterPersistent;
(*==============================================*)

	Origin_pos: LREAL;
	
	// 軸名稱
	scAxisName : WSTRING;
END_VAR

VAR_OUTPUT
	// 功能執行中
	bBuzy 	: BOOL;
	// 功能結束
	bDone	: BOOL;
	// 發生錯誤
	bError	: BOOL;
	// 錯誤步驟
	iErrorID	: INT;
	// 功能錯誤碼
	iFbErrorID	: INT;
	// 已歸零
	bHome	: BOOL;
	// 位置
	fPos : LREAL;
END_VAR

VAR_INPUT
	bJogMode: BOOL;
	// 移動軸
	Axis1: REFERENCE TO AXIS_REF;
	// 負極限
	inLimiter: BOOL;
	// 正極限
	outLimiter: BOOL;
	// 原點
	origin : BOOL;
	
	
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF __ISVALIDREF(Axis1) THEN
	Main();
END_IF]]></ST>
    </Implementation>
    <Folder Name="內部程式" Id="{e5de0d32-1ffe-4a65-a7a5-7df8f1d6ac6e}" />
    <Folder Name="設定" Id="{91b6e104-fcba-496e-9f1a-7709e316e3ed}" />
    <Method Name="AbsMove" Id="{3dbb7e18-f98a-46c0-8fec-c345a6610696}">
      <Declaration><![CDATA[METHOD AbsMove : BOOL
VAR_INPUT
	// 目標位置
	_Position : LREAL;
	
	// 移動速度
	_Velocity : LREAL := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bDone := FALSE;
step:=1;
Mode := ActionMode.AbsMove;
TargetPos := _Position;

IF _Velocity = 0 THEN
	Velocity := 10;
ELSE
	Velocity := _Velocity;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="Axis_States" Id="{7b960861-a51e-4a23-bd65-da67915085c6}">
      <Declaration><![CDATA[PROPERTY Axis_States : ST_AxisStatus]]></Declaration>
      <Get Name="Get" Id="{64f2a350-eead-4386-a897-5b0dd9c30a7d}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Axis1.ReadStatus();
Axis_States := Axis1.Status;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Homing" Id="{d7034322-1188-4828-915b-e064860e8ffe}">
      <Declaration><![CDATA[METHOD Homing : BOOL
VAR
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[bDone := FALSE;
step:=1;
Mode := ActionMode.Home;]]></ST>
      </Implementation>
    </Method>
    <Action Name="Main" Id="{4aeb78d2-a676-4df6-b41b-0e02fb18ad8e}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[Estop_Trig(CLK:= (SystemError OR Estop OR Input.Feed_Reset) AND bBuzy );

IF Estop_Trig.Q THEN
	iErrorId := step;
	step:=800;
	bDone := FALSE;
END_IF

bBuzy := step > 0 AND step < 10000;
berror := step >= 10000;
IF bBuzy OR berror THEN
	bDone := FALSE;
END_IF
IF bError THEN
	iErrorID := step - 10000;
	
END_IF

ws_step := INT_TO_WSTRING(step);

CASE step OF
	0://程式待命
		tmr1.IN					:= FALSE;
		tmr100.IN				:= FALSE;
		tmr200.IN				:= FALSE;
		tmr201.IN				:= FALSE;
		tmr800.IN				:= FALSE;
		tmrWdt.in 				:= FALSE;
		
END_CASE

IF step > 0 THEN
	Step0_Start();
	Step1_1_AbsMove();
	Step1_2_RelMove();
	Step1_3_Home();
	Step8_End();
END_IF

MC_FB();
fPos := LREAL_TO_REAL(Axis1.NcToPlc.ActPos);
timer();
]]></ST>
      </Implementation>
    </Action>
    <Action Name="MC_FB" Id="{9fe6743b-e976-48f4-8b4f-8556b9f99b02}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[// 正轉極限
Axis1Power.Enable_Positive:= OutLimiter;
// 反轉極限
Axis1Power.Enable_Negative:= inLimiter;

Axis1.ReadStatus();

// 軸速度百分比
Axis1Power.Override := Axis.Override; 


(*===================== 軸電源 =====================*)
Axis1Power(Axis:= Axis1);


(*===================== 軸重置 =====================*)
Axis1Reset(Axis:= Axis1);


(*===================== 軸停止 =====================*)
Axis1Stop(Axis:= Axis1);


(*===================== 軸命令取消 =====================*)
Axis1Halt(Axis:= Axis1);


(*===================== 軸絕對移動 =====================*)
fb_AbsMove(Axis:= Axis1);


(*===================== 軸相對移動 =====================*)
fb_RelMove(Axis:= Axis1);

(*===================== 軸歸零 =====================*)
fb_Axis1_NcIoOutput(Axis:= Axis1, Device := NcIoDeviceDrive, NcIoOutput := NcIoOutputnCtrl2);

(*===================== 軸歸零 =====================*)
fb_Home(Axis:= Axis1, HomingMode:= MC_Direct);

(*===================== 軸寫入BOOL參數 =====================*)
fb_WriteBoolParameter(Axis:= Axis1);

(*===================== 軸寫入參數 =====================*)
fb_WriteParameter(Axis:= Axis1);

(*===================== 背隙補償 =====================*)
fb_BacklashCompensation(Axis:= Axis1);]]></ST>
      </Implementation>
    </Action>
    <Property Name="Name" Id="{c448288c-cbd8-45e4-b4dc-0f11df02c1f7}" FolderPath="設定\">
      <Declaration><![CDATA[PROPERTY Name : WSTRING]]></Declaration>
      <Get Name="Get" Id="{c28166b1-5b79-4bc3-9e78-a1f81fb3c27f}">
