<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="Axis_VFD" Id="{edbc04f7-bfb6-425a-9f7c-ee8caf462bd5}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Axis_VFD IMPLEMENTS I_Axis
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	// 模式
	Mode: ActionMode;
	// 步進
	step: INT;
	// 發生錯誤步
	ws_step: WSTRING;
	// 目標位置
	TargetPos: LREAL;
	// 動作速度
	Velocity: LREAL;
	
	
(*=======================================
				計時器
=======================================*)
	
	tmr1: TON := (PT := TIME#100MS);
	tmr2: TON := (PT := TIME#100MS);
	tmr100: TON;
	tmr200: TON := (PT := TIME#1S);
	tmr201: TON := (PT := TIME#1S);
	tmr800: TON := (PT := TIME#100MS);
	
	// 超時監視計時器
	tmrWdt: Ton := (PT := TIME#10S0MS);
  	
	
(*=======================================
				軸IO
=======================================*)
	// 原點
	_Origin				: POINTER TO  BOOL;
	
	// 正極限
	_P_Limit			: POINTER TO  BOOL;
	// 負極限
	_N_Limit			: POINTER TO  BOOL;

	// 編碼器
	_Enc : POINTER TO  MM540;
	
	// 變頻器IO
	Axis1_IO: VFD_E_IO;
	
	Limit_status : WORD;
	
	Estop_Old: BOOL;
	
	Estop_Trig : R_TRIG;

(*==============================================*)

	Origin_pos: LREAL;
	// 位置
	_pos : LREAL;
	
	// 軸名稱
	scAxisName : WSTRING;
	
	
	// 位置誤差量
	_ErrorPos: LREAL;
	
	HightSpeed_Error : LREAL := 470;
	MidSpeed_Error : LREAL := 80;
	
	// 上次位置
	_lastPos: LREAL;
	// 速度
	_speed: LREAL;
	
	// 速度
	_speed_average: ARRAY [0..10] OF LREAL;
	
	i : INT;
END_VAR

VAR_OUTPUT
	// 功能執行中
	bBuzy 	: BOOL;
	// 功能結束
	bDone	: BOOL;
	// 發生錯誤
	bError	: BOOL;
	// 錯誤步驟
	iErrorID	: INT;
	// 功能錯誤碼
	iFbErrorID	: INT;
	// 已歸零
	bHome	: BOOL;
	
	rFindPos : LREAL;
END_VAR

VAR_INPUT
	bJogMode: BOOL;
	
	// 負極限
	inLimiter: BOOL;
	// 正極限
	outLimiter: BOOL;
	// 原點
	origin : BOOL;
	
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[Main();]]></ST>
    </Implementation>
    <Folder Name="內部程式" Id="{86c16185-c8eb-4089-b5a8-48df1e46de8e}" />
    <Folder Name="設定" Id="{775d3b91-ee3f-4c6c-b768-03d09cceb522}" />
