IF _Velocity = 0 THEN
	Velocity := 10;
ELSE
	Velocity := _Velocity;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Set_VFD_IO" Id="{8fe2b810-32af-4cdf-82f5-0abbfb867a05}" FolderPath="設定\">
      <Declaration><![CDATA[METHOD Set_VFD_IO : BOOL
VAR_INPUT
	FWD : LWORD;
	REV : LWORD;
	Speed_Io_1 : LWORD;
	Speed_Io_2 : LWORD;
	Speed_Io_3 : LWORD;
	Reset : LWORD;
	
	Run : LWORD;
	Error : LWORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Axis1_IO.o_FWD := FWD;
Axis1_IO.o_REV := REV;
Axis1_IO.o_Speed1 := Speed_Io_1;
Axis1_IO.o_Speed2 := Speed_Io_2;
Axis1_IO.o_Speed3 := Speed_Io_3;
Axis1_IO.o_Reset := Reset;

Axis1_IO.i_Run := RUN;
Axis1_IO.i_Error := Error;]]></ST>
      </Implementation>
    </Method>
