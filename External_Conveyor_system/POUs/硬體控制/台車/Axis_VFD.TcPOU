END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetLimit_IO" Id="{4e5448ad-2b57-4c53-be51-bba22bc0412a}" FolderPath="設定\">
      <Declaration><![CDATA[METHOD SetLimit_IO : BOOL
VAR_INPUT
	Origin : LWORD;
	
	P_Limit : LWORD;
	
	N_Limit : LWORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Origin := Origin;
_P_Limit := P_Limit;
_N_Limit := N_Limit;]]></ST>
      </Implementation>
    </Method>
    <Action Name="Step0_Start" Id="{7c8f7c1f-eb40-4ac0-904b-31cf2fa1cd95}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*============================
				啟動馬達
	  ============================*)
CASE step OF
	
	1://開始移動流程
		// 設定狀態
		bDone := FALSE;
		Axis1_IO.o_Reset^ :=FALSE;
		tmrWdt.IN := FALSE;
		IF NOT bDone THEN
			step := 10;
		END_IF
		
	10:
		IF NOT Axis1_IO.i_Error^ THEN
			step := step + 1;
		ELSE
			step := 20;
		END_IF
		
	11:
		Axis1_IO.o_Reset^ :=TRUE;
		step := step + 1;
		
	12:
		tmr1.PT := T#2S;
		tmr1.IN := TRUE;
		IF tmr1.Q OR NOT Axis1_IO.i_Error^ THEN
			tmr1.IN := FALSE;
			step := step + 1;
		END_IF


	13:
		Axis1_IO.o_Reset^ :=FALSE;
		IF NOT Axis1_IO.i_Error^ THEN
			// 變頻器錯誤無法重置		
			step := step + 10000;
		ELSE
			step := 20;
		END_IF
		
	20:
		step := 80;
		
	80: //模式選擇
		CASE Mode OF
			ActionMode.AbsMove:
				step := 100;
				
			ActionMode.RelMove:
				step := 200;
				
			ActionMode.Home:
				step := 300;
				
			ActionMode.Find:
				step		:= 400;
				
			ActionMode.DoNothing:
				step := step + 1;
		END_CASE
		
	81:
		bdone := TRUE;
		step := 0;
		
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step1_1_AbsMove" Id="{32a7c67e-d9e6-4936-a163-2c28770f7e33}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*========================================
					開始移動
	=========================================*)	

	

CASE step OF
	100:		
		Axis1_IO.o_Speed1^ 		:= FALSE;
		Axis1_IO.o_Speed2^ 		:= FALSE;
		Axis1_IO.o_Speed3^ 		:= FALSE;
		step := step + 1;
		
	101:
		IF ABS(_ErrorPos) < 2 THEN 
			step:= 190;
		ELSE
			step := step + 1;
		END_IF
		
	102:
		step:= 109;
		
	109:
		step:= 110;
		

	110: // 設定移動位置
		Axis1_IO.o_Speed3^ := TRUE;
		IF _ErrorPos > 0 THEN
			Axis1_IO.o_FWD^ := TRUE;
			Axis1_IO.o_REV^ := FALSE;
		ELSE
			Axis1_IO.o_FWD^ := FALSE;
			Axis1_IO.o_REV^ := TRUE;
		END_IF
	
	
		IF ABS(_ErrorPos) > config.dis_to_MidSpeed AND (Velocity > 0) THEN
			step := step + 1;
		ELSIF ABS(_ErrorPos) > config.dis_to_LowSpeed THEN
			step := 120;
		ELSE
			step := 130;
		END_IF
		
		
	111:
		Axis1_IO.o_Speed2^ := TRUE;
		step := step + 1;
		
	112:
		IF ABS(_ErrorPos) <= ABS(_speed) * 1.5 THEN
			step:=step + 1;
		END_IF
		
	113:
		step:= 120;
		
	120:
		IF ABS(_ErrorPos) > config.dis_to_LowSpeed THEN
			step:=step + 1;
		ELSE
			step := 130;
		END_IF
		
	121:
		Axis1_IO.o_Speed1^ := TRUE;
		Axis1_IO.o_Speed2^ := FALSE;
		step:=step + 1;
		
	122:
		IF ABS(_ErrorPos) <= config.dis_to_LowSpeed THEN
			step:=step + 1;
		END_IF
		
	123:
		step:= 130;
		
	130:
		Axis1_IO.o_Speed1^ := TRUE;
		Axis1_IO.o_Speed2^ := TRUE;
		
		step:=step + 1;
		
	131:
		IF ABS(_speed) < 20 THEN
			Axis1_IO.o_Speed3^ := FALSE;
		END_IF
		
		IF ABS(_ErrorPos) <= 2 THEN
			Axis1_IO.o_FWD^ := FALSE;
			Axis1_IO.o_REV^ := FALSE;
			Axis1_IO.o_Speed1^ := FALSE;
			Axis1_IO.o_Speed2^ := FALSE;
			step:=step + 1;
		END_IF
		
	132:
		step:= 190;


	190:
		bDone := TRUE;
		step:=0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step1_2_RelMove" Id="{9d3e4e8e-d7f3-465e-bd78-44bf72aaae89}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*========================================
					開始移動
	=========================================*)	
CASE step OF
	200:
		fb_RelMove.Execute := FALSE;
		Axis1Halt.Execute := FALSE;
		Axis1Stop.Execute := FALSE;
		step := step + 1;
		
	201:
		IF Velocity = 0 THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str2(scAxisName, ":Rel設定速度為0", 0)
			);
		ELSE
			step := step + 1;
		END_IF
		
	202:
		IF TargetPos = 0 THEN 
			step:= 280;
		ELSE
			step := step + 1;
		END_IF
		
	203:
		IF Axis1.Status.HasJob THEN
			Axis1Halt.Deceleration := 0;
			Axis1Halt.Execute := TRUE;
			step := step + 1;
		ELSE
			step:= 209;
		END_IF
		
	204:
		IF Axis1Halt.Busy OR Axis1Halt.Done OR Axis1Halt.Error THEN
			step:=step + 1;
		END_IF
		
	205:
		IF Axis1Halt.Done THEN
			Axis1Halt.Execute := FALSE;
			step:=step + 1;
		ELSIF Axis1Halt.Error THEN
			Axis1Halt.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	206:
		step:= 209;
		
	209:
		step:= 210;
		

	210: // 設定移動位置
		fb_RelMove.Distance := TargetPos;
		fb_RelMove.Velocity:= Velocity;
		fb_RelMove.BufferMode:= MC_Aborting;
		step:=step + 1;
		
	211:
		fb_RelMove.Execute := TRUE;
		step:=step + 1;
		
	212:
		IF fb_RelMove.Busy OR fb_RelMove.Done OR fb_RelMove.Error THEN
			step:=step + 1;
		END_IF
		
	213:
		IF fb_RelMove.Done THEN
			fb_RelMove.Execute := FALSE;
			step:=step + 1;
		ELSIF fb_RelMove.Error THEN
			pMsg.Push_Error(
				ErrorCodeConver.Str2(scAxisName, ":Rel移動失敗", fb_RelMove.ErrorID)
			);
			fb_RelMove.Execute := FALSE;
			step:=step + 10000;
		END_IF
		
	214:
		step:=290;
		
	280:
		tmr1.PT := T#500MS;
		tmr1.IN := TRUE;
		IF tmr1.Q THEN
			tmr1.IN := FALSE;
			step:=step + 1;
		END_IF
		
	281:
		step := 290;
		
	290:
		bDone := TRUE;
		step:=890;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step1_3_Home" Id="{55dd1d67-6503-4dfb-af12-4efd7081fa19}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[(*========================================
				歸零
=========================================*)	
CASE step OF
	// 檢查是否有原點感應器 ， 沒有直接結束歸零
	300:
		
		IF _Origin > 0 THEN
			step := step + 1;
		ELSE
			step := 0;
		END_IF
		
	301:
		Axis1_IO.o_Speed1^	:= FALSE;
		Axis1_IO.o_Speed2^	:= FALSE;
		Axis1_IO.o_Speed3^	:= FALSE;
		Axis1_IO.o_FWD^ 	:= FALSE;
		Axis1_IO.o_REV^ 	:= FALSE;
		step := 310;
		
	310: // 沒原點開關訊號  (開關已碰到)
		IF NOT _Origin^ THEN
			step := step + 1;
		ELSE
			step := 320;
		END_IF
		
	311:
		Axis1_IO.o_Speed1^ := TRUE;
		Axis1_IO.o_FWD^ := TRUE;
		step := step + 1;
		
	312:
		tmr1.PT := T#2S;
		tmr1.IN := TRUE;
		IF tmr1.Q OR _Origin^ THEN
			tmr1.IN := FALSE;
			Axis1_IO.o_FWD^ := FALSE;
			Axis1_IO.o_Speed1^ := FALSE;
	
			IF _Origin^ THEN
				step := step + 1;
			ELSE
		// !!錯誤!!  原點訊號沒出現
				step := step + 10000;
			END_IF
			
		END_IF
		
	313:
		step := 320;
		
	320: // 往反方向找原點開關
		Axis1_IO.o_Speed3^ := TRUE;
		Axis1_IO.o_Speed1^ := TRUE;
		Axis1_IO.o_Rev^ := TRUE;
		step := step + 1;
		
	321:
		tmr1.PT := T#2m;
		tmr1.IN := TRUE;
		IF tmr1.Q OR not _Origin^ THEN
			tmr1.IN := FALSE;
			Axis1_IO.o_Rev^ := FALSE;
			Axis1_IO.o_Speed1^ := FALSE;
	
			IF NOT _Origin^ THEN
				step := step + 1;
			ELSE
		// !!錯誤!!  原點訊號沒消失
				step := step + 10000;
			END_IF
			
		END_IF
		
	322:
		step := 330;
		
	330: // 往 正方向  脫離原點開關 最慢速
		Axis1_IO.o_Speed1^ := TRUE;
		Axis1_IO.o_Speed2^ := TRUE;
		Axis1_IO.o_Speed3^ := FALSE;
		Axis1_IO.o_FWD^ := TRUE;
		step := step + 1;
		
	331:
		tmr1.PT := T#10S;
		tmr1.IN := TRUE;
		IF tmr1.Q OR _Origin^ THEN
			tmr1.IN := FALSE;
			Axis1_IO.o_FWD^ := FALSE;
			Axis1_IO.o_Speed1^ := FALSE;
			Axis1_IO.o_Speed2^ := FALSE;
			IF _Origin^ THEN
				step := step + 1;
			ELSE
		// !!錯誤!!  原點訊號沒恢復
				step := step + 10000;
			END_IF
			
		END_IF
		
	332:
		step := 340;
		
	340:
		tmr1.PT := T#500ms;
		tmr1.IN := TRUE;
		IF tmr1.Q THEN
			tmr1.IN := FALSE;
			step := step + 1;
		END_IF
		
	341:
		_enc^.SetPos(Config.FeedCar_Enc_Origin_offset);
		bhome := FALSE;
		step := step + 1;
		
	342:
		IF _enc^.bActive THEN
			step := step + 1;
		END_IF
		
	343:
		Axis1_IO.o_Speed1^ := TRUE;
		Axis1_IO.o_Speed2^ := TRUE;
		Axis1_IO.o_FWD^ := TRUE;
		step := step + 1;
		
	344:
		IF _enc^.Done OR _enc^.Error THEN
			Axis1_IO.o_Speed1^ := FALSE;
			Axis1_IO.o_Speed2^ := FALSE;
			Axis1_IO.o_FWD^ := FALSE;
			IF _enc^.Done THEN
				step := step + 1;
			ELSIF _enc^.Error THEN
				step := step + 10000;
			END_IF
		END_IF
		
	345:
		bhome := TRUE;
		bdone := TRUE;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step1_4_Find" Id="{997e2920-cb35-4cdf-9e7f-fc3736dc0598}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*========================================
					開始移動
	=========================================*)	

	

CASE step OF
	400:		
		Axis1_IO.o_Speed1^ 		:= FALSE;
		Axis1_IO.o_Speed2^ 		:= FALSE;
		step := step + 1;
		
	401:
		step := 410;
		
		
	410:
		Axis1_IO.o_Speed1^	:= TRUE;
		Axis1_IO.o_Speed2^	:= FALSE;
		step := step + 1;
		
	411:
		Axis1_IO.o_FWD^ 	:= TRUE;
		step := step + 1;
		
	412:
		tmr1.PT := T#1S;
		tmr1.IN := _speed < 10;
		IF tmr1.Q THEN
			tmr1.IN := FALSE;
			step := step + 1;
		END_IF
		
	413:
		step := 420;
		
		
	420:
		Axis1_IO.o_Speed2^	:= TRUE;
		step := step + 1;
		
	421:
		tmr1.PT := T#0.5S;
		tmr1.IN := _speed < 10;
		IF tmr1.Q THEN
			tmr1.IN := FALSE;
			step := step + 1;
		END_IF
		
	422:
		step := 430;
		
		
	430:
		rFindPos := config.pos_CarPin_StopPoint - _pos;
		step := step + 1;
		
	431:
		Axis1_IO.o_Speed1^	:= TRUE;
		Axis1_IO.o_Speed2^	:= TRUE;
		Axis1_IO.o_FWD^		:= FALSE;
		Axis1_IO.o_REV^		:= TRUE;
		step := step + 1;
		
	432:
		tmr1.PT := T#3S;
		tmr1.IN := TRUE;
		IF tmr1.Q THEN
			tmr1.IN := FALSE;
			step := step + 1;
		END_IF
		
	433:
		Axis1_IO.o_Speed1^	:= FALSE;
		Axis1_IO.o_Speed2^	:= FALSE;
		Axis1_IO.o_Speed3^	:= FALSE;
		Axis1_IO.o_FWD^		:= FALSE;
		Axis1_IO.o_REV^		:= FALSE;
		step := step + 1;
		
	434:
		bdone := TRUE;
		step := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="Step8_End" Id="{ee3b57bd-6d8f-466f-94c0-24ac75cdfaa6}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[	(*======================================
					關閉馬達
	  ======================================*)
CASE step OF
	800:
		Axis1_IO.o_Speed1^	:= FALSE;
		Axis1_IO.o_Speed2^	:= FALSE;
		Axis1_IO.o_Speed3^	:= FALSE;
		Axis1_IO.o_FWD^		:= FALSE;
		Axis1_IO.o_REV^		:= FALSE;
		step := step + 1;
		
	801:
		step := 0;

END_CASE]]></ST>
      </Implementation>
    </Action>
    <Method Name="Stop" Id="{d9802399-faa5-4742-9aee-310b0cd7274e}">
      <Declaration><![CDATA[METHOD Stop : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*===============================
			關閉馬達
  ===============================*)
step:=800;]]></ST>
      </Implementation>
    </Method>
    <Action Name="timer" Id="{5e3dcb98-b13b-42a1-940f-fdc1a23da6b5}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[tmr1();
tmr2();
tmr100(PT:=T#50MS);
tmr200();
tmr201();
tmr800();
tmrWdt();]]></ST>
      </Implementation>
    </Action>
  </POU>
</TcPlcObject>