    </Method>
    <Action Name="Main" Id="{9a51f988-8cd1-4e98-b084-36c6cc75fe4f}" FolderPath="內部程式\">
      <Implementation>
        <ST><![CDATA[Estop_Trig(CLK:= SystemError OR Input.Feed_Reset);

IF Estop_Trig.Q THEN
	iErrorId := step;
	step:=800;
	bDone := FALSE;
END_IF

bBuzy := step > 0 AND step < 10000;
berror := step >= 10000;
IF bBuzy OR berror THEN
	bDone := FALSE;
END_IF

IF bError THEN
	iErrorID := step - 10000;
	Axis1_IO.o_Speed1^ 		:= FALSE;
	Axis1_IO.o_Speed2^ 		:= FALSE;
	Axis1_IO.o_Speed3^ 		:= FALSE;
	Axis1_IO.o_FWD^			:= FALSE;
	Axis1_IO.o_REV^			:= FALSE;
END_IF

IF _N_Limit > 0 THEN
	Limit_status.0 := _N_Limit^;
ELSE
	Limit_status.0 := TRUE;
END_IF

IF _P_Limit > 0 THEN
	Limit_status.1 := _P_Limit^;
ELSE
	Limit_status.1 := TRUE;
END_IF

IF _Origin > 0 THEN
	Limit_status.2 := _Origin^;
END_IF



ws_step := INT_TO_WSTRING(step);

CASE step OF
	0://程式待命
		tmr1.IN					:= FALSE;
		tmr100.IN				:= FALSE;
		tmr200.IN				:= FALSE;
		tmr201.IN				:= FALSE;
		tmr800.IN				:= FALSE;
		tmrWdt.in 				:= FALSE;
		Axis1_IO.o_Speed1^ 		:= FALSE;
		Axis1_IO.o_Speed2^ 		:= FALSE;
		Axis1_IO.o_Speed3^ 		:= FALSE;
		Axis1_IO.o_FWD^			:= FALSE;
		Axis1_IO.o_REV^			:= FALSE;
		
END_CASE

_enc^();



_pos := _Enc^.Pos * Config.FeedCar_Enc_Scal;

_speed_average[10] := (_pos - _lastPos) * 100;

FOR i := 0 TO 9 DO
	_speed_average[9 - i] := _speed_average[10 - i];
END_FOR

_speed := 0;

FOR i := 0 TO 10 DO
	_speed := _speed + _speed_average[i];
END_FOR

_speed := _speed / 11;

_lastPos := _pos;

_ErrorPos := TargetPos - _pos;

IF step > 0 THEN
	Step0_Start();
	Step1_1_AbsMove();
//	Step1_2_RelMove();
	Step1_3_Home();
	Step1_4_Find();
	Step8_End();
END_IF




timer();


// 碰到正轉極限
IF NOT Limit_status.0 AND Axis1_IO.o_REV^ THEN
	Axis1_IO.o_REV^ := FALSE;
END_IF

// 碰到反轉極限
IF NOT Limit_status.1 AND Axis1_IO.o_FWD^ THEN
	Axis1_IO.o_FWD^ := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Action>
