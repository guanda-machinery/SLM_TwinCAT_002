	// 目標位置
	_Position : LREAL;
	// 移動速度
	_Velocity : LREAL := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bDone := FALSE;
step:=1;
Mode := ActionMode.AbsMove;
TargetPos := _Position;
Velocity := _Velocity;]]></ST>
      </Implementation>
    </Method>
