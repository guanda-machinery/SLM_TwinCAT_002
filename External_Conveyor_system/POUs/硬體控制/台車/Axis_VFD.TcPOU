    <Method Name="RelMove" Id="{d221efc8-fbee-45bd-a5d6-f2619f303ee0}">
      <Declaration><![CDATA[METHOD RelMove : BOOL
VAR_INPUT
	// 目標位置
	_Position : LREAL;
	
	// 移動速度
	_Velocity : LREAL := 0;
END_VAR
]]></Declaration>
      <Implementation>
